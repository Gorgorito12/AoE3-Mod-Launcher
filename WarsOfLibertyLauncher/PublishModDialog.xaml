<Window x:Class="WarsOfLibertyLauncher.PublishModDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Publish my mod"
        Width="760" Height="640"
        MinWidth="640" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">

    <!-- Chrome matches LauncherSettingsDialog / TranslationPackagerDialog:
         WindowStyle=None + a custom dark caption with a ✕ close button, so
         the wizard reads as part of the launcher instead of a stock white
         OS title bar. The App.OnStartup class handler installs the
         WM_GETMINMAXINFO (maximise-respects-taskbar) + rounded-corners hooks
         on every WindowStyle=None window, so no per-window interop here. -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Compact form chrome shared across every step. Keeps the wizard's
             form rows tight (40px target height) so all six steps fit in
             the 640px window without needing nested scrollbars per panel. -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BgPanel}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="ErrorText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Title-bar close ✕. Same recipe as the other custom-chrome
             dialogs (red hover). -->
        <Style x:Key="DialogCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Secondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerAlert}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,14,8,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderTitle"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="HeaderStep"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <Button x:Name="CloseHeaderButton"
                        Grid.Column="1"
                        Style="{StaticResource DialogCloseButton}"
                        Content="&#xE8BB;"
                        VerticalAlignment="Top"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="32,18">
            <Grid>
                <!-- Step 1 — Identity: id + displayName (required), author + subtitle (optional). -->
                <StackPanel x:Name="Step1Panel">
                    <!-- Wizard intro — explains what the whole flow produces and
                         where the mod ends up, so step 1 isn't a cold form. -->
                    <Border Background="{DynamicResource BgPanel}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12,10"
                            Margin="0,0,0,14">
                        <TextBlock x:Name="IntroText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock x:Name="Step1Title" Style="{StaticResource FieldLabel}" FontSize="15" Margin="0,0,0,8"/>
                    <TextBlock x:Name="Step1Hint"  Style="{StaticResource FieldHint}" FontStyle="Normal" FontSize="12" Margin="0,0,0,12"/>

                    <TextBlock x:Name="LblId" Style="{StaticResource FieldLabel}"/>
                    <TextBox  x:Name="FieldId"   Style="{StaticResource FieldInput}"/>
                    <TextBlock x:Name="HintId" Style="{StaticResource FieldHint}"/>
                    <TextBlock x:Name="ErrorId" Style="{StaticResource ErrorText}" Visibility="Collapsed"/>

                    <TextBlock x:Name="LblDisplayName" Style="{StaticResource FieldLabel}"/>
                    <TextBox  x:Name="FieldDisplayName" Style="{StaticResource FieldInput}"/>
                    <TextBlock x:Name="HintDisplayName" Style="{StaticResource FieldHint}"/>
                    <TextBlock x:Name="ErrorDisplayName" Style="{StaticResource ErrorText}" Visibility="Collapsed"/>

                    <TextBlock x:Name="LblAuthor" Style="{StaticResource FieldLabel}"/>
                    <TextBox  x:Name="FieldAuthor" Style="{StaticResource FieldInput}"/>
                    <TextBlock x:Name="HintAuthor" Style="{StaticResource FieldHint}"/>

                    <TextBlock x:Name="LblSubtitle" Style="{StaticResource FieldLabel}"/>
                    <TextBox  x:Name="FieldSubtitle" Style="{StaticResource FieldInput}"/>
                    <TextBlock x:Name="HintSubtitle" Style="{StaticResource FieldHint}"/>
                </StackPanel>

                <!-- Step 2 — Look & feel: accent + icon filename + banner filename. -->
                <StackPanel x:Name="Step2Panel" Visibility="Collapsed">
                    <TextBlock x:Name="Step2Title" Style="{StaticResource FieldLabel}" FontSize="15" Margin="0,0,0,8"/>
                    <TextBlock x:Name="Step2Hint"  Style="{StaticResource FieldHint}" FontStyle="Normal" FontSize="12" Margin="0,0,0,12"/>

                    <TextBlock x:Name="LblAccent" Style="{StaticResource FieldLabel}"/>
                    <TextBox  x:Name="FieldAccent" Style="{StaticResource FieldInput}"/>
                    <TextBlock x:Name="HintAccent" Style="{StaticResource FieldHint}"/>
                    <TextBlock x:Name="ErrorAccent" Style="{StaticResource ErrorText}" Visibility="Collapsed"/>

                    <TextBlock x:Name="LblIcon" Style="{StaticResource FieldLabel}"/>
                    <TextBox  x:Name="FieldIcon" Style="{StaticResource FieldInput}"/>
                    <TextBlock x:Name="HintIcon" Style="{StaticResource FieldHint}"/>
                    <TextBlock x:Name="ErrorIcon" Style="{StaticResource ErrorText}" Visibility="Collapsed"/>

                    <TextBlock x:Name="LblBanner" Style="{StaticResource FieldLabel}"/>
                    <TextBox  x:Name="FieldBanner" Style="{StaticResource FieldInput}"/>
                    <TextBlock x:Name="HintBanner" Style="{StaticResource FieldHint}"/>
                    <TextBlock x:Name="ErrorBanner" Style="{StaticResource ErrorText}" Visibility="Collapsed"/>

                    <!-- Reminder that these fields are just filenames — the real
                         PNG/JPG files have to be committed to the PR separately,
                         which is the #1 thing first-time publishers miss. -->
                    <Border Background="{DynamicResource BgPanel}"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12,10"
                            Margin="0,16,0,0">
                        <TextBlock x:Name="ImagesUploadNote"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

                <!-- Step 3 — Install. -->
                <StackPanel x:Name="Step3Panel" Visibility="Collapsed">
                    <TextBlock x:Name="Step3Title" Style="{StaticResource FieldLabel}" FontSize="15" Margin="0,0,0,8"/>
                    <TextBlock x:Name="Step3Hint"  Style="{StaticResource FieldHint}" FontStyle="Normal" FontSize="12" Margin="0,0,0,12"/>

                    <TextBlock x:Name="LblInstallType" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="FieldInstallType"
                              Background="{DynamicResource BgPanel}"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource BorderSubtle}"
                              Padding="8,6" FontSize="12">
                        <ComboBoxItem Content="IsolatedFolder" Tag="IsolatedFolder"/>
                        <ComboBoxItem Content="InPlaceOverlay" Tag="InPlaceOverlay"/>
                    </ComboBox>
                    <TextBlock x:Name="HintInstallType" Style="{StaticResource FieldHint}"/>

                    <TextBlock x:Name="LblDefaultFolder" Style="{StaticResource FieldLabel}"/>
                    <TextBox  x:Name="FieldDefaultFolder" Style="{StaticResource FieldInput}"/>
                    <TextBlock x:Name="HintDefaultFolder" Style="{StaticResource FieldHint}"/>

                    <TextBlock x:Name="LblProbeFile" Style="{StaticResource FieldLabel}"/>
                    <TextBox  x:Name="FieldProbeFile" Style="{StaticResource FieldInput}"/>
                    <TextBlock x:Name="HintProbeFile" Style="{StaticResource FieldHint}"/>

                    <TextBlock x:Name="LblExecutable" Style="{StaticResource FieldLabel}"/>
                    <TextBox  x:Name="FieldExecutable" Style="{StaticResource FieldInput}"/>
                    <TextBlock x:Name="HintExecutable" Style="{StaticResource FieldHint}"/>
                    <TextBlock x:Name="ErrorExecutable" Style="{StaticResource ErrorText}" Visibility="Collapsed"/>

                    <TextBlock x:Name="LblArguments" Style="{StaticResource FieldLabel}"/>
                    <TextBox  x:Name="FieldArguments" Style="{StaticResource FieldInput}"/>
                    <TextBlock x:Name="HintArguments" Style="{StaticResource FieldHint}"/>
                </StackPanel>

                <!-- Step 4 — Updates: mechanism (+ contextual subfields). -->
                <StackPanel x:Name="Step4Panel" Visibility="Collapsed">
                    <TextBlock x:Name="Step4Title" Style="{StaticResource FieldLabel}" FontSize="15" Margin="0,0,0,8"/>
                    <TextBlock x:Name="Step4Hint"  Style="{StaticResource FieldHint}" FontStyle="Normal" FontSize="12" Margin="0,0,0,12"/>

                    <TextBlock x:Name="LblMechanism" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="FieldMechanism"
                              Background="{DynamicResource BgPanel}"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource BorderSubtle}"
                              Padding="8,6" FontSize="12">
                        <ComboBoxItem Content="WolPatcher"        Tag="WolPatcher"/>
                        <ComboBoxItem Content="GitHubReleases"    Tag="GitHubReleases"/>
                        <ComboBoxItem Content="DelegatedExternal" Tag="DelegatedExternal"/>
                        <ComboBoxItem Content="Manual"            Tag="Manual"/>
                    </ComboBox>
                    <TextBlock x:Name="HintMechanism" Style="{StaticResource FieldHint}"/>

                    <!-- WoL patcher subfields. -->
                    <StackPanel x:Name="MechanismWolPanel" Visibility="Collapsed">
                        <TextBlock x:Name="LblWolUpdateInfoUrl" Style="{StaticResource FieldLabel}"/>
                        <TextBox  x:Name="FieldWolUpdateInfoUrl" Style="{StaticResource FieldInput}"/>
                        <TextBlock x:Name="HintWolUpdateInfoUrl" Style="{StaticResource FieldHint}"/>
                    </StackPanel>

                    <!-- GitHub Releases subfields. -->
                    <StackPanel x:Name="MechanismGitHubPanel" Visibility="Collapsed">
                        <TextBlock x:Name="LblSourceRepo" Style="{StaticResource FieldLabel}"/>
                        <TextBox  x:Name="FieldSourceRepo" Style="{StaticResource FieldInput}"/>
                        <TextBlock x:Name="HintSourceRepo" Style="{StaticResource FieldHint}"/>

                        <TextBlock x:Name="LblApprovedTag" Style="{StaticResource FieldLabel}"/>
                        <TextBox  x:Name="FieldApprovedTag" Style="{StaticResource FieldInput}"/>
                        <TextBlock x:Name="HintApprovedTag" Style="{StaticResource FieldHint}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Step 5 — Description + website. -->
                <StackPanel x:Name="Step5Panel" Visibility="Collapsed">
                    <TextBlock x:Name="Step5Title" Style="{StaticResource FieldLabel}" FontSize="15" Margin="0,0,0,8"/>
                    <TextBlock x:Name="Step5Hint"  Style="{StaticResource FieldHint}" FontStyle="Normal" FontSize="12" Margin="0,0,0,12"/>

                    <TextBlock x:Name="LblDescriptionEn" Style="{StaticResource FieldLabel}"/>
                    <TextBox  x:Name="FieldDescriptionEn" Style="{StaticResource FieldInput}"
                              AcceptsReturn="True" TextWrapping="Wrap" Height="70" VerticalScrollBarVisibility="Auto"/>
                    <TextBlock x:Name="HintDescription" Style="{StaticResource FieldHint}"/>

                    <TextBlock x:Name="LblDescriptionEs" Style="{StaticResource FieldLabel}"/>
                    <TextBox  x:Name="FieldDescriptionEs" Style="{StaticResource FieldInput}"
                              AcceptsReturn="True" TextWrapping="Wrap" Height="70" VerticalScrollBarVisibility="Auto"/>

                    <TextBlock x:Name="LblWebsite" Style="{StaticResource FieldLabel}"/>
                    <TextBox  x:Name="FieldWebsite" Style="{StaticResource FieldInput}"/>
                    <TextBlock x:Name="HintWebsite" Style="{StaticResource FieldHint}"/>
                    <TextBlock x:Name="ErrorWebsite" Style="{StaticResource ErrorText}" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Step 6 — Review + actions. -->
                <StackPanel x:Name="Step6Panel" Visibility="Collapsed">
                    <TextBlock x:Name="Step6Title" Style="{StaticResource FieldLabel}" FontSize="15" Margin="0,0,0,8"/>
                    <TextBlock x:Name="Step6Hint"  Style="{StaticResource FieldHint}" FontStyle="Normal" FontSize="12" Margin="0,0,0,12"/>

                    <Border BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="1"
                            Background="{DynamicResource BgPanel}"
                            CornerRadius="4"
                            Padding="2">
                        <TextBox x:Name="JsonPreview"
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource TextPrimary}"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Height="280"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="CopyJsonButton"
                                Background="{DynamicResource BgPanelAlt}"
                                Foreground="{DynamicResource TextPrimary}"
                                BorderBrush="{DynamicResource BorderSubtle}"
                                BorderThickness="1"
                                Padding="14,6"
                                Margin="0,0,10,0"
                                Cursor="Hand"/>
                        <Button x:Name="OpenPrButton"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="14,6"
                                Cursor="Hand"/>
                    </StackPanel>

                    <!-- Post-publish flow — what GitHub / the catalog CI does after
                         the PR is opened, so the modder knows what to expect and
                         isn't left wondering whether anything happened. -->
                    <Border Background="{DynamicResource BgPanel}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="14,12"
                            Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock x:Name="NextStepsTitle"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBlock x:Name="NextStepsBody"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       LineHeight="18"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="CancelButton"
                        Grid.Column="0"
                        Background="Transparent"
                        Foreground="{DynamicResource TextSecondary}"
                        BorderBrush="{DynamicResource BorderSubtle}"
                        BorderThickness="1"
                        Padding="16,8"
                        Cursor="Hand"/>
                <Button x:Name="BackButton"
                        Grid.Column="2"
                        Background="{DynamicResource BgPanelAlt}"
                        Foreground="{DynamicResource TextPrimary}"
                        BorderBrush="{DynamicResource BorderSubtle}"
                        BorderThickness="1"
                        Padding="16,8"
                        Margin="0,0,10,0"
                        Cursor="Hand"/>
                <Button x:Name="NextButton"
                        Grid.Column="3"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="20,8"
                        FontWeight="SemiBold"
                        Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>
