<Window x:Class="WarsOfLibertyLauncher.PasswordPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Password"
        Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">
    <StackPanel Margin="24,20">
        <TextBlock x:Name="PromptText"
                   Foreground="{DynamicResource TextPrimary}"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>
        <PasswordBox x:Name="PasswordEntry"
                     Background="#2a2d34"
                     Foreground="White"
                     BorderBrush="#3a3d44"
                     BorderThickness="1"
                     Padding="8,5"
                     FontSize="12"
                     MaxLength="50"/>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelButton"
                    Click="CancelButton_Click"
                    Style="{StaticResource SidebarPrimaryButton}"
                    Background="#3a3d44"
                    Padding="18,6"
                    MinWidth="100"
                    Margin="0,0,8,0"
                    Content="Cancel"/>
            <Button x:Name="OkButton"
                    Click="OkButton_Click"
                    IsDefault="True"
                    Style="{StaticResource SidebarPrimaryButton}"
                    Padding="18,6"
                    MinWidth="100"
                    Content="OK"/>
        </StackPanel>
    </StackPanel>
</Window>
