<Window x:Class="WarsOfLibertyLauncher.LauncherSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Launcher Settings"
        Height="600" Width="820"
        MinHeight="540" MinWidth="720"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">

    <!--
        Launcher-wide settings dialog. Layout refactored from "one long
        scroll with section headers" to "sidebar tabs" to match the per-
        mod Properties dialog — each section gets the full content area
        instead of competing for vertical real estate. Tabs:
          GENERAL     — Language, autostart, close-on-game, tray, toasts,
                        Radmin assistant mode
          UPDATES     — Auto-check-on-startup, open-post-update-pages
          MODS CATALOG— Default/Custom/Disabled source + clear cache
          MAINTENANCE — Clear cached mod icons + clear scratch temp

        Chrome:
          • WindowStyle=None + WindowChrome — custom dark title bar
          • Single ✕ close button top-right (same recipe as
            ModPropertiesDialog)
          • Sticky Cancel/Save footer so the actions never scroll off
            (was true in the previous design, preserved here)

        Code-behind contract: every named element (CheckBox, ComboBox,
        Button, TextBox, hint TextBlock) carries the same name as before
        so the existing LoadFromConfig / SaveButton_Click logic ports
        across unchanged. The only new code is SetActiveTab + four
        TabXxxBtn_Click handlers, copied verbatim from ModPropertiesDialog.
    -->

    <!-- ResizeBorderThickness=6 enables edge-drag resize even though
         WindowStyle=None hides the native chrome — paired with
         ResizeMode=CanResize above, the user can stretch the dialog
         from any edge or corner. CaptionHeight=40 still scopes the
         drag area to the header row so the sidebar tabs stay
         clickable instead of starting a drag on click. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="6"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Hairline divider between groups inside a tab panel. Same
             recipe as ModPropertiesDialog's DialogDivider — duplicated
             here because that style lives in the per-Window resources
             of the other dialog and isn't reachable from this scope. -->
        <Style x:Key="DialogDivider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource BorderSubtle}"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Margin" Value="0,18,0,18"/>
        </Style>

        <!-- Hint caption under checkboxes/radios/buttons. Indented 22 px
             to align with the box's label text. -->
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="22,1,0,8"/>
        </Style>

        <!-- CheckBox / RadioButton / TextBox / ComboBox are now themed
             globally by Styles/Inputs.xaml (dark surfaces, gold accent,
             and — crucially for ComboBox — a full dark ControlTemplate so
             the dropdown popup isn't white). The old local colour-only
             styles lived here but couldn't retemplate the ComboBox, which
             is why the language dropdown rendered white. Removed so the
             global implicit styles apply. -->
        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- Title-bar close ✕. Inline template instead of {StaticResource
             DialogCloseButton} because that style is local to the
             ModPropertiesDialog Window scope. -->
        <Style x:Key="DialogCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Secondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerAlert}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Sidebar + content -->
            <RowDefinition Height="Auto"/>   <!-- Sticky action bar -->
        </Grid.RowDefinitions>

        <!-- =========================================================
             HEADER — compact single row: title + close.
             ========================================================= -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgSidebar}"
                BorderBrush="{DynamicResource BorderSecondary}"
                BorderThickness="0,0,0,1"
                Padding="22,10,8,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="TitleText"
                           FontFamily="{DynamicResource DisplayFont}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"/>
                <Button x:Name="CloseHeaderBtn"
                        Grid.Column="1"
                        Style="{StaticResource DialogCloseButton}"
                        Content="&#xE8BB;"
                        VerticalAlignment="Center"
                        Click="CancelButton_Click"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>
        </Border>

        <!-- =========================================================
             SIDEBAR + TAB PANELS
             ========================================================= -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left tab rail. Same pattern as ModPropertiesDialog so
                 the two settings surfaces feel like siblings. -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BgSidebar}"
                    BorderBrush="{DynamicResource BorderSecondary}"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="0,16,0,0">
                    <Button x:Name="TabGeneralBtn"
                            Style="{StaticResource SidebarNavButton}"
                            Click="TabGeneralBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TabGeneralLabel"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="TabInterfaceBtn"
                            Style="{StaticResource SidebarNavButton}"
                            Click="TabInterfaceBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A1;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TabInterfaceLabel"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="TabUpdatesBtn"
                            Style="{StaticResource SidebarNavButton}"
                            Click="TabUpdatesBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE895;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TabUpdatesLabel"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="TabCatalogBtn"
                            Style="{StaticResource SidebarNavButton}"
                            Click="TabCatalogBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8F1;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TabCatalogLabel"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="TabTranslationsBtn"
                            Style="{StaticResource SidebarNavButton}"
                            Click="TabTranslationsBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xF2B7;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TabTranslationsLabel"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="TabMaintenanceBtn"
                            Style="{StaticResource SidebarNavButton}"
                            Click="TabMaintenanceBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TabMaintenanceLabel"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Right content area. Each panel is one tab; only one is
                 Visible at a time (driven by SetActiveTab). -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="32,24,32,24">

                    <!-- ===================================================
                         GENERAL TAB
                         =================================================== -->
                    <StackPanel x:Name="GeneralPanel" Visibility="Visible">

                        <!-- Language row: label + combo on one line. -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       x:Name="LanguageLabel"
                                       Foreground="#ddd"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      x:Name="LanguageCombo"
                                      Width="220"
                                      HorizontalAlignment="Left">
                                <ComboBoxItem Content="English" Tag="en"/>
                                <ComboBoxItem Content="Español" Tag="es"/>
                            </ComboBox>
                        </Grid>

                        <!-- Theme picker removed: the launcher is dorado-
                             imperial dark-only by design now. The old
                             light theme dictionary (Styles/Colors.Light.xaml)
                             predated the secondary palette, Workshop badges,
                             multiplayer brushes etc. — switching to it
                             threw every DynamicResource consumer onto a
                             null brush and crashed the app. Picker, config
                             field, ThemeService and light dictionary were
                             all deleted together. -->

                        <CheckBox x:Name="StartWithWindowsCheck"/>
                        <TextBlock x:Name="StartWithWindowsHint" Style="{StaticResource HintText}"/>

                        <CheckBox x:Name="CloseOnGameCheck"/>
                        <TextBlock x:Name="CloseOnGameHint" Style="{StaticResource HintText}"/>

                        <CheckBox x:Name="MinimizeToTrayCheck"/>
                        <TextBlock x:Name="MinimizeToTrayHint" Style="{StaticResource HintText}"/>

                        <CheckBox x:Name="ShowToastsCheck"/>
                        <TextBlock x:Name="ShowToastsHint" Style="{StaticResource HintText}"/>

                        <Border Style="{StaticResource DialogDivider}"/>

                        <!-- Radmin assistant mode — decides whether the
                             guided overlay auto-opens on the Multiplayer
                             tab. Combo items built in code-behind so the
                             labels can follow the language switch. -->
                        <TextBlock x:Name="RadAsstLabelText"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <ComboBox x:Name="RadAsstCombo"
                                  Width="280"
                                  HorizontalAlignment="Left"
                                  SelectionChanged="RadAsstCombo_SelectionChanged"/>
                        <TextBlock x:Name="RadAsstHintText"
                                   Style="{StaticResource HintText}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- ===================================================
                         INTERFACE TAB — reorder the top nav tabs.
                         The rows in TabOrderList are built in code-behind
                         from the in-memory order list so ↑/↓ reordering is
                         just a re-render. The first row = the tab that
                         opens on launch.
                         =================================================== -->
                    <StackPanel x:Name="InterfacePanel" Visibility="Collapsed">
                        <TextBlock x:Name="TabOrderLabel"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="TabOrderHint"
                                   Style="{StaticResource HintText}"
                                   Margin="0,0,0,14"/>
                        <!-- One row per nav tab (built by RenderTabOrderList).
                             Each row: position badge + tab name + ↑/↓. -->
                        <StackPanel x:Name="TabOrderList"
                                    HorizontalAlignment="Left"
                                    MinWidth="360"/>
                    </StackPanel>

                    <!-- ===================================================
                         UPDATES TAB
                         =================================================== -->
                    <StackPanel x:Name="UpdatesPanel" Visibility="Collapsed">
                        <CheckBox x:Name="AutoCheckCheck"/>
                        <TextBlock x:Name="AutoCheckHint" Style="{StaticResource HintText}"/>

                        <CheckBox x:Name="OpenPostUpdateCheck"/>
                        <TextBlock x:Name="OpenPostUpdateHint" Style="{StaticResource HintText}"/>
                    </StackPanel>

                    <!-- ===================================================
                         MODS CATALOG TAB
                         =================================================== -->
                    <StackPanel x:Name="CatalogPanel" Visibility="Collapsed">
                        <RadioButton x:Name="CatalogDefaultRadio" GroupName="Catalog"/>
                        <RadioButton x:Name="CatalogCustomRadio"
                                     GroupName="Catalog"
                                     Margin="0,8,0,2"/>
                        <TextBox x:Name="CatalogCustomBox"
                                 Margin="22,2,0,2"
                                 Width="380"
                                 HorizontalAlignment="Left"/>
                        <TextBlock x:Name="CatalogInvalidText"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   FontSize="11"
                                   Margin="22,2,0,4"
                                   Visibility="Collapsed"/>
                        <RadioButton x:Name="CatalogDisabledRadio"
                                     GroupName="Catalog"
                                     Margin="0,8,0,0"/>

                        <Border Style="{StaticResource DialogDivider}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    x:Name="ClearCacheButton"
                                    Style="{StaticResource PropertyActionButton}"
                                    MinWidth="180"
                                    Click="ClearCacheButton_Click"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="ClearCacheHint"
                                       Style="{StaticResource HintText}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <!-- ===================================================
                         TRANSLATIONS TAB — translator-facing entry point
                         to the packaging workflow. The packager itself is
                         a separate modal dialog (multi-section form +
                         async export step) — this tab is just the
                         description + launch button so casual users see
                         what the feature is for without leaving Settings.
                         The packager is globalised across mods, so the
                         tab body doesn't depend on which mod is active.
                         =================================================== -->
                    <StackPanel x:Name="TranslationsPanel" Visibility="Collapsed">
                        <TextBlock x:Name="TranslationsHeader"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="TranslationsDescription"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>
                        <Button x:Name="OpenPackagerButton"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="240"
                                HorizontalAlignment="Left"
                                Click="OpenPackagerButton_Click"/>
                        <TextBlock x:Name="TranslationsHint"
                                   Style="{StaticResource HintText}"
                                   Margin="0,10,0,0"/>
                    </StackPanel>

                    <!-- ===================================================
                         MAINTENANCE TAB
                         =================================================== -->
                    <StackPanel x:Name="MaintenancePanel" Visibility="Collapsed">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    x:Name="ClearAssetsButton"
                                    Style="{StaticResource PropertyActionButton}"
                                    MinWidth="180"
                                    Click="ClearAssetsButton_Click"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="ClearAssetsHint"
                                       Style="{StaticResource HintText}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    x:Name="ClearTempButton"
                                    Style="{StaticResource PropertyActionButton}"
                                    MinWidth="180"
                                    Click="ClearTempButton_Click"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="ClearTempHint"
                                       Style="{StaticResource HintText}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- =========================================================
             STICKY ACTION BAR — Cancel + Save, always visible.
             ========================================================= -->
        <Border Grid.Row="2"
                Background="{DynamicResource BgPanel}"
                Padding="24,16"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        Style="{StaticResource DialogButton}"
                        Margin="0,0,12,0"
                        Click="CancelButton_Click"/>
                <Button x:Name="SaveButton"
                        Style="{StaticResource PrimaryButton}"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
