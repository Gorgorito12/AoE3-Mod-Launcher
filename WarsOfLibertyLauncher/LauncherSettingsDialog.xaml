<Window x:Class="WarsOfLibertyLauncher.LauncherSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Launcher Settings"
        Width="600"
        SizeToContent="Height"
        MaxHeight="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#ddd"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#ddd"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- Section header: small-caps coloured label that separates
             groups of settings (General / Updates / Mods catalog). Matches
             the style of the sidebar gear-menu section headers. -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,16,0,4"/>
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="22,1,0,6"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2a2d34"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3a3d44"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2a2d34"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3a3d44"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource BgBase}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>      <!-- Scrollable settings -->
            <RowDefinition Height="Auto"/>   <!-- Sticky action bar -->
        </Grid.RowDefinitions>

        <!-- Scrollable settings area. Padding leaves room for the vertical
             scrollbar (Chrome.xaml gives ScrollViewer a default 0,0,8,0
             gutter, which we override with explicit per-side padding so
             the content edges align nicely on both axes). -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,20,16,20">
            <StackPanel>
                <!-- Title -->
                <TextBlock x:Name="TitleText"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>

            <!-- ===== GENERAL ===== -->
            <TextBlock x:Name="SectionGeneralText" Style="{StaticResource SectionHeader}"/>

            <Grid Margin="0,4,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="LanguageLabel"
                           Foreground="#ddd"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          x:Name="LanguageCombo"
                          Width="200"
                          HorizontalAlignment="Left">
                    <ComboBoxItem Content="English" Tag="en"/>
                    <ComboBoxItem Content="Español" Tag="es"/>
                </ComboBox>
            </Grid>

            <!-- Theme picker removed: the launcher is dorado-imperial
                 dark-only by design now. The old light theme dictionary
                 (Styles/Colors.Light.xaml) was stale — it predated the
                 secondary palette, Workshop badges, multiplayer brushes,
                 progress-tone gradients, etc., so switching to it threw
                 every DynamicResource consumer onto a null brush and
                 crashed the app. Deleted the picker, the config field,
                 the ThemeService, and the light dictionary together so
                 the dark theme can't accidentally come back as an
                 option that doesn't actually work. -->

            <CheckBox x:Name="StartWithWindowsCheck"/>
            <TextBlock x:Name="StartWithWindowsHint" Style="{StaticResource HintText}"/>

            <CheckBox x:Name="CloseOnGameCheck"/>
            <TextBlock x:Name="CloseOnGameHint" Style="{StaticResource HintText}"/>

            <CheckBox x:Name="MinimizeToTrayCheck"/>
            <TextBlock x:Name="MinimizeToTrayHint" Style="{StaticResource HintText}"/>

            <CheckBox x:Name="ShowToastsCheck"/>
            <TextBlock x:Name="ShowToastsHint" Style="{StaticResource HintText}"/>

            <!-- Radmin assistant mode. Decides whether the guided
                 overlay auto-opens on the Multiplayer tab. -->
            <TextBlock x:Name="RadAsstLabelText"
                       Foreground="{DynamicResource TextPrimary}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,10,0,4"/>
            <ComboBox x:Name="RadAsstCombo"
                      Width="280"
                      HorizontalAlignment="Left"
                      SelectionChanged="RadAsstCombo_SelectionChanged"/>
            <TextBlock x:Name="RadAsstHintText" Style="{StaticResource HintText}"/>

            <!-- ===== UPDATES ===== -->
            <TextBlock x:Name="SectionUpdatesText" Style="{StaticResource SectionHeader}"/>

            <CheckBox x:Name="AutoCheckCheck"/>
            <TextBlock x:Name="AutoCheckHint" Style="{StaticResource HintText}"/>

            <CheckBox x:Name="OpenPostUpdateCheck"/>
            <TextBlock x:Name="OpenPostUpdateHint" Style="{StaticResource HintText}"/>

            <!-- ===== MODS CATALOG ===== -->
            <TextBlock x:Name="SectionCatalogText" Style="{StaticResource SectionHeader}"/>

            <RadioButton x:Name="CatalogDefaultRadio" GroupName="Catalog"/>
            <RadioButton x:Name="CatalogCustomRadio"
                         GroupName="Catalog"
                         Margin="0,4,0,2"/>
            <TextBox x:Name="CatalogCustomBox"
                     Margin="22,2,0,2"
                     Width="320"
                     HorizontalAlignment="Left"/>
            <TextBlock x:Name="CatalogInvalidText"
                       Foreground="{DynamicResource ErrorBrush}"
                       FontSize="11"
                       Margin="22,2,0,4"
                       Visibility="Collapsed"/>
            <RadioButton x:Name="CatalogDisabledRadio"
                         GroupName="Catalog"
                         Margin="0,4,0,0"/>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        x:Name="ClearCacheButton"
                        Style="{StaticResource DialogButton}"
                        Click="ClearCacheButton_Click"/>
                <TextBlock Grid.Column="1"
                           x:Name="ClearCacheHint"
                           Style="{StaticResource HintText}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
            </Grid>

            <!-- ===== MAINTENANCE ===== -->
            <TextBlock x:Name="SectionMaintenanceText" Style="{StaticResource SectionHeader}"/>

            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        x:Name="ClearAssetsButton"
                        Style="{StaticResource DialogButton}"
                        Click="ClearAssetsButton_Click"/>
                <TextBlock Grid.Column="1"
                           x:Name="ClearAssetsHint"
                           Style="{StaticResource HintText}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
            </Grid>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        x:Name="ClearTempButton"
                        Style="{StaticResource DialogButton}"
                        Click="ClearTempButton_Click"/>
                <TextBlock Grid.Column="1"
                           x:Name="ClearTempHint"
                           Style="{StaticResource HintText}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
            </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Sticky action bar — always visible regardless of scroll position
             so Save/Cancel never get pushed off-screen by long content. -->
        <Border Grid.Row="1"
                Background="{DynamicResource BgPanel}"
                Padding="24,16"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        Style="{StaticResource DialogButton}"
                        Margin="0,0,12,0"
                        Click="CancelButton_Click"/>
                <Button x:Name="SaveButton"
                        Style="{StaticResource PrimaryButton}"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
