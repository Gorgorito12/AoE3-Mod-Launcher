<Window x:Class="WarsOfLibertyLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:WarsOfLibertyLauncher.Controls"
        Title="AoE3 Mod Launcher"
        Height="700" Width="1100"
        MinHeight="620" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource BgBase}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed">
    <!-- WindowChrome (caption drag + edge-resize + snap/Aero) is applied
         centrally in App.OnAnyWindowLoaded from the TitleBarHeight token; the
         title bar itself is the shared controls:TitleBar below (Grid.Row=0). -->

    <Window.Resources>
        <!-- Dark-themed tooltip: matches the rest of the launcher's UI
             instead of the default OS pale-yellow rectangle. Applied
             implicitly to every ToolTip in this Window and its descendants. -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#22252c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3a3d44"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4"
                                MaxWidth="380">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10"
                                                  ShadowDepth="2"
                                                  Color="Black"
                                                  Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- (Removed local SidebarPrimaryButton style — the redesign
             relies on the global one from Styles/Buttons.xaml which
             has the gold gradient + glow effect. Window.Resources used
             to override it with a flat fill, which defeated the
             premium hero CTA look.) -->

        <!-- Sidebar action buttons coded by operation. Background + border
             come from each button instance, so the same template handles
             every color variant: cyan for Update, purple for Verify, amber
             for Repair, soft-red for Uninstall, etc. -->
        <Style x:Key="SidebarColoredButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                                <Setter Property="Foreground" Value="#aaa"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar secondary actions — Actualizar, Configuración, Abrir
             carpeta, Verificar archivos. Stretched full width, left-aligned
             label so they line up like a settings list. -->
        <Style x:Key="SidebarSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2a2d34"/>
            <Setter Property="Foreground" Value="#ddd"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3a3d44"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#22252c"/>
                                <Setter Property="Foreground" Value="#666"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tabs across the top of the right-hand content panel. The active
             tab gets its underline + brighter foreground programmatically
             from RefreshTabs() in code-behind. -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Margin" Value="0,0,28,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LangToggle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="{DynamicResource BgPanelAlt}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="8"/>
        </Style>

        <!-- Thin dark scrollbar — replaces the Windows-default light gray
             one so it blends with the rest of the theme. Track is fully
             transparent; the thumb is a subtle pill that brightens on
             hover/drag. The up/down repeat buttons are templated to empty
             so the bar is a pure track + thumb (matches VS Code / Discord
             / Spotify). -->
        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="#3a3d44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Margin="1,0"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5a5d64"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Empty repeat-button template so the up/down arrows disappear
             from the scrollbar without breaking its hit-testing. -->
        <Style x:Key="ScrollBarHiddenButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarHiddenButton}"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarHiddenButton}"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Horizontal variant — same template but with a thin height. -->
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Default ScrollViewer padding: reserves a thin gutter on the
             right so when the scrollbar appears it doesn't push the
             content sideways. The scrollbar is 6 px wide and we reserve 8
             so it has 1 px of breathing room on each side. -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Padding" Value="0,0,8,0"/>
        </Style>

        <!-- The Min/Max/Close caption-button styles moved to the global
             Styles/Chrome.xaml (TitleBarButton / TitleBarCloseButton),
             consumed by the shared controls:TitleBar — no per-window copy. -->
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Custom title bar (shared controls:TitleBar, height = TitleBarHeightMain token = classic 36; the slim 28px is secondary-windows only) -->
            <RowDefinition Height="38"/>   <!-- Horizontal nav strip (Steam-style); compact, 14px main tabs -->
            <RowDefinition Height="*"/>    <!-- App content -->
        </Grid.RowDefinitions>

        <!-- =============================================================
             CUSTOM TITLE BAR — replaces the white Windows-default
             chrome with our own painted strip in BgSidebar so the
             whole window reads as one cohesive dark surface. App
             icon + window title on the left; min / max / close on
             the right. Drag works automatically over CaptionHeight
             (set in WindowChrome above); buttons mark themselves
             hit-test-visible-in-chrome so they aren't blocked by
             the drag area.

             NO bottom border here on purpose: the nav-tab strip
             below (Grid.Row=1) shares the exact same BgSidebar fill,
             so a divider between them would draw a visible seam
             through what should read as one continuous chrome
             surface. The seam below the nav tabs is the nav strip's
             OWN bottom border — that one stays, since it delimits
             chrome from content. -->
        <!-- Main header opts OUT of the slim secondary bar: pins the classic
             36px height + 46/10 buttons so the brand bar + nav strip are
             untouched. Height reads TitleBarHeightMain so it matches the
             CaptionHeight App.ApplyWindowChrome assigns to MainWindow. -->
        <controls:TitleBar Grid.Row="0"
                           Height="{StaticResource TitleBarHeightMain}"
                           ButtonWidth="46"
                           GlyphSize="10"
                           ShowMinimize="True"
                           ShowMaximize="True"
                           ShowClose="True">
                <!-- Title-bar brand button — clickable, opens the same
                     brand menu as the AOE3 LAUNCHER button in the nav
                     strip below. Steam-pattern: clicking the launcher
                     name in the title bar should open the launcher
                     menu (Launcher settings / About / Exit).
                     IsHitTestVisibleInChrome=True so WindowChrome's
                     drag handler doesn't swallow the click. -->
                <!-- Title-bar brand button uses the SAME interaction recipe
                     as NavTabButton (the LIBRARY/WORKSHOP/MULTIPLAYER tabs):
                     the text illuminates instead of painting a background
                     tile. Implemented as a Button.Style — NOT inline
                     attributes — on purpose:
                       • idle Foreground is a STYLE setter (precedence 7),
                         so the template's hover/press/open Foreground
                         triggers (precedence 4-6) can override it. A local
                         Foreground ATTRIBUTE (precedence 3) beats the
                         triggers and the colour never changes — that was
                         the earlier bug.
                       • the ContentPresenter is left DEFAULT (no explicit
                         Foreground): a ContentControl's ContentPresenter
                         auto-propagates the templated parent's Foreground to
                         the content text, so when a trigger flips the
                         Button's Foreground the icon-label TextBlocks follow.
                         (Setting TextElement.Foreground directly on the
                         ContentPresenter did NOT propagate — that's why the
                         previous attempt looked dead.)
                     States: idle = dim Secondary, hover = #E6EEF8 (near-white,
                     the same token the nav tabs lift to), pressed/open =
                     #FFFFFF pure white (open held while the brand popup lives
                     via Tag="open", set in BrandMenuButton_Click). -->
                <!-- Brand block = the TitleBar's Content. No left Padding and no
                     Grid.Column (dead from when it lived in MainWindow's own grid):
                     it now sits flush at the TitleBar's content gutter
                     (TitleBarContentPadding.Left = 18), the same left edge the nav
                     tabs use, so brand + tabs are anchored to one consistent gutter. -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button x:Name="TitleBarBrandButton"
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Cursor="Hand"
                        Click="BrandMenuButton_Click"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground" Value="{DynamicResource Secondary}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Left"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#E6EEF8"/>
                                            </Trigger>
                                            <!-- Pressed + Open after hover so
                                                 they win when both match; pure
                                                 white vs hover's near-white
                                                 keeps press/open distinct. -->
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="Tag" Value="open">
                                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <!-- Source is the 256x256 PNG (sibling to AppIcon.ico,
                             see csproj) NOT the .ico, because WPF's ICO codec
                             picks the smallest frame >= the requested logical
                             size and downscales it: at 20-logical-pixels it
                             selects the 24x24 frame and stretches, which is
                             visibly soft. The PNG decoder skips that frame
                             selection — HighQuality bicubic downscales the
                             native 256x256 directly to the physical pixel
                             size, which lands crisp at every DPI (the global
                             UseLayoutRounding + Display formatting from
                             App.OnStartup pin it to integer device pixels).
                             DecodePixelWidth=256 decodes the NATIVE frame so the
                             only resample is the renderer's single HighQuality
                             bicubic downscale (256 → 20-40 physical px). The
                             earlier 64 cap pre-shrank in the decoder first, so a
                             non-integer 64→40 second downscale softened the icon;
                             decoding native keeps it sharp. Costs ~256 KB RAM
                             instead of ~16 KB — trivial, and worth it for a crisp
                             brand mark. (Size stays 20x20: sharper, not bigger.) -->
                        <Image Width="20" Height="20"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Source>
                                <BitmapImage UriSource="pack://application:,,,/AppIcon.png"
                                             DecodePixelWidth="256"
                                             CacheOption="OnLoad"/>
                            </Image.Source>
                            <!-- Illuminate with the text. The icon is a
                                 bitmap, not a glyph, so it can't follow
                                 Foreground like the wordmark does — it
                                 brightens via Opacity instead: 0.7 dimmed
                                 at rest (same rest tone as the chevron),
                                 1.0 full on hover or while the brand menu
                                 is open. Bound to the ancestor brand
                                 button's IsMouseOver / Tag because the
                                 Image lives in the button CONTENT, not its
                                 template, so the template's Foreground
                                 triggers can't reach it. -->
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Opacity" Value="0.7"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="open">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Text="AoE3 Mod Launcher"
                                   FontFamily="{DynamicResource DisplayFont}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <!-- Chevron flips ▾↔▴ in code-behind on open/close
                             to signal the dropdown is expanded. Named so
                             BrandMenuButton_Click can swap the glyph. -->
                        <TextBlock x:Name="BrandChevron"
                                   Text="&#xE70D;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   Margin="6,1,0,0"
                                   Opacity="0.7"/>
                    </StackPanel>
                </Button>
                <!-- Persistent, non-invasive launcher self-update reminder.
                     Replaces the old auto-modal that got permanently silenced
                     on Cancel (SkippedLauncherTag). Shown whenever a newer
                     launcher version exists; stays visible on EVERY launch until
                     the user updates (no permanent dismiss). Click opens the
                     existing download/restart dialog. Gold pill with dark text
                     for contrast; pulses once per session (LauncherUpdatePillScale).
                     Self-contained template so the global Button style doesn't
                     flatten the pill look. IsHitTestVisibleInChrome=True so the
                     window-drag handler doesn't swallow the click. Text + tooltip
                     are localized from code-behind. -->
                <Button x:Name="LauncherUpdatePill"
                        Visibility="Collapsed"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Margin="14,0,0,0"
                        FontFamily="{DynamicResource BodyFont}"
                        FontSize="{StaticResource FontSizeCaption}"
                        Click="LauncherUpdatePill_Click"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <ScaleTransform x:Name="LauncherUpdatePillScale" ScaleX="1" ScaleY="1"/>
                    </Button.RenderTransform>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <!-- The text comes from the Button's Content (set in
                                 code-behind) via the ContentPresenter — x:Name'd
                                 elements inside a ControlTemplate live in their own
                                 namescope and aren't reachable from code-behind, so
                                 we drive the label through Content instead. -->
                            <Border x:Name="pillBorder"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="{StaticResource RadiusMd}"
                                    Padding="10,3">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            TextElement.Foreground="#1A1A1A"
                                            TextElement.FontWeight="SemiBold">
                                    <TextBlock Text="&#xE777;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="pillBorder" Property="Opacity" Value="0.88"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                </StackPanel>
        </controls:TitleBar>

        <!-- =============================================================
             OFFLINE CHIP. Overlaid on the title bar (Grid.Row=0), to the
             LEFT of the notification bell (inset clears the bell + caption
             buttons). Visible only when ConnectivityState.IsOffline (driven
             from code-behind). Reuses the MpStatusOffline brush; a colored
             dot avoids depending on a specific Segoe MDL2 glyph. Click forces
             a connectivity re-check so the user can retry without waiting for
             the periodic refresh. IsHitTestVisibleInChrome so the window-drag
             handler doesn't eat the click (same recipe as the bell/brand).
             ============================================================= -->
        <Grid Grid.Row="0"
              HorizontalAlignment="Right"
              VerticalAlignment="Stretch"
              Margin="0,0,200,0"
              Panel.ZIndex="10"
              shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Button x:Name="OfflineChip"
                    Visibility="Collapsed"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    Click="OfflineChip_Click"
                    FontFamily="{DynamicResource BodyFont}"
                    FontSize="{StaticResource FontSizeCaption}"
                    ToolTipService.InitialShowDelay="400"
                    ToolTipService.ShowDuration="8000">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="chipBorder"
                                Background="#33201A18"
                                BorderBrush="{DynamicResource MpStatusOffline}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}"
                                Padding="8,2">
                            <!-- Label comes from the Button's Content (set in
                                 code-behind) — an x:Name'd element inside a
                                 ControlTemplate lives in its own namescope and
                                 isn't reachable from code-behind, so we drive the
                                 text through Content + ContentPresenter, like the
                                 launcher-update pill above. -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                        TextElement.Foreground="{DynamicResource MpStatusOffline}">
                                <Ellipse Width="8" Height="8"
                                         Fill="{DynamicResource MpStatusOffline}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="chipBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- =============================================================
             NOTIFICATION BELL (Steam-style). Overlaid on the title bar
             (Grid.Row=0), right-aligned and inset by the width of the 3
             caption buttons (ButtonWidth 46 × 3 = 138) so it sits just to
             their left. IsHitTestVisibleInChrome=True so the window-drag
             handler doesn't swallow the click (same recipe as the brand
             button above). Badge + one-shot pulse are driven from code.
             ============================================================= -->
        <Grid Grid.Row="0"
              HorizontalAlignment="Right"
              VerticalAlignment="Stretch"
              Margin="0,0,148,0"
              Panel.ZIndex="10"
              shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Button x:Name="NotificationBellButton"
                    Click="NotificationBell_Click"
                    MouseEnter="NotificationBell_MouseEnter"
                    MouseLeave="NotificationBell_MouseLeave"
                    VerticalAlignment="Stretch"
                    ToolTipService.InitialShowDelay="500"
                    ToolTipService.ShowDuration="5000"
                    Style="{StaticResource NotificationBellButton}">
                <Button.ToolTip>
                    <ToolTip x:Name="NotifToolTip"
                             Style="{StaticResource NotifToolTipStyle}"
                             Content="Notificaciones"/>
                </Button.ToolTip>
                <Grid Width="24" Height="24">
                    <!-- Bell drawn as a SOLID vector path (gold) rather than a
                         Segoe MDL2 glyph (which renders as an outline). The pulse
                         animation (PulseNotificationBell) rotates NotificationBellRotate. -->
                    <Path x:Name="NotificationBellGlyph"
                          Fill="#99FFFFFF"
                          Stroke="Black"
                          StrokeThickness="0.6"
                          StrokeLineJoin="Round"
                          Stretch="Uniform"
                          Width="16" Height="16"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          RenderTransformOrigin="0.5,0.15"
                          Data="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.63-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.64 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="NotificationBellRotate" Angle="0"/>
                        </Path.RenderTransform>
                    </Path>
                    <!-- Small unread indicator dot (7px), top-right corner. Thin
                         dark ring separates it from the bell / bar. -->
                    <Ellipse x:Name="NotificationDot"
                             Width="7" Height="7"
                             Fill="#E5484D"
                             Stroke="{DynamicResource BgBase}"
                             StrokeThickness="1"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Margin="0,0,-1,0"
                             Visibility="Collapsed"/>
                </Grid>
            </Button>

            <!-- Dropdown panel. Right-aligned under the bell (HorizontalOffset
                 shifts the 360-wide card left so its right edge lands near the
                 bell). Items + empty-state visibility are wired in code-behind. -->
            <Popup x:Name="NotificationPopup"
                   PlacementTarget="{Binding ElementName=NotificationBellButton}"
                   Placement="Bottom"
                   StaysOpen="True"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   HorizontalOffset="-316"
                   VerticalOffset="2">
                <Border Width="360"
                        Background="{DynamicResource MpSurface}"
                        BorderBrush="{DynamicResource MpDivider}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Margin="8"
                        SnapsToDevicePixels="True">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="3" Opacity="0.5"/>
                    </Border.Effect>
                    <DockPanel LastChildFill="True">
                        <!-- Header -->
                        <Grid DockPanel.Dock="Top" Margin="14,12,10,8">
                            <TextBlock x:Name="NotificationPanelTitle"
                                       Text="Notifications"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontFamily="{DynamicResource DisplayFont}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button x:Name="NotificationMarkAllRead"
                                        Click="NotificationMarkAllRead_Click"
                                        Content="Mark all read"
                                        Style="{StaticResource NotifLinkButton}"/>
                                <TextBlock Text="·"
                                           Foreground="{DynamicResource MpDivider}"
                                           Margin="6,0"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="NotificationClearAll"
                                        Click="NotificationClearAll_Click"
                                        Content="Clear"
                                        Style="{StaticResource NotifLinkButton}"/>
                            </StackPanel>
                        </Grid>

                        <Border DockPanel.Dock="Top"
                                Height="1"
                                Background="{DynamicResource MpDivider}"/>

                        <!-- Empty state -->
                        <TextBlock x:Name="NotificationEmptyText"
                                   DockPanel.Dock="Top"
                                   Text="No notifications"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,28,0,30"
                                   Visibility="Collapsed"/>

                        <!-- Items -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      MaxHeight="380">
                            <ItemsControl x:Name="NotificationList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Tag="{Binding}"
                                                Click="NotificationItem_Click"
                                                HorizontalContentAlignment="Stretch"
                                                Style="{StaticResource NotifRowButton}">
                                            <Grid Margin="14,9,12,9">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Kind glyph -->
                                                <TextBlock Grid.Column="0"
                                                           VerticalAlignment="Top"
                                                           Margin="0,1,10,0"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="16"
                                                           Foreground="{DynamicResource TextSecondary}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="&#xEA8F;"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Kind}" Value="UpdateAvailable">
                                                                    <Setter Property="Text" Value="&#xE896;"/>
                                                                    <Setter Property="Foreground" Value="#5AA9E6"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="UpdateFinished">
                                                                    <Setter Property="Text" Value="&#xE930;"/>
                                                                    <Setter Property="Foreground" Value="#62C462"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="NewTranslation">
                                                                    <Setter Property="Text" Value="&#xF2B7;"/>
                                                                    <Setter Property="Foreground" Value="#D8B66A"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="LauncherUpdate">
                                                                    <Setter Property="Text" Value="&#xE777;"/>
                                                                    <Setter Property="Foreground" Value="#D4A04A"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="Connectivity">
                                                                    <Setter Property="Text" Value="&#xE774;"/>
                                                                    <Setter Property="Foreground" Value="#8AA0B4"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="NewMod">
                                                                    <Setter Property="Text" Value="&#xE710;"/>
                                                                    <Setter Property="Foreground" Value="#B48AD8"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- Title + body + time -->
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="{DynamicResource TextPrimary}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Body}"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Margin="0,1,0,0"/>
                                                    <TextBlock Text="{Binding CreatedLocal, StringFormat='{}{0:dd MMM, HH:mm}'}"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               FontSize="11"
                                                               Opacity="0.7"
                                                               Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <!-- Unread dot -->
                                                <Ellipse Grid.Column="2"
                                                         Width="8" Height="8"
                                                         Margin="8,4,0,0"
                                                         VerticalAlignment="Top"
                                                         Fill="#E5484D">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Read}" Value="True">
                                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Popup>
        </Grid>

        <!-- =============================================================
             HORIZONTAL NAVIGATION (Steam-style redesign). Replaces
             the old 240px vertical sidebar. Three content tabs only
             — the brand dropdown (Launcher settings / About / Exit)
             lives EXCLUSIVELY in the title bar above, so it's not
             duplicated here. Same x:Names as the old vertical
             sidebar so code-behind (RefreshTopTabHighlight,
             ApplyStrings, SwitchTopTab) keeps working unchanged.
             ============================================================= -->
        <Border Grid.Row="1"
                Background="{DynamicResource BgSidebar}"
                BorderBrush="{DynamicResource BorderSecondary}"
                BorderThickness="0,0,0,1">
            <StackPanel x:Name="TopTabBar"
                        Orientation="Horizontal"
                        VerticalAlignment="Stretch">
                <!-- Content tabs — icon + label inline. Active state
                     is driven by Tag="active" via RefreshTopTabHighlight
                     in code-behind. The left-to-right child order is
                     re-applied at startup from LauncherConfig.TopTabOrder
                     by ApplyTopTabOrder() — the XAML order here is just
                     the default for a fresh config. -->
                <Button x:Name="TopTabPlay"
                        Style="{StaticResource NavTabButton}"
                        Click="TopTabPlay_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE80F;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="SidebarLabelDashboard" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="TopTabMods"
                        Style="{StaticResource NavTabButton}"
                        Click="TopTabMods_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7C5;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="SidebarLabelCatalog" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="TopTabMultiplayer"
                        Style="{StaticResource NavTabButton}"
                        Click="TopTabMultiplayer_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE716;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="SidebarLabelMultiplayer" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- =============================================================
             Content area. Now full-width (no sidebar column eating
             240px). PlayView is the "cinema" dashboard. Other tabs
             (Workshop, Multiplayer, Settings) overlay on top when
             active.

             ClipToBounds guards the seamless title-bar + nav chrome above
             (Rows 0/1): everything in this row — the full-bleed dashboard
             background image, the hero gradients, the scaled hero block —
             is clipped to the row so none of it can render up over the
             chrome. This is the safety net for the maximized full-bleed
             image reading as if it bleeds into the nav strip; it does NOT
             touch the chrome itself, so the one-surface look (no title-bar
             divider) is preserved.
             ============================================================= -->
        <Grid x:Name="ContentHost" Grid.Row="2" ClipToBounds="True">

            <!-- ============================================================
                 PLAY VIEW — cinema dashboard.
                 Hero background image of active mod + dark gradient
                 overlays + bottom-anchored title/desc/PLAY/Settings/
                 ChangeMod row + progress strip.
                 All the legacy controls (ModsBar, HeroBanner, StatusCard,
                 ActionPanel, ProgressPanel, MainTabs) stay alive inside
                 LegacyPlayContent (Visibility=Collapsed) so the dozens
                 of code-behind references resolve and the install /
                 update / progress data still pumps through them. The
                 visible Dashboard buttons forward to those hidden
                 controls' click handlers.
                 ============================================================ -->
            <Grid x:Name="PlayView">

                <!-- Layer 1: the hero painted Stretch=Fill (the brush is
                     built in code in RefreshActiveMod) so it fills the whole
                     panel edge-to-edge with NO side bands and NO crop — at the
                     cost of distorting the hero's aspect ratio in a non-16:9
                     window. The maintainer picked stretch-to-fill over both
                     the old two-layer blurred-margin design (read as side
                     bands, "franjas") and a UniformToFill cover (disliked the
                     top/bottom crop). Fallback when no hero is a neutral dark
                     gradient, also set in RefreshActiveMod.
                     HighQuality scaling keeps 4K heroes crisp when decoded down.
                     DashboardBgFill is the BASE; DashboardBgFillB is the crossfade
                     overlay (opacity 0 at rest) for the rotating-hero feature —
                     ApplyDashboardHero owns both. Keep B right here, BEFORE the
                     dim gradients, or the overlay would cover the readability
                     scrims. -->
                <Border x:Name="DashboardBgFill"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        Background="{DynamicResource BgPanelAlt}"/>
                <Border x:Name="DashboardBgFillB"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        Opacity="0"/>

                <!-- Layer 2: vertical gradient — transparent at top,
                     opaque at bottom — so the title/desc/buttons at the
                     bottom-left stay readable on any hero image. -->
                <Rectangle IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#66000000" Offset="0.0"/>
                            <GradientStop Color="#22000000" Offset="0.40"/>
                            <GradientStop Color="#ee131313" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- Layer 2b: horizontal left-side dim so the title
                     reads even on bright images. -->
                <Rectangle IsHitTestVisible="False"
                           HorizontalAlignment="Left"
                           Width="640">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#cc000000" Offset="0.0"/>
                            <GradientStop Color="#00000000" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- (Layer 3 removed — the top-right utility row with the
                     gear-cog Launcher Settings button and EN/ES language
                     toggles was retired per user request. Both flows are
                     still reachable from the title-bar brand menu
                     (🛡 AoE3 Mod Launcher ▼ → "Launcher settings"),
                     where the LauncherSettingsDialog hosts the language
                     combo too. The handlers stay in code-behind because
                     LauncherSettingsButton_Click is reused by the brand
                     menu wiring.) -->

                <!-- Layer 4: hero content — title, description, action
                     row, and the progress strip. Anchored bottom-left
                     so it sits over the dimmest part of the overlay.

                     The whole block is wrapped in HeroScaleTransform so it
                     auto-fits the resolution: 1:1 on a 1600x900-or-larger
                     screen and shrinking gently on anything smaller
                     (so the text isn't oversized on small laptops).
                     UpdateHeroScale() in code-behind divides the live
                     footprint by a FIXED ~1600x900 reference and drives
                     ScaleX/ScaleY off SizeChanged. RenderTransform
                     (not LayoutTransform) with RenderTransformOrigin="0,1"
                     pins the bottom-left corner so the block shrinks in
                     place over the dim corner of the hero image without
                     reflowing or nudging the layers behind it.

                     Text crispness: the global HiDPI setup renders all text
                     in TextFormattingMode=Display (pixel-snapped), which looks
                     crisp at 1:1 but BLURRY once a ScaleTransform shrinks it.
                     UpdateHeroScale() flips this subtree to Ideal + Animated
                     hinting whenever scale < 1.0 (smooth under transform) and
                     back to Display at exactly 1.0 (maximized) so the full-
                     size hero keeps its pixel-crisp look. -->
                <!-- Hero block. The window-size scale + bottom-left render-pin
                     are installed in code by UiScale.Attach(... Kind.Render,
                     origin 0,1) — see the constructor. Keep this subtree free of
                     a static RenderTransform so the scaler owns it. -->
                <Grid x:Name="HeroContentGrid"
                      Margin="48,0,48,32" VerticalAlignment="Bottom">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title + description block. Narrow column (was 900):
                         keeps the hero copy reading vertically instead of
                         sprawling across the panel, and lets multi-line
                         "Game: Subtitle" titles stack cleanly. -->
                    <StackPanel Grid.Row="0" MaxWidth="640" HorizontalAlignment="Left">
                        <!-- Mod/game icon (catalog icon.png or built-in packed
                             icon). Filled + shown by RefreshActiveModBanner;
                             collapsed when the active mod has no icon. -->
                        <Border x:Name="DashboardIconHost"
                                Width="64" Height="64"
                                CornerRadius="{StaticResource RadiusLg}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,14"
                                Visibility="Collapsed">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Color="Black" Opacity="0.6"/>
                            </Border.Effect>
                        </Border>
                        <TextBlock x:Name="DashboardTitleText"
                                   FontFamily="{DynamicResource DisplayFont}"
                                   FontSize="48"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   LineHeight="56"
                                   LineStackingStrategy="BlockLineHeight"
                                   TextWrapping="Wrap">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="2" Color="Black" Opacity="0.85"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <!-- Version chip — installed-version of the active
                             mod. Painted in the green Status-Installed
                             palette (same as the Catalog "Installed"
                             badge) so the colour itself reads as "you
                             have this version on disk, everything's
                             healthy" — green = good, like the rest of
                             the app's status badges. Hidden by code-
                             behind when no version is known (fresh
                             machine before CheckAsync ran, or for mods
                             that haven't been installed yet). -->
                        <Border x:Name="DashboardVersionChip"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,0"
                                Padding="10,3"
                                CornerRadius="{StaticResource RadiusLg}"
                                BorderBrush="{DynamicResource StatusInstalledFg}"
                                BorderThickness="1"
                                Background="{DynamicResource StatusInstalledBg}"
                                Visibility="Collapsed">
                            <TextBlock x:Name="DashboardVersionText"
                                       FontFamily="{DynamicResource DisplayFont}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource StatusInstalledFg}"/>
                        </Border>
                        <!-- Description copy: SecondaryFixed (#d2e4fb)
                             — bright cool body tone so the paragraph
                             reads against the dim hero background
                             without competing with the dorado title. -->
                        <TextBlock x:Name="DashboardDescText"
                                   FontFamily="{DynamicResource BodyFont}"
                                   FontSize="14"
                                   Foreground="{DynamicResource SecondaryFixed}"
                                   LineHeight="22"
                                   TextWrapping="Wrap"
                                   MaxWidth="780"
                                   Margin="0,14,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Color="Black" Opacity="0.7"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>

                    <!-- Action row: PLAY (gold gradient + glow) +
                         settings gear + change mod. -->
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="0,28,0,0">
                        <Button x:Name="DashboardPlayButton"
                                Style="{StaticResource SidebarPrimaryButton}"
                                MinWidth="220"
                                Padding="34,16"
                                Click="DashboardPlayButton_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE768;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="20"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="DashboardPlayButtonText"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="18"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="DashboardSettingsButton"
                                Style="{StaticResource DashboardSecondaryButton}"
                                Width="64"
                                Margin="14,0,0,0"
                                Padding="0"
                                Click="DashboardSettingsButton_Click"
                                ToolTip="Mod actions">
                            <TextBlock Text="&#xE713;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="22"
                                       HorizontalAlignment="Center"/>
                        </Button>
                        <Button x:Name="DashboardChangeModButton"
                                Style="{StaticResource DashboardSecondaryButton}"
                                Margin="14,0,0,0"
                                Padding="22,0"
                                Click="DashboardChangeModButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8FD;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="18"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="DashboardChangeModButtonText"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           FontFamily="{DynamicResource DisplayFont}"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Progress strip. Always visible; the label flips
                         between "Ready for operations" (idle) and the
                         live update label (running). Speed/Eta/Pct cells
                         show "—" when idle.
                         Capped at MaxWidth so the bar doesn't stretch
                         the full hero width — the HTML mock has a much
                         tighter progress footprint that lives next to
                         the bottom-left content column, not flush to
                         the right edge of the panel. -->
                    <StackPanel Grid.Row="2"
                                x:Name="DashboardProgressContainer"
                                HorizontalAlignment="Left"
                                MaxWidth="860"
                                Margin="0,28,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <!-- Pause / Cancel column. Only visible
                                     while an op is running; the
                                     SyncDashboardProgressFromLegacyPanel
                                     pump flips its visibility from the
                                     legacy ProgressRunningActions row. -->
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="DashboardProgressIcon"
                                               Text="&#xE73E;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock x:Name="DashboardProgressLabel"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontFamily="{DynamicResource DisplayFont}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Cool secondary tone for the subtitle "Listo
                                     para operaciones / Descargando…" so the
                                     bigger gold label above carries the
                                     visual weight. -->
                                <TextBlock x:Name="DashboardProgressSubtitle"
                                           Foreground="{DynamicResource OnSecondaryContainer}"
                                           FontSize="11"
                                           Margin="22,2,0,0"/>
                            </StackPanel>
                            <!-- Column-header microtype labels switch to the
                                 cool Secondary tone so they read as quiet
                                 metadata. Data values stay dorado so the
                                 user's eye locks onto the actual numbers. -->
                            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                <TextBlock Text="VELOCIDAD"
                                           Foreground="{DynamicResource Secondary}"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                                <!-- Data values use SecondaryFixed (cool
                                     bright blue-white) so progress reads
                                     as informational metadata. Dorado is
                                     reserved for the main progress label
                                     + the indicator bar. -->
                                <TextBlock x:Name="DashboardProgressSpeed"
                                           Foreground="{DynamicResource SecondaryFixed}"
                                           FontSize="13"
                                           Text="—"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="14,0,0,0">
                                <TextBlock Text="TIEMPO RESTANTE"
                                           Foreground="{DynamicResource Secondary}"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="DashboardProgressEta"
                                           Foreground="{DynamicResource SecondaryFixed}"
                                           FontSize="13"
                                           Text="—"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="14,0,0,0">
                                <TextBlock Text="PROGRESO"
                                           Foreground="{DynamicResource Secondary}"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="DashboardProgressPercent"
                                           Foreground="{DynamicResource SecondaryFixed}"
                                           FontSize="13"
                                           Text="—"/>
                            </StackPanel>

                            <!-- Pause + Cancel for the currently running
                                 operation. Hidden in idle state; visible
                                 only when ProgressRunningActions on the
                                 legacy panel is visible. Clicks are
                                 forwarded to the legacy buttons so the
                                 existing pause/resume/cancel logic in
                                 PauseButton_Click / CancelButton_Click
                                 keeps owning the decisions. -->
                            <StackPanel Grid.Column="4"
                                        x:Name="DashboardProgressActions"
                                        Orientation="Horizontal"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <Button x:Name="DashboardPauseButton"
                                        Style="{StaticResource DashboardSecondaryButton}"
                                        Width="36" Height="36"
                                        Padding="0"
                                        Click="DashboardPauseButton_Click"
                                        ToolTip="Pause/Resume">
                                    <TextBlock x:Name="DashboardPauseButtonIcon"
                                               Text="&#xE769;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="13"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="DashboardCancelButton"
                                        Style="{StaticResource DashboardSecondaryButton}"
                                        Width="36" Height="36"
                                        Padding="0"
                                        Margin="8,0,0,0"
                                        Click="DashboardCancelButton_Click"
                                        ToolTip="Cancel">
                                    <TextBlock Text="&#xE711;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="13"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                        <ProgressBar x:Name="DashboardProgressBar"
                                     Style="{StaticResource ShimmerProgressBar}"
                                     Height="4"
                                     Value="0"/>
                    </StackPanel>
                </Grid>

                <!-- LEGACY COMPAT: hidden but tree-attached so the
                     existing code-behind keeps working (RefreshActiveMod,
                     RefreshActionPanel, RefreshStatusCard, all the
                     MainTabs handlers, etc.). The visible Dashboard
                     above mirrors data from these on Refresh*. -->
                <Grid x:Name="LegacyPlayContent" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="ModsBarLabel"/>
                        <StackPanel x:Name="ModCardsPanel" Orientation="Horizontal"/>
                        <controls:HeroBanner x:Name="ActiveModBanner"/>
                        <controls:StatusCard x:Name="StatusCardControl"/>
                        <controls:ActionPanel x:Name="ActionPanelControl"/>
                        <controls:ProgressPanel x:Name="ProgressPanelControl"/>
                        <controls:MainTabs x:Name="MainTabsControl"/>
                        <Border x:Name="ProgressOverlay" Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </Grid>   <!-- /PlayView -->

            <!-- v0.9 mod browser — appears overlaying the cinema dashboard
                 when CATALOG is active in the sidebar. -->
            <controls:ModsBrowser x:Name="ModsBrowserView" Visibility="Collapsed"/>

            <!-- v1.0 multiplayer lobby. -->
            <controls:MultiplayerTab x:Name="MultiplayerView" Visibility="Collapsed"/>

            <!-- Settings tab placeholder. -->
            <Grid x:Name="SettingsView" Visibility="Collapsed"
                  Background="{DynamicResource BgBase}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="500">
                    <TextBlock x:Name="SettingsTeaserText"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="{StaticResource FontSizeBodyStrong}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"/>
                    <Button x:Name="OpenSettingsTabButton"
                            Style="{StaticResource SidebarPrimaryButton}"
                            HorizontalAlignment="Center"
                            MinWidth="200"
                            Click="OpenSettingsTabButton_Click"/>
                </StackPanel>
            </Grid>

        </Grid>   <!-- /Content host (root Grid.Column=1) -->

        <!-- Hidden compatibility shim. The old layout had an "AoE3PathRow" that
             code-behind sometimes referenced; the new design folds that info
             into the game footer, so this is just a placeholder so the existing
             references keep compiling. -->
        <StackPanel x:Name="AoE3PathRow" Visibility="Collapsed"/>
        <TextBlock x:Name="InstallPathText" Visibility="Collapsed"/>
        <TextBlock x:Name="LblModPath" Visibility="Collapsed"/>

        <!-- System-tray icon. Hidden by default; the code-behind shows it
             when the user has "Minimize to tray on close" enabled and they
             close the main window. Double-click the tray icon to restore;
             right-click to get a tiny context menu (Show / Exit). The
             icon resource is pack://-loaded so it survives single-file
             publish. -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        IconSource="pack://application:,,,/AppIcon.ico"
                        Visibility="Collapsed"
                        TrayMouseDoubleClick="TrayIcon_DoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="TrayMenuShow" Click="TrayMenuShow_Click"/>
                    <Separator/>
                    <MenuItem x:Name="TrayMenuExit" Click="TrayMenuExit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
