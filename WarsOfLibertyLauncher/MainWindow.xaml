<Window x:Class="WarsOfLibertyLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wars of Liberty Launcher"
        Height="620" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#1a1d24">

    <Window.Resources>
        <Style x:Key="LauncherButton" TargetType="Button">
            <Setter Property="Background" Value="#c8102e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="22,11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#e63950"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#3a3d44"/>
                                <Setter Property="Foreground" Value="#888"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LangToggle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#2a2d34"/>
            <Setter Property="Foreground" Value="#c8102e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Version cards -->
            <RowDefinition Height="*"/>      <!-- News placeholder -->
            <RowDefinition Height="Auto"/>   <!-- Update transition header -->
            <RowDefinition Height="Auto"/>   <!-- Status -->
            <RowDefinition Height="Auto"/>   <!-- Progress block -->
            <RowDefinition Height="Auto"/>   <!-- Action buttons -->
        </Grid.RowDefinitions>

        <!-- Header with language toggle -->
        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="WARS OF LIBERTY"
                           FontSize="32" FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock x:Name="SubtitleText"
                           FontSize="14" Foreground="#888"
                           Margin="0,-4,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button x:Name="LangEnButton" Style="{StaticResource LangToggle}"
                        Content="EN" Click="LangEnButton_Click"/>
                <TextBlock Text="|" Foreground="#444"
                           VerticalAlignment="Center" Margin="2,0"/>
                <Button x:Name="LangEsButton" Style="{StaticResource LangToggle}"
                        Content="ES" Click="LangEsButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Version info card -->
        <Border Grid.Row="1"
                Background="#22252c"
                CornerRadius="6"
                Padding="16,12"
                Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="LblInstalledVersion" Foreground="#888" FontSize="11"/>
                    <TextBlock x:Name="CurrentVersionText"
                               Text="—" Foreground="White"
                               FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="LblLatestVersion" Foreground="#888" FontSize="11"/>
                    <TextBlock x:Name="LatestVersionText"
                               Text="—" Foreground="White"
                               FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <Grid>
                        <TextBlock x:Name="LblModPath" Foreground="#888" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BrowseButton"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#888"
                                FontSize="10"
                                Cursor="Hand"
                                Padding="4,0"
                                Click="BrowseButton_Click"/>
                    </Grid>
                    <TextBlock x:Name="InstallPathText"
                               Text="—" Foreground="White"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- News placeholder -->
        <Border Grid.Row="2"
                Background="#22252c"
                CornerRadius="6"
                Margin="0,16,0,16">
            <TextBlock x:Name="NewsPlaceholderText"
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontStyle="Italic"/>
        </Border>

        <!-- Update transition header (visible during updates) -->
        <TextBlock x:Name="UpdateHeaderText"
                   Grid.Row="3"
                   Text=""
                   Foreground="White"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"
                   Visibility="Collapsed"/>

        <!-- Status -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="4"
                   Text=""
                   Foreground="#ddd"
                   FontSize="13"
                   Margin="0,0,0,8"
                   TextTrimming="CharacterEllipsis"/>

        <!-- Progress block -->
        <StackPanel Grid.Row="5" Margin="0,0,0,20">
            <!-- Per-patch progress -->
            <Grid Margin="0,0,0,2">
                <TextBlock x:Name="LblCurrentPatch" Foreground="#888" FontSize="11"/>
                <TextBlock x:Name="PatchBytesText"
                           Foreground="#aaa" FontSize="11"
                           HorizontalAlignment="Right"/>
            </Grid>
            <ProgressBar x:Name="PatchProgress" Margin="0,0,0,12"/>

            <!-- Overall progress -->
            <Grid Margin="0,0,0,2">
                <TextBlock x:Name="LblOverall" Foreground="#888" FontSize="11"/>
                <TextBlock x:Name="OverallBytesText"
                           Foreground="#aaa" FontSize="11"
                           HorizontalAlignment="Right"/>
            </Grid>
            <ProgressBar x:Name="OverallProgress" Margin="0,0,0,4"/>

            <!-- Speed and ETA -->
            <Grid>
                <TextBlock x:Name="SpeedText"
                           Foreground="#888" FontSize="11"/>
                <TextBlock x:Name="EtaText"
                           Foreground="#888" FontSize="11"
                           HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>

        <!-- Action buttons -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="PauseButton"
                    Style="{StaticResource LauncherButton}"
                    Background="#3a3d44"
                    Margin="0,0,10,0"
                    Visibility="Collapsed"
                    Click="PauseButton_Click"/>
            <Button x:Name="CancelButton"
                    Style="{StaticResource LauncherButton}"
                    Background="#3a3d44"
                    Margin="0,0,10,0"
                    Visibility="Collapsed"
                    Click="CancelButton_Click"/>
            <Button x:Name="UpdateButton"
                    Style="{StaticResource LauncherButton}"
                    Background="#3a3d44"
                    Margin="0,0,10,0"
                    Click="UpdateButton_Click"/>
            <Button x:Name="PlayButton"
                    Style="{StaticResource LauncherButton}"
                    MinWidth="160"
                    Click="PlayButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
