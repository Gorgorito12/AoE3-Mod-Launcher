<Window x:Class="WarsOfLibertyLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:controls="clr-namespace:WarsOfLibertyLauncher.Controls"
        Title="AoE3 Mod Launcher"
        Height="700" Width="1100"
        MinHeight="620" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource BgBase}">

    <Window.Resources>
        <!-- Dark-themed tooltip: matches the rest of the launcher's UI
             instead of the default OS pale-yellow rectangle. Applied
             implicitly to every ToolTip in this Window and its descendants. -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#22252c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3a3d44"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4"
                                MaxWidth="380">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10"
                                                  ShadowDepth="2"
                                                  Color="Black"
                                                  Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar primary action — the big "JUGAR / INSTALAR" button. -->
        <Style x:Key="SidebarPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#c8102e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#e63950"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#3a3d44"/>
                                <Setter Property="Foreground" Value="#888"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar action buttons coded by operation. Background + border
             come from each button instance, so the same template handles
             every color variant: cyan for Update, purple for Verify, amber
             for Repair, soft-red for Uninstall, etc. -->
        <Style x:Key="SidebarColoredButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                                <Setter Property="Foreground" Value="#aaa"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar secondary actions — Actualizar, Configuración, Abrir
             carpeta, Verificar archivos. Stretched full width, left-aligned
             label so they line up like a settings list. -->
        <Style x:Key="SidebarSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2a2d34"/>
            <Setter Property="Foreground" Value="#ddd"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3a3d44"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#22252c"/>
                                <Setter Property="Foreground" Value="#666"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tabs across the top of the right-hand content panel. The active
             tab gets its underline + brighter foreground programmatically
             from RefreshTabs() in code-behind. -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Margin" Value="0,0,28,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LangToggle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#2a2d34"/>
            <Setter Property="Foreground" Value="#c8102e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="8"/>
        </Style>

        <!-- Thin dark scrollbar — replaces the Windows-default light gray
             one so it blends with the rest of the theme. Track is fully
             transparent; the thumb is a subtle pill that brightens on
             hover/drag. The up/down repeat buttons are templated to empty
             so the bar is a pure track + thumb (matches VS Code / Discord
             / Spotify). -->
        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="#3a3d44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Margin="1,0"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5a5d64"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Empty repeat-button template so the up/down arrows disappear
             from the scrollbar without breaking its hit-testing. -->
        <Style x:Key="ScrollBarHiddenButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarHiddenButton}"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarHiddenButton}"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Horizontal variant — same template but with a thin height. -->
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Default ScrollViewer padding: reserves a thin gutter on the
             right so when the scrollbar appears it doesn't push the
             content sideways. The scrollbar is 6 px wide and we reserve 8
             so it has 1 px of breathing room on each side. -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Padding" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Top-level tabs -->
            <RowDefinition Height="*"/>      <!-- Active-tab content -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             TOP-LEVEL TABS. SwitchTopTab() in code-behind toggles which
             of the views below is visible. The Play tab keeps the
             original 2-row layout (Mods bar + sidebar/right body) so the
             existing flow is unchanged when the user lands here.
             ============================================================ -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgBase}"
                Padding="20,0"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="TopTabPlay"
                        Style="{StaticResource TopTabButton}"
                        Click="TopTabPlay_Click"/>
                <Button x:Name="TopTabMods"
                        Style="{StaticResource TopTabButton}"
                        Click="TopTabMods_Click"/>
                <Button x:Name="TopTabMultiplayer"
                        Style="{StaticResource TopTabButton}"
                        Click="TopTabMultiplayer_Click"/>
                <Button x:Name="TopTabNews"
                        Style="{StaticResource TopTabButton}"
                        Click="TopTabNews_Click"/>
                <Button x:Name="TopTabSettings"
                        Style="{StaticResource TopTabButton}"
                        Click="TopTabSettings_Click"/>
            </StackPanel>
        </Border>

        <!-- ============================================================
             Content host: only one of the view Grids below is Visible
             at a time, driven by SwitchTopTab(). Play is the default.
             ============================================================ -->
        <Grid Grid.Row="1">

            <!-- Play view: existing 2-row layout (mods bar + body). -->
            <Grid x:Name="PlayView">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Mods bar -->
                    <RowDefinition Height="*"/>      <!-- 2-column body -->
                </Grid.RowDefinitions>

                <!-- ============================================================
                     MODS BAR. Horizontal cards for every mod profile, plus the
                     EN/ES language toggle on the right.
                     ============================================================ -->
                <Border Grid.Row="0"
                        Background="{DynamicResource BgPanel}"
                        Padding="20,12"
                        BorderBrush="{DynamicResource BorderSubtle}"
                        BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="ModsBarLabel"
                               Foreground="#666"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <StackPanel x:Name="ModCardsPanel"
                                Orientation="Horizontal"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- "Launcher Settings" entry point. Opens a modal
                         dialog with launcher-wide preferences (theme-style
                         scope: language, autostart, catalog source, etc.).
                         Distinct from the gear button in the sidebar,
                         which is per-mod (paths, user data, mod-level
                         maintenance). -->
                    <Button x:Name="LauncherSettingsButton"
                            Style="{StaticResource LangToggle}"
                            Click="LauncherSettingsButton_Click"
                            ToolTip="Launcher Settings"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="12" Height="12"
                                  Stretch="Uniform"
                                  Fill="#888"
                                  VerticalAlignment="Center"
                                  Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"/>
                            <TextBlock x:Name="LauncherSettingsButtonText"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="|" Foreground="#444"
                               VerticalAlignment="Center" Margin="2,0"/>
                    <Button x:Name="LangEnButton" Style="{StaticResource LangToggle}"
                            Content="EN" Click="LangEnButton_Click"/>
                    <TextBlock Text="|" Foreground="#444"
                               VerticalAlignment="Center" Margin="2,0"/>
                    <Button x:Name="LangEsButton" Style="{StaticResource LangToggle}"
                            Content="ES" Click="LangEsButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================================
             BODY: two-column layout. Left = active-mod info + actions;
             right = tabs (Noticias / Changelog / Ayuda) + content host.
             ============================================================ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ====================== LEFT SIDEBAR ====================== -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BgBase}"
                    BorderBrush="{DynamicResource BorderSubtle}"
                    BorderThickness="0,0,1,0">
                <Grid Margin="20,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Banner -->
                        <RowDefinition Height="Auto"/>  <!-- StatusCard -->
                        <RowDefinition Height="*"/>     <!-- Actions (fills rest) -->
                        <RowDefinition Height="Auto"/>  <!-- ProgressPanel -->
                    </Grid.RowDefinitions>

                    <!-- Mod banner. Title/subtitle overlay + background image
                         (or accent gradient when no image) — driven by
                         RefreshActiveModBanner() in code-behind. -->
                    <controls:HeroBanner Grid.Row="0"
                                         x:Name="ActiveModBanner"/>

                    <!-- StatusCard: state badge + installed/latest version
                         rows + a conditional "AoE3 not found" row. Driven
                         from code by RefreshStatusCard(). -->
                    <controls:StatusCard Grid.Row="1"
                                         x:Name="StatusCardControl"
                                         Margin="0,12,0,0"/>

                    <!-- ProgressPanel (Grid.Row="3") is declared further
                         down in the source for readability, but renders
                         at the bottom of the sidebar. Idle state: a
                         neutral "Listo para operaciones" line. Operation
                         state: full bars + speed/step + Pause/Cancel,
                         driven by StartProgressPanel and friends. -->


                    <!-- Actions. Primary button + secondaries + the gear
                         More menu (which carries the per-mod ContextMenu). -->
                    <controls:ActionPanel Grid.Row="2" x:Name="ActionPanelControl"/>


                    <!-- Bottom slot: a single panel always visible. Tone
                         (color + icon) and content (idle / progress bars /
                         final-state banner) are driven from code by
                         SetProgressTone() + the idle/state setters. -->
                    <controls:ProgressPanel Grid.Row="3"
                                            x:Name="ProgressPanelControl"
                                            Margin="0,12,0,0"/>
                </Grid>
            </Border>

            <!-- ====================== RIGHT CONTENT ====================== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <controls:MainTabs Grid.Row="0" x:Name="MainTabsControl"/>

                <!-- Hidden compat stub kept so existing references that
                     toggle ProgressOverlay still resolve to a real control. -->
                <Border Grid.Row="1"
                        x:Name="ProgressOverlay"
                        Visibility="Collapsed"/>
            </Grid>
        </Grid>
            </Grid>   <!-- /PlayView -->

            <!-- v0.9 mod browser: header + scrollable card grid populated
                 from ModRegistry.All (built-ins + community catalog). The
                 UserControl is decoupled from runtime services — MainWindow
                 calls Populate() whenever the underlying state changes. -->
            <controls:ModsBrowser x:Name="ModsBrowserView" Visibility="Collapsed"/>

            <!-- Multiplayer placeholder — lobby ships in v1.0. -->
            <Grid x:Name="MultiplayerView" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="600">
                    <TextBlock x:Name="MultiplayerTeaserText"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="16"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>

            <!-- Large News view: full-width news feed. RefreshNewsAsync
                 populates both this panel and the smaller Noticias feed
                 inside Play / MainTabs from the same cached data. -->
            <ScrollViewer x:Name="NewsLargeView"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <Grid Margin="40,32" HorizontalAlignment="Center">
                    <StackPanel MaxWidth="800">
                        <StackPanel x:Name="NewsLargeCardsPanel"/>
                        <TextBlock x:Name="NewsLargePlaceholderText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   Margin="0,40,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- Settings tab: opens the existing settings dialog. Embedding
                 the dialog content directly is a larger refactor; for now,
                 a teaser + button keeps the surface flow consistent without
                 duplicating the dialog's layout. -->
            <Grid x:Name="SettingsView" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="500">
                    <TextBlock x:Name="SettingsTeaserText"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="14"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"/>
                    <Button x:Name="OpenSettingsTabButton"
                            Style="{StaticResource SidebarPrimaryButton}"
                            HorizontalAlignment="Center"
                            MinWidth="200"
                            Click="OpenSettingsTabButton_Click"/>
                </StackPanel>
            </Grid>

        </Grid>   <!-- /Content host (root Grid.Row=1) -->

        <!-- Hidden compatibility shim. The old layout had an "AoE3PathRow" that
             code-behind sometimes referenced; the new design folds that info
             into the game footer, so this is just a placeholder so the existing
             references keep compiling. -->
        <StackPanel x:Name="AoE3PathRow" Visibility="Collapsed"/>
        <TextBlock x:Name="InstallPathText" Visibility="Collapsed"/>
        <TextBlock x:Name="LblModPath" Visibility="Collapsed"/>

        <!-- System-tray icon. Hidden by default; the code-behind shows it
             when the user has "Minimize to tray on close" enabled and they
             close the main window. Double-click the tray icon to restore;
             right-click to get a tiny context menu (Show / Exit). The
             icon resource is pack://-loaded so it survives single-file
             publish. -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        IconSource="pack://application:,,,/WoL.ico"
                        Visibility="Collapsed"
                        TrayMouseDoubleClick="TrayIcon_DoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="TrayMenuShow" Click="TrayMenuShow_Click"/>
                    <Separator/>
                    <MenuItem x:Name="TrayMenuExit" Click="TrayMenuExit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
