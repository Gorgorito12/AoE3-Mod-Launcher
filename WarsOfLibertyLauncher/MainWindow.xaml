                            </Grid>
                            <Button.ContextMenu>
                                <ContextMenu x:Name="MoreMenu"
                                             Background="#22252c"
                                             BorderBrush="#3a3d44"
                                             BorderThickness="1"
                                             Padding="6"
                                             MinWidth="280">
                                    <ContextMenu.Resources>
                                        <!-- ContextMenu: custom template that
                                             drops the default "gutter column"
                                             (the white-ish left strip the
                                             default WPF style reserves for
                                             checkmarks). The result is a
                                             clean rounded panel where item
                                             hover fills the whole row. -->
                                        <Style TargetType="ContextMenu">
                                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                                            <Setter Property="SnapsToDevicePixels" Value="True"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ContextMenu">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6"
                                                                Padding="{TemplateBinding Padding}"
                                                                SnapsToDevicePixels="True">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="16"
                                                                                  ShadowDepth="3"
                                                                                  Color="Black"
                                                                                  Opacity="0.55"/>
                                                            </Border.Effect>
                                                            <ItemsPresenter/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>

                                        <!-- Separator: thin dark gray line -->
                                        <Style TargetType="Separator">
                                            <Setter Property="Background" Value="#3a3d44"/>
                                            <Setter Property="Margin" Value="6,4"/>
                                            <Setter Property="Height" Value="1"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Separator">
                                                        <Border Background="{TemplateBinding Background}"
                                                                Height="{TemplateBinding Height}"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>

                                        <!-- MenuItem: dark theme with full template control over
                                             both leaf items and submenu headers, plus a styled
                                             popup for nested submenus. -->
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Padding" Value="8,7"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                                            <Setter Property="ToolTipService.InitialShowDelay" Value="500"/>
                                            <Setter Property="ToolTipService.ShowDuration" Value="10000"/>
                                            <Setter Property="ToolTipService.BetweenShowDelay" Value="100"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="MenuItem">
                                                        <Border x:Name="border"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="3"
                                                                Padding="{TemplateBinding Padding}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="24"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <ContentPresenter Grid.Column="0"
                                                                                  ContentSource="Icon"
                                                                                  VerticalAlignment="Center"
                                                                                  HorizontalAlignment="Center"/>
                                                                <ContentPresenter Grid.Column="1"
                                                                                  ContentSource="Header"
                                                                                  VerticalAlignment="Center"
                                                                                  Margin="6,0,12,0"
                                                                                  RecognizesAccessKey="True"/>
                                                                <Path x:Name="arrow"
                                                                      Grid.Column="2"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,4,0"
                                                                      Width="6" Height="10"
                                                                      Stretch="Uniform"
                                                                      Fill="#888"
                                                                      Data="M0,0 L6,5 L0,10 Z"
                                                                      Visibility="Collapsed"/>
                                                                <Popup x:Name="PART_Popup"
                                                                       IsOpen="{TemplateBinding IsSubmenuOpen}"
                                                                       Placement="Right"
                                                                       HorizontalOffset="-2"
                                                                       VerticalOffset="-4"
                                                                       AllowsTransparency="True"
                                                                       PopupAnimation="Fade"
                                                                       Focusable="False">
                                                                    <Border Background="#22252c"
                                                                            BorderBrush="#3a3d44"
                                                                            BorderThickness="1"
                                                                            CornerRadius="4"
                                                                            Padding="4"
                                                                            Margin="4">
                                                                        <Border.Effect>
                                                                            <DropShadowEffect BlurRadius="12"
                                                                                              ShadowDepth="2"
                                                                                              Color="Black"
                                                                                              Opacity="0.5"/>
                                                                        </Border.Effect>
                                                                        <StackPanel IsItemsHost="True"/>
                                                                    </Border>
                                                                </Popup>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="HasItems" Value="True">
                                                                <Setter TargetName="arrow" Property="Visibility" Value="Visible"/>
                                                            </Trigger>
                                                            <Trigger Property="IsHighlighted" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#3a3d44"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Foreground" Value="#666"/>
                                                                <Setter TargetName="arrow" Property="Fill" Value="#444"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>

                                        <!-- Section header — small-caps colored label
                                             with an icon on the left, marking groups
                                             of items. Each section sets its own
                                             Foreground inline so the header pops
                                             without competing with the items below.
                                             Not clickable. -->
                                        <Style x:Key="MenuSectionHeader" TargetType="MenuItem">
                                            <Setter Property="Foreground" Value="#f0f0f0"/>
                                            <Setter Property="Background" Value="Transparent"/>
