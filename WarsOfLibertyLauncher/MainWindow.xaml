<Window x:Class="WarsOfLibertyLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AoE3 Mod Launcher"
        Height="700" Width="1100"
        MinHeight="620" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#1a1d24">

    <Window.Resources>
        <!-- Dark-themed tooltip: matches the rest of the launcher's UI
             instead of the default OS pale-yellow rectangle. Applied
             implicitly to every ToolTip in this Window and its descendants. -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#22252c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3a3d44"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4"
                                MaxWidth="380">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10"
                                                  ShadowDepth="2"
                                                  Color="Black"
                                                  Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar primary action — the big "JUGAR / INSTALAR" button. -->
        <Style x:Key="SidebarPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#c8102e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#e63950"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#3a3d44"/>
                                <Setter Property="Foreground" Value="#888"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar action buttons coded by operation. Background + border
             come from each button instance, so the same template handles
             every color variant: cyan for Update, purple for Verify, amber
             for Repair, soft-red for Uninstall, etc. -->
        <Style x:Key="SidebarColoredButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                                <Setter Property="Foreground" Value="#aaa"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar secondary actions — Actualizar, Configuración, Abrir
             carpeta, Verificar archivos. Stretched full width, left-aligned
             label so they line up like a settings list. -->
        <Style x:Key="SidebarSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2a2d34"/>
            <Setter Property="Foreground" Value="#ddd"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3a3d44"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#22252c"/>
                                <Setter Property="Foreground" Value="#666"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tabs across the top of the right-hand content panel. The active
             tab gets its underline + brighter foreground programmatically
             from RefreshTabs() in code-behind. -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Margin" Value="0,0,28,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LangToggle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#2a2d34"/>
            <Setter Property="Foreground" Value="#c8102e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="8"/>
        </Style>

        <!-- Thin dark scrollbar — replaces the Windows-default light gray
             one so it blends with the rest of the theme. Track is fully
             transparent; the thumb is a subtle pill that brightens on
             hover/drag. The up/down repeat buttons are templated to empty
             so the bar is a pure track + thumb (matches VS Code / Discord
             / Spotify). -->
        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="#3a3d44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Margin="1,0"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5a5d64"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Empty repeat-button template so the up/down arrows disappear
             from the scrollbar without breaking its hit-testing. -->
        <Style x:Key="ScrollBarHiddenButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarHiddenButton}"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarHiddenButton}"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Horizontal variant — same template but with a thin height. -->
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Default ScrollViewer padding: reserves a thin gutter on the
             right so when the scrollbar appears it doesn't push the
             content sideways. The scrollbar is 6 px wide and we reserve 8
             so it has 1 px of breathing room on each side. -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Padding" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Top: Mods bar -->
            <RowDefinition Height="*"/>      <!-- Body: 2 columns -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             TOP: Mods bar. Horizontal cards for every mod profile, plus
             EN/ES language toggle on the right.
             ============================================================ -->
        <Border Grid.Row="0"
                Background="#22252c"
                Padding="20,12"
                BorderBrush="#3a3d44"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="ModsBarLabel"
                               Foreground="#666"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <StackPanel x:Name="ModCardsPanel"
                                Orientation="Horizontal"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="LangEnButton" Style="{StaticResource LangToggle}"
                            Content="EN" Click="LangEnButton_Click"/>
                    <TextBlock Text="|" Foreground="#444"
                               VerticalAlignment="Center" Margin="2,0"/>
                    <Button x:Name="LangEsButton" Style="{StaticResource LangToggle}"
                            Content="ES" Click="LangEsButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================================
             BODY: two-column layout. Left = active-mod info + actions;
             right = tabs (Noticias / Changelog / Ayuda) + content host.
             ============================================================ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ====================== LEFT SIDEBAR ====================== -->
            <Border Grid.Column="0"
                    Background="#1a1d24"
                    BorderBrush="#3a3d44"
                    BorderThickness="0,0,1,0">
                <Grid Margin="20,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Banner -->
                        <RowDefinition Height="Auto"/>  <!-- StatusCard -->
                        <RowDefinition Height="*"/>     <!-- Actions (fills rest) -->
                        <RowDefinition Height="Auto"/>  <!-- ProgressPanel -->
                    </Grid.RowDefinitions>

                    <!-- Mod banner. Background image + name overlaid bottom-left;
                         filled programmatically by RefreshActiveModBanner() so the
                         current mod's logo + accent show up here. -->
                    <Border Grid.Row="0"
                            x:Name="ModBannerHost"
                            Height="140"
                            CornerRadius="8"
                            BorderBrush="#3a3d44"
                            BorderThickness="1"
                            ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="1"
                                        Margin="14,0,14,12"
                                        VerticalAlignment="Bottom">
                                <TextBlock x:Name="TitleText"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock x:Name="SubtitleText"
                                           FontSize="11"
                                           Foreground="#ccc"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- StatusCard. Three-row card with the mod's high-level
                         info: state badge, installed version, latest version.
                         Plus a fourth conditional row + Browse AoE3 button
                         when the game's install can't be auto-detected.
                         Driven from code by RefreshStatusCard(). -->
                    <Border Grid.Row="1"
                            x:Name="StatusCard"
                            Background="#22252c"
                            BorderBrush="#3a3d44"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,12"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <!-- Estado row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0"
                                      x:Name="StatusRowIcon"
                                      Width="14" Height="14"
                                      Stretch="Uniform"
                                      Fill="#9bd99b"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      Data="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z"/>
                                <TextBlock Grid.Column="1"
                                           Text="Estado:"
                                           Foreground="#888"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           x:Name="StatusValueText"
                                           Text="—"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#9bd99b"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Versión actual row -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0"
                                      Width="14" Height="14"
                                      Stretch="Uniform"
                                      Fill="#888"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      Data="M21.41,11.58L12.41,2.58C12.05,2.22 11.55,2 11,2H4C2.89,2 2,2.89 2,4V11C2,11.55 2.22,12.05 2.59,12.41L11.58,21.41C11.95,21.78 12.45,22 13,22C13.55,22 14.05,21.78 14.41,21.41L21.41,14.41C21.78,14.05 22,13.55 22,13C22,12.45 21.77,11.94 21.41,11.58M5.5,7A1.5,1.5 0 0,1 4,5.5A1.5,1.5 0 0,1 5.5,4A1.5,1.5 0 0,1 7,5.5A1.5,1.5 0 0,1 5.5,7Z"/>
                                <TextBlock Grid.Column="1"
                                           x:Name="StatusInstalledLabel"
                                           Foreground="#888"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           x:Name="CurrentVersionText"
                                           Text="—"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Última versión row -->
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0"
                                      Width="14" Height="14"
                                      Stretch="Uniform"
                                      Fill="#888"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      Data="M19.35,10.04C18.67,6.59 15.64,4 12,4C9.11,4 6.6,5.64 5.35,8.04C2.34,8.36 0,10.91 0,14A6,6 0 0,0 6,20H19A5,5 0 0,0 24,15C24,12.36 21.95,10.22 19.35,10.04Z"/>
                                <TextBlock Grid.Column="1"
                                           x:Name="StatusLatestLabel"
                                           Foreground="#888"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           x:Name="LatestVersionText"
                                           Text="—"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- AoE3 missing row — collapsed by default; shown
                                 when GameLauncher.Find() can't resolve the
                                 game executable for the active profile. -->
                            <Grid x:Name="AoE3MissingRow"
                                  Visibility="Collapsed"
                                  Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0"
                                      Width="14" Height="14"
                                      Stretch="Uniform"
                                      Fill="#e63950"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      Data="M13,14H11V10H13M13,18H11V16H13M1,21H23L12,2L1,21Z"/>
                                <TextBlock Grid.Column="1"
                                           x:Name="AoE3MissingText"
                                           Foreground="#e63950"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                                <Button Grid.Column="2"
                                        x:Name="BrowseAoE3Button"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#5b9bd5"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Padding="6,2"
                                        Click="BrowseAoE3Button_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ProgressPanel (Grid.Row="3") is declared further
                         down in the source for readability, but renders
                         at the bottom of the sidebar. Idle state: a
                         neutral "Listo para operaciones" line. Operation
                         state: full bars + speed/step + Pause/Cancel,
                         driven by StartProgressPanel and friends. -->


                    <!-- Actions. Section label + primary button + secondaries.
                         Pause/Cancel are part of the same stack, hidden until
                         an operation is in flight. The whole stack lives
                         inside a ScrollViewer so adding more secondaries
                         later doesn't push the game footer off-screen. -->
                    <ScrollViewer Grid.Row="2"
                                  Margin="0,16,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock x:Name="ActionsLabel"
                                       Foreground="#666"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <!-- Primary action — Play / Install / Update / Stop
                                 depending on state. SetPrimaryAction() updates
                                 PlayButtonText.Text + the disc background +
                                 the dispatched click action. The play-triangle
                                 icon stays in place across all states. -->
                            <Button x:Name="PlayButton"
                                    Style="{StaticResource SidebarPrimaryButton}"
                                    Click="PlayButton_Click">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <Path Width="14" Height="14"
                                          Stretch="Uniform"
                                          Fill="White"
                                          VerticalAlignment="Center"
                                          Data="M8,5.14V19.14L19,12.14L8,5.14Z"/>
                                    <TextBlock x:Name="PlayButtonText"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Stop button kept for handler compatibility; the
                                 unified primary covers stop now. Permanently
                                 collapsed. -->
                            <Button x:Name="StopButton"
                                    Style="{StaticResource SidebarSecondaryButton}"
                                    Background="#5a1a1a"
                                    Foreground="#e63950"
                                    Visibility="Collapsed"
                                    Margin="0,6,0,0"
                                    Click="StopButton_Click"/>
                            <!-- PauseButton + CancelButton live inside the
                                 ProgressPanel below (ProgressRunningActions). -->

                            <!-- "Update" — only shown when the active mod is
                                 detected with a known version AND has pending
                                 patches. -->
                            <Button x:Name="UpdateButton"
                                    Style="{StaticResource SidebarColoredButton}"
                                    Background="#1a3a52"
                                    BorderBrush="#3a8cd9"
                                    HorizontalContentAlignment="Stretch"
                                    Visibility="Collapsed"
                                    Margin="0,6,0,0"
                                    Click="UpdateButton_Click">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <Path Width="14" Height="14"
                                          Stretch="Uniform"
                                          Fill="White"
                                          VerticalAlignment="Center"
                                          Data="M19.35,10.04C18.67,6.59 15.64,4 12,4C9.11,4 6.6,5.64 5.35,8.04C2.34,8.36 0,10.91 0,14A6,6 0 0,0 6,20H19A5,5 0 0,0 24,15C24,12.36 21.95,10.22 19.35,10.04M19,18H6A4,4 0 0,1 2,14A4,4 0 0,1 6,10H6.71C7.37,7.69 9.5,6 12,6C15,6 17.5,8.5 17.5,11.5V12H19A3,3 0 0,1 22,15A3,3 0 0,1 19,18M8,13H10.55V16H13.45V13H16L12,9L8,13Z"/>
                                    <TextBlock x:Name="UpdateButtonText"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        <Button x:Name="MoreButton"
                                Style="{StaticResource SidebarSecondaryButton}"
                                HorizontalContentAlignment="Stretch"
                                Margin="0,6,0,0"
                                Click="MoreButton_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0"
                                      Width="14" Height="14"
                                      Stretch="Uniform"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      VerticalAlignment="Center"
