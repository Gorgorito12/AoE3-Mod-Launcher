                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          VerticalAlignment="Center"
                                          Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"/>
                                    <TextBlock x:Name="OpenFolderButtonText"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Verify, Repair and Uninstall buttons that
                                 used to live here are now in the gear menu
                                 (Configuración) under "Mantenimiento" /
                                 "Peligro" sections — they're destructive or
                                 advanced actions, no need to clutter the
                                 sidebar with them. -->
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Bottom slot: a single panel always visible. Its tone
                         (color + icon) and content (idle status / progress
                         bars / final-state banner) are driven entirely from
                         code by SetProgressTone() + the idle/state setters
                         below. There's no separate "Game detected" footer —
                         the idle state of this same panel reflects the mod's
                         current status (Ready / Update available / Not
                         installed / AoE3 missing). -->
                    <Border Grid.Row="3"
                            x:Name="ProgressPanel"
                            Background="#22252c"
                            BorderBrush="#3a3d44"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,10"
                            Margin="0,12,0,0">
                        <StackPanel>
                                <!-- Header label -->
                                <TextBlock x:Name="ProgressPanelLabel"
                                           Foreground="#5b9bd5"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>

                                <!-- Title + subtitle with operation icon.
                                     Single-cell Grid (no column defs) used
                                     as an overlay: the dot floats Left and
                                     the title block (ProgressTitleStack)
                                     floats independently. In idle, code-
                                     behind sets ProgressTitleStack to
                                     HorizontalAlignment=Center for true
                                     panel-wide symmetry. In operations it
                                     switches to Left with a 20px margin so
                                     the title sits next to the dot like a
                                     standard side-by-side layout. -->
                                <Grid>
                                    <TextBlock x:Name="ProgressIcon"
                                               Text="↻"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#5b9bd5"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"/>
                                    <StackPanel x:Name="ProgressTitleStack"
                                                HorizontalAlignment="Center">
                                        <TextBlock x:Name="ProgressTitleText"
                                                   Foreground="White"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="ProgressSubtitleText"
                                                   Foreground="#aaa"
                                                   FontSize="10"
                                                   Margin="0,1,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Bars + footer wrapped in their own panel
                                     so they hide as a group during end states
                                     (the message banner takes their place). -->
                                <StackPanel x:Name="ProgressBarsGroup">
                                    <Grid Margin="0,8,0,2">
                                        <TextBlock x:Name="LblCurrentPatch"
                                                   Foreground="#888" FontSize="10"/>
                                        <TextBlock x:Name="PatchBytesText"
                                                   Foreground="#aaa" FontSize="10"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <ProgressBar x:Name="PatchProgress"
                                                 Height="6"
                                                 Foreground="#3a8cd9"/>
                                    <Grid Margin="0,6,0,2">
                                        <TextBlock x:Name="LblOverall"
                                                   Foreground="#888" FontSize="10"/>
                                        <TextBlock x:Name="OverallBytesText"
                                                   Foreground="#aaa" FontSize="10"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <ProgressBar x:Name="OverallProgress"
                                                 Height="6"
                                                 Foreground="#3a8cd9"/>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   x:Name="SpeedText"
                                                   Foreground="#888"
                                                   FontSize="10"/>
                                        <TextBlock Grid.Column="1"
                                                   x:Name="ProgressStepText"
                                                   Foreground="#888"
                                                   FontSize="10"/>
                                    </Grid>
                                </StackPanel>
                                <!-- Kept hidden so the existing OnProgress
                                     reporter can still write to it without
                                     blowing up. -->
                                <TextBlock x:Name="EtaText" Visibility="Collapsed"/>

                                <!-- Pause / Cancel — visible only while an
                                     operation is in flight (driven by
                                     ShowDownloadControls). Collapsed once
                                     the panel transitions to a final state
                                     (Completed / Error / Cancelled). -->
                                <StackPanel x:Name="ProgressRunningActions"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,8,0,0"
                                            Visibility="Collapsed">
                                    <Button x:Name="PauseButton"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#5b9bd5"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Cursor="Hand"
                                            Padding="6,2"
                                            Margin="0,0,8,0"
                                            Click="PauseButton_Click"/>
                                    <Button x:Name="CancelButton"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#c84a4a"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Cursor="Hand"
                                            Padding="6,2"
                                            Click="CancelButton_Click"/>
                                </StackPanel>

                                <!-- Final-state banner (Completed / Error /
                                     Cancelled). Visible only after the
                                     operation settles. -->
                                <Border x:Name="ProgressMessagePanel"
                                        Visibility="Collapsed"
                                        CornerRadius="3"
                                        Padding="8,6"
                                        Margin="0,8,0,0">
                                    <TextBlock x:Name="ProgressMessageText"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- Inline action row. Single end-state
                                     button: Retry (Error / Cancelled).
                                     Browse AoE3 lives in the StatusCard
                                     above, not here. -->
                                <StackPanel x:Name="ProgressActionsRow"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,8,0,0"
                                            Visibility="Collapsed">
                                    <Button x:Name="ProgressActionRetry"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#d4a04a"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Cursor="Hand"
                                            Padding="6,2"
                                            Visibility="Collapsed"
                                            Click="ProgressActionRetry_Click"/>
                                </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ====================== RIGHT CONTENT ====================== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>  <!-- Progress overlay -->
                </Grid.RowDefinitions>

                <!-- Tabs -->
                <Border Grid.Row="0"
                        Background="#1a1d24"
                        Padding="20,14,20,0"
                        BorderBrush="#3a3d44"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="TabNoticias"
                                Style="{StaticResource TabButton}"
                                Click="TabNoticias_Click"/>
                        <Button x:Name="TabChangelog"
                                Style="{StaticResource TabButton}"
                                Click="TabChangelog_Click"/>
                        <Button x:Name="TabAyuda"
                                Style="{StaticResource TabButton}"
                                Click="TabAyuda_Click"/>
                    </StackPanel>
                </Border>

                <!-- Content area. Three ScrollViewers stacked; the active tab
                     toggles which one is visible. -->
                <Grid Grid.Row="1" Background="#1a1d24">
                    <ScrollViewer x:Name="NoticiasContent"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="24,18">
                        <StackPanel>
                            <!-- Progress panel moved to the sidebar's bottom slot.
                                 See ProgressPanel further up in the left column.

                                 StatusText below stays as a hidden compat
                                 stub so the dozens of SetStatus(...) calls
                                 across code-behind keep compiling — they
                                 just write into an invisible control now. -->
                            <TextBlock x:Name="StatusText"
                                       Visibility="Collapsed"/>

                            <!-- News cards — populated programmatically when a
                                 future feed/profile metadata lands. Until then
                                 the placeholder fills the empty space. -->
                            <StackPanel x:Name="NewsCardsPanel"/>
                            <TextBlock x:Name="NewsPlaceholderText"
                                       Foreground="#666"
                                       FontStyle="Italic"
                                       HorizontalAlignment="Center"
                                       Margin="0,40,0,0"/>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="ChangelogContent"
                                  Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="24,18">
                        <TextBlock x:Name="ChangelogText"
                                   Foreground="#ccc"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>

                    <ScrollViewer x:Name="AyudaContent"
                                  Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="24,18">
                        <TextBlock x:Name="HelpText"
                                   Foreground="#ccc"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Grid>

                <!-- Footer area kept empty — the progress UI moved to the
                     top of the news content (ProgressPanel) so the user sees
                     it with the news/changelog/help context instead of as
                     a sticky footer. The grid row + this stub are kept so
                     existing references that toggle ProgressOverlay still
                     resolve to a real (but harmless) control. -->
                <Border Grid.Row="2"
                        x:Name="ProgressOverlay"
                        Visibility="Collapsed"/>
            </Grid>
        </Grid>

        <!-- Hidden compatibility shim. The old layout had an "AoE3PathRow" that
             code-behind sometimes referenced; the new design folds that info
             into the game footer, so this is just a placeholder so the existing
             references keep compiling. -->
        <StackPanel x:Name="AoE3PathRow" Visibility="Collapsed"/>
        <TextBlock x:Name="InstallPathText" Visibility="Collapsed"/>
        <TextBlock x:Name="LblModPath" Visibility="Collapsed"/>
    </Grid>
</Window>
