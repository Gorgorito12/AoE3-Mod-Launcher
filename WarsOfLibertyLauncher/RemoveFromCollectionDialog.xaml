<Window x:Class="WarsOfLibertyLauncher.RemoveFromCollectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WarsOfLibertyLauncher.Controls"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">
  <Grid>
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <controls:TitleBar x:Name="Chrome" Grid.Row="0"
                       ShowMinimize="False" ShowMaximize="False" ShowClose="True"/>
    <StackPanel Grid.Row="1" Margin="24,20">
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="&#x26A0;"
                       FontSize="{StaticResource FontSizeHeading}"
                       Foreground="{DynamicResource AccentBrush}"
                       VerticalAlignment="Top"
                       Margin="0,0,14,0"/>
            <StackPanel Grid.Column="1">
                <TextBlock x:Name="ModNameText"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="{StaticResource FontSizeBodyStrong}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="BodyText"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="{StaticResource FontSizeBody}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <!-- Only shown for an installed mod: the folder the files stay in, so
             "nothing is deleted" is verifiable instead of just asserted. -->
        <StackPanel x:Name="PathBlock" Visibility="Collapsed" Margin="0,0,0,16">
            <TextBlock x:Name="PathLabel"
                       Foreground="{DynamicResource TextSecondary}"
                       FontSize="{StaticResource FontSizeCaption}"
                       Margin="0,0,0,4"/>
            <Border Background="{DynamicResource BgPanelAlt}"
                    BorderBrush="{DynamicResource BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}"
                    Padding="12,8">
                <TextBlock x:Name="PathText"
                           FontFamily="Consolas"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource SecondaryFixed}"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <!-- Cancel is IsDefault on purpose: on a destructive confirm,
                 Enter must not carry out the action. -->
            <Button x:Name="CancelButton"
                    Click="CancelButton_Click"
                    IsDefault="True"
                    IsCancel="True"
                    Style="{StaticResource SidebarPrimaryButton}"
                    Background="#3a3d44"
                    Padding="18,6"
                    MinWidth="110"
                    Margin="0,0,10,0"/>
            <Button x:Name="ConfirmButton"
                    Click="ConfirmButton_Click"
                    Style="{StaticResource DangerButton}"
                    Padding="18,6"
                    MinWidth="140"/>
        </StackPanel>
    </StackPanel>
  </Grid>
</Window>
