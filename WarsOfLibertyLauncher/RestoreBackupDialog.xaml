<Window x:Class="WarsOfLibertyLauncher.RestoreBackupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restore user data backup"
        Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1d24"
        ShowInTaskbar="False">

    <StackPanel Margin="24">
        <!-- Header -->
        <TextBlock x:Name="HeaderText"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,4"/>
        <TextBlock x:Name="DescriptionText"
                   FontSize="12"
                   Foreground="#aaa"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <!-- Backup info panel (green — info, positive action) -->
        <Border Background="#1f3a1f"
                BorderBrush="#3a8c3a"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,10"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="BackupTitleText"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#9bd99b"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="BackupDetailsText"
                           FontSize="12"
                           Foreground="White"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Behavior explanation -->
        <TextBlock x:Name="ExplanationText"
                   FontSize="12"
                   Foreground="#ccc"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <!-- Older backups note (only visible if there are any) -->
        <TextBlock x:Name="OlderBackupsText"
                   FontSize="11"
                   Foreground="#888"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"
                   Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Style="{StaticResource DialogButton}"
                    MinWidth="100"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button x:Name="RestoreButton"
                    Style="{StaticResource SuccessButton}"
                    MinWidth="140"
                    IsDefault="True"
                    Click="RestoreButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
