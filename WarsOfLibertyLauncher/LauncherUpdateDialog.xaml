<Window x:Class="WarsOfLibertyLauncher.LauncherUpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WarsOfLibertyLauncher.Controls"
        Title="Launcher Update"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
            <Setter Property="Height" Value="10"/>
        </Style>
    </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <controls:TitleBar Grid.Row="0" x:Name="TitleBarControl"
                       ShowMinimize="False" ShowMaximize="False" ShowClose="True"/>
    <StackPanel Grid.Row="1" Margin="24">
        <TextBlock x:Name="HeaderText"
                   FontSize="{StaticResource FontSizeHeading}" FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,4"/>
        <TextBlock x:Name="VersionInfoText"
                   FontSize="{StaticResource FontSizeBody}"
                   Foreground="#aaa"
                   Margin="0,0,0,16"/>

        <!-- "What's new" — the release notes (release.body), shown only when the
             release has any. Scrolls so a long changelog doesn't blow up the
             dialog height (the Window is SizeToContent="Height"). -->
        <StackPanel x:Name="ReleaseNotesSection" Visibility="Collapsed" Margin="0,0,0,16">
            <TextBlock x:Name="ReleaseNotesHeader"
                       FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                       Foreground="#888"
                       Margin="0,0,0,4"/>
            <Border Background="{DynamicResource BgPanel}"
                    BorderBrush="#3A434F" BorderThickness="1"
                    CornerRadius="4" Padding="10">
                <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ReleaseNotesText"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="#ccc"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <Grid Margin="0,0,0,4">
            <TextBlock x:Name="ProgressLabelText"
                       FontSize="{StaticResource FontSizeCaption}" Foreground="#888"/>
            <TextBlock x:Name="ProgressPercentText"
                       FontSize="{StaticResource FontSizeCaption}" Foreground="#aaa"
                       HorizontalAlignment="Right"/>
        </Grid>
        <ProgressBar x:Name="DownloadProgress"
                     Minimum="0" Maximum="100" Value="0"
                     Margin="0,0,0,4"/>

        <Grid Margin="0,0,0,16">
            <TextBlock x:Name="SpeedText"
                       FontSize="{StaticResource FontSizeCaption}" Foreground="#888"/>
            <TextBlock x:Name="EtaText"
                       FontSize="{StaticResource FontSizeCaption}" Foreground="#888"
                       HorizontalAlignment="Right"/>
        </Grid>

        <TextBlock x:Name="StatusText"
                   FontSize="{StaticResource FontSizeBody}"
                   Foreground="#ccc"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Style="{StaticResource DialogButton}"
                    MinWidth="100"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button x:Name="ActionButton"
                    Style="{StaticResource PrimaryButton}"
                    MinWidth="160"
                    IsDefault="True"
                    Click="ActionButton_Click"/>
        </StackPanel>
    </StackPanel>
  </Grid>
</Window>
