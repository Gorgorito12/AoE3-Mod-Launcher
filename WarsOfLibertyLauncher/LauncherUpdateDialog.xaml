<Window x:Class="WarsOfLibertyLauncher.LauncherUpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Launcher Update"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1d24"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Background" Value="#3a3d44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4a4d54"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#2a2d34"/>
                                <Setter Property="Foreground" Value="#666"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#c8102e"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e63950"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#2a2d34"/>
            <Setter Property="Foreground" Value="#c8102e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="10"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">
        <TextBlock x:Name="HeaderText"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,4"/>
        <TextBlock x:Name="VersionInfoText"
                   FontSize="12"
                   Foreground="#aaa"
                   Margin="0,0,0,16"/>

        <Grid Margin="0,0,0,4">
            <TextBlock x:Name="ProgressLabelText"
                       FontSize="11" Foreground="#888"/>
            <TextBlock x:Name="ProgressPercentText"
                       FontSize="11" Foreground="#aaa"
                       HorizontalAlignment="Right"/>
        </Grid>
        <ProgressBar x:Name="DownloadProgress"
                     Minimum="0" Maximum="100" Value="0"
                     Margin="0,0,0,4"/>

        <Grid Margin="0,0,0,16">
            <TextBlock x:Name="SpeedText"
                       FontSize="11" Foreground="#888"/>
            <TextBlock x:Name="EtaText"
                       FontSize="11" Foreground="#888"
                       HorizontalAlignment="Right"/>
        </Grid>

        <TextBlock x:Name="StatusText"
                   FontSize="12"
                   Foreground="#ccc"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Style="{StaticResource DialogButton}"
                    MinWidth="100"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button x:Name="ActionButton"
                    Style="{StaticResource PrimaryButton}"
                    MinWidth="160"
                    IsDefault="True"
                    Click="ActionButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
