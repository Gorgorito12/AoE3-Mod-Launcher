<Window x:Class="WarsOfLibertyLauncher.LauncherUpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Launcher Update"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
            <Setter Property="Height" Value="10"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">
        <TextBlock x:Name="HeaderText"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,4"/>
        <TextBlock x:Name="VersionInfoText"
                   FontSize="12"
                   Foreground="#aaa"
                   Margin="0,0,0,16"/>

        <Grid Margin="0,0,0,4">
            <TextBlock x:Name="ProgressLabelText"
                       FontSize="11" Foreground="#888"/>
            <TextBlock x:Name="ProgressPercentText"
                       FontSize="11" Foreground="#aaa"
                       HorizontalAlignment="Right"/>
        </Grid>
        <ProgressBar x:Name="DownloadProgress"
                     Minimum="0" Maximum="100" Value="0"
                     Margin="0,0,0,4"/>

        <Grid Margin="0,0,0,16">
            <TextBlock x:Name="SpeedText"
                       FontSize="11" Foreground="#888"/>
            <TextBlock x:Name="EtaText"
                       FontSize="11" Foreground="#888"
                       HorizontalAlignment="Right"/>
        </Grid>

        <TextBlock x:Name="StatusText"
                   FontSize="12"
                   Foreground="#ccc"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Style="{StaticResource DialogButton}"
                    MinWidth="100"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button x:Name="ActionButton"
                    Style="{StaticResource PrimaryButton}"
                    MinWidth="160"
                    IsDefault="True"
                    Click="ActionButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
