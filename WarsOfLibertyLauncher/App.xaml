<Application x:Class="WarsOfLibertyLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Tokens.xaml FIRST: the geometry tokens (radii / spacing /
                     icon-disc / button-padding) must precede Buttons.xaml and
                     Inputs.xaml, because a `{StaticResource}` used INSIDE a
                     control template in those merged dictionaries can only
                     resolve resources in dictionaries merged BEFORE it — it
                     cannot see App.xaml's inline resources (added after the
                     merge block). Same reason Colors.xaml is merged early:
                     its brushes resolve inside those templates too. -->
                <ResourceDictionary Source="/Styles/Tokens.xaml"/>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/Buttons.xaml"/>
                <ResourceDictionary Source="/Styles/Chrome.xaml"/>
                <ResourceDictionary Source="/Styles/Inputs.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ============================================================
                 Typography. Stitch's design uses EB Garamond (display
                 serif) + Inter (humanist sans). We approximate with
                 Windows-built-in fonts that ship on every install since
                 Vista — no external assets, no .ttf to bundle. Both
                 chains end in generic family names so a stripped-down
                 Windows install still renders sanely.

                 To upgrade to the real fonts later: drop
                 EBGaramond-{Regular,SemiBold}.ttf + Inter-{Regular,
                 Medium,SemiBold}.ttf into Assets/Fonts/, mark them as
                 Resource in the .csproj, and prepend the pack URIs
                 here (e.g. "pack://application:,,,/Assets/Fonts/
                 #EB Garamond, Cambria, Georgia, serif").
                 ============================================================ -->

            <!-- Cinematic serif for headings, mod titles and the big PLAY
                 button. (The top nav tabs deliberately use BodyFont/sans —
                 a serif nav read "off"/heavy vs Steam's clean sans chrome.)
                 Cambria is Microsoft's
                 closest analogue to EB Garamond. Georgia as fallback
                 (also Windows-built-in). NO CSS generic family names
                 here — WPF FontFamily doesn't understand "serif" /
                 "sans-serif" and throws at construction, which silently
                 nukes the whole ResourceDictionary load. -->
            <FontFamily x:Key="DisplayFont">Cambria, Georgia</FontFamily>

            <!-- Body text — explicit Segoe UI (also the WPF default)
                 with Tahoma as a paranoid fallback. Single knob to
                 swap in real Inter later. -->
            <FontFamily x:Key="BodyFont">Segoe UI, Tahoma</FontFamily>

            <!-- ============================================================
                 Typography SCALE — semantic FontSize tokens.

                 WHY: the launcher had ~388 hardcoded FontSize literals
                 across 15 distinct values and zero shared sizing, so the
                 Workshop catalog text drifted to 10-11px — too small on
                 125/150% displays (the common laptop default). These
                 role-named doubles are the single knob for text size,
                 mirroring how DisplayFont/BodyFont centralize the family.
                 New UI binds to a token; it must not hardcode a FontSize
                 literal.

                 StaticResource (not Dynamic) on purpose: these are
                 app-lifetime constants — there is no runtime text-scale
                 feature, unlike the per-mod accent brushes that stay
                 DynamicResource. FontSize is a double DP, so a sys:Double
                 resource is the canonical WPF way to bind it.

                 These stay INLINE here (not in Tokens.xaml) because they're
                 only referenced from Setters + direct element attributes,
                 never from inside a merged-dictionary control template — so
                 the "template body can't see App-inline resources" trap that
                 forced the geometry tokens into Tokens.xaml doesn't apply.

                 Floor is 13, body 14 — calibrated against Steam's client
                 (its comfortable body ≈14px), so the launcher reads at the
                 same scale. The dashboard hero is intentionally NOT a
                 consumer — it scales as a unit via the shared UiScale
                 transform (see CLAUDE.md); don't route hero text through these.
                 ============================================================ -->
            <sys:Double x:Key="FontSizeCaption">13</sys:Double>
            <sys:Double x:Key="FontSizeBody">14</sys:Double>
            <sys:Double x:Key="FontSizeBodyStrong">15</sys:Double>
            <sys:Double x:Key="FontSizeSubtitle">16</sys:Double>
            <sys:Double x:Key="FontSizeTitle">18</sys:Double>
            <sys:Double x:Key="FontSizeHeading">24</sys:Double>
            <sys:Double x:Key="FontSizeDisplay">34</sys:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>
