<Window x:Class="WarsOfLibertyLauncher.PatchGeneratorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WarsOfLibertyLauncher.Controls"
        Title="Generate patch"
        Width="720" Height="680"
        MinHeight="560" MinWidth="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">

    <!--
        Modder-facing incremental delta-patch generator. Diffs two overlay .zips
        (the previous release's and the new one's) by SHA-256 and writes a small
        patch-<from>-to-<to>.zip + .json the modder uploads to their new GitHub
        release. Chrome + section styles mirror TranslationPackagerDialog. See
        Services/DeltaPatchService.GeneratePatchAsync and docs/MODDING.md.
    -->

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource DisplayFont}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeSubtitle}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#aab1bd"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <Style x:Key="SectionDivider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource BorderSubtle}"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Margin" Value="0,20,0,18"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <controls:TitleBar Grid.Row="0" x:Name="TitleBarControl"
                           ShowMinimize="False" ShowMaximize="True" ShowClose="True"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="28,22,28,22">
                <TextBlock x:Name="HeaderText"
                           FontSize="{StaticResource FontSizeHeading}" FontWeight="SemiBold"
                           Foreground="White" Margin="0,0,0,4"/>
                <TextBlock x:Name="DescriptionText"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="#aab1bd" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- SOURCE ZIPS -->
                <TextBlock x:Name="SectionSourcesHeader" Style="{StaticResource SectionHeader}"/>

                <TextBlock x:Name="LblOldZip" Style="{StaticResource FieldLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="OldZipBox" Grid.Column="0" IsReadOnly="True"/>
                    <Button x:Name="BrowseOldBtn" Grid.Column="2"
                            Style="{StaticResource PrimaryButton}" MinWidth="110"
                            Click="BrowseOldBtn_Click"/>
                </Grid>
                <TextBlock x:Name="HintOldZip" Style="{StaticResource FieldHint}"/>

                <TextBlock x:Name="LblNewZip" Style="{StaticResource FieldLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NewZipBox" Grid.Column="0" IsReadOnly="True"/>
                    <Button x:Name="BrowseNewBtn" Grid.Column="2"
                            Style="{StaticResource PrimaryButton}" MinWidth="110"
                            Click="BrowseNewBtn_Click"/>
                </Grid>
                <TextBlock x:Name="HintNewZip" Style="{StaticResource FieldHint}"/>

                <Border Style="{StaticResource SectionDivider}"/>

                <!-- VERSIONS -->
                <TextBlock x:Name="SectionVersionsHeader" Style="{StaticResource SectionHeader}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="LblFromTag" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox x:Name="FromTagBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="LblToTag" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox x:Name="ToTagBox"/>
                    </StackPanel>
                </Grid>
                <TextBlock x:Name="HintVersions" Style="{StaticResource FieldHint}"/>

                <Border Style="{StaticResource SectionDivider}"/>

                <!-- OUTPUT -->
                <TextBlock x:Name="SectionOutputHeader" Style="{StaticResource SectionHeader}"/>
                <TextBlock x:Name="LblOutput" Style="{StaticResource FieldLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="OutputBox" Grid.Column="0" IsReadOnly="True"/>
                    <Button x:Name="BrowseOutBtn" Grid.Column="2"
                            Style="{StaticResource PrimaryButton}" MinWidth="110"
                            Click="BrowseOutBtn_Click"/>
                </Grid>

                <!-- Result / reminder -->
                <Border x:Name="ResultPanel" Visibility="Collapsed"
                        Background="#1E2A22" BorderBrush="{DynamicResource StatusInstalledFg}"
                        BorderThickness="1" CornerRadius="{StaticResource RadiusMd}"
                        Padding="14,12" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock x:Name="ResultText"
                                   Foreground="{DynamicResource StatusInstalledFg}"
                                   FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <TextBlock x:Name="ReminderText"
                                   Foreground="#cfe8d6" TextWrapping="Wrap" Margin="0,8,0,0"
                                   FontSize="{StaticResource FontSizeCaption}"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="ErrorText" Visibility="Collapsed"
                           Foreground="{DynamicResource MpStatusOffline}"
                           TextWrapping="Wrap" Margin="0,16,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Sticky footer -->
        <Border Grid.Row="2" Background="{DynamicResource BgSidebar}"
                BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0"
                Padding="28,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CloseBtn" Style="{StaticResource DialogButton}" MinWidth="120"
                        Click="CloseBtn_Click"/>
                <Button x:Name="GenerateBtn" Style="{StaticResource PrimaryButton}" MinWidth="160"
                        Margin="12,0,0,0" Click="GenerateBtn_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
