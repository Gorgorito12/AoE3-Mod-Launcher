<Window x:Class="WarsOfLibertyLauncher.TranslationPackagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Empaquetar traducción"
        Width="720" Height="720"
        MinHeight="600" MinWidth="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">

    <!--
        Translator-facing packaging dialog.

        Surfaces a "Mod a traducir" picker at the top so the same dialog
        works for every installed mod (was hard-coded to the launcher's
        active mod before — see CLAUDE.md gotcha "Empaquetar mi traducción
        lives in Settings → Traducciones"). Switching the picker swaps the
        underlying TranslationService instance and re-derives the
        compatibility version + originals snapshot for the picked mod.

        Chrome matches LauncherSettingsDialog / ModPropertiesDialog:
        WindowStyle=None + custom title bar + edge-drag resize. Sticky
        footer keeps Cancel/Generate visible while the scrollable body
        holds the multi-section form.
    -->

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Section header above each group of fields. Uppercase + accent
             colour so it reads as a header without taking too much vertical
             space. Same recipe as ModPropertiesDialog section heads. -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource DisplayFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Label above each form field. Subtle grey, small. -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#aab1bd"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>

        <!-- Inline hint under each field. Italicised + dimmer than the
             label so the form reads as label / control / explanation. -->
        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- Hairline between sections — same recipe as the other dialogs. -->
        <Style x:Key="SectionDivider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource BorderSubtle}"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Margin" Value="0,20,0,18"/>
        </Style>

        <!-- Title-bar close ✕. Same recipe as LauncherSettingsDialog. -->
        <Style x:Key="DialogCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Secondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerAlert}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header chrome -->
            <RowDefinition Height="*"/>      <!-- Scrollable body -->
            <RowDefinition Height="Auto"/>   <!-- Sticky footer -->
        </Grid.RowDefinitions>

        <!-- =========================================================
             HEADER — custom dark title bar with ✕ close button.
             ========================================================= -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgSidebar}"
                BorderBrush="{DynamicResource BorderSecondary}"
                BorderThickness="0,0,0,1"
                Padding="22,10,8,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="TitleText"
                           FontFamily="{DynamicResource DisplayFont}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"/>
                <Button x:Name="CloseHeaderBtn"
                        Grid.Column="1"
                        Style="{StaticResource DialogCloseButton}"
                        Content="&#xE8BB;"
                        VerticalAlignment="Center"
                        Click="CancelButton_Click"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>
        </Border>

        <!-- =========================================================
             BODY — multi-section form (Mod / Identity / Source / Compat /
             Output) above the fold; success preview below the fold
             (swapped in place via Visibility once Generate succeeds).
             ========================================================= -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28,22,28,22">

                <!-- ============= FORM PANEL ============= -->
                <StackPanel x:Name="FormPanel">

                    <!-- Intro: who this is for + what it produces. -->
                    <TextBlock x:Name="HeaderText"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="DescriptionText"
                               FontSize="12"
                               Foreground="#aab1bd"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"/>

                    <!-- ===================================================
                         MOD TARGET — which mod is this translation for?
                         The combo drives every downstream default: originals
                         folder (auto-filled from <install>\translations\
                         _originals if a snapshot exists), compatibility
                         version pre-fill, output filename prefix.
                         =================================================== -->
                    <TextBlock x:Name="SectionModHeader" Style="{StaticResource SectionHeader}"/>
                    <TextBlock x:Name="LblMod" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="ModCombo"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="ModCombo_SelectionChanged"/>
                    <TextBlock x:Name="HintMod" Style="{StaticResource FieldHint}"/>

                    <Border Style="{StaticResource SectionDivider}"/>

                    <!-- ===================================================
                         PACK IDENTITY — language id, display name, author,
                         pack version. Two columns on wide windows.
                         =================================================== -->
                    <TextBlock x:Name="SectionIdentityHeader" Style="{StaticResource SectionHeader}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Id (column 0) -->
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="LblId" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBox x:Name="IdBox" Text="es"/>
                            <TextBlock x:Name="HintId" Style="{StaticResource FieldHint}"/>
                        </StackPanel>

                        <!-- Name (column 2) -->
                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="LblName" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBox x:Name="NameBox" Text="Español"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Author (column 0) -->
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="LblAuthor" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBox x:Name="AuthorBox"/>
                        </StackPanel>

                        <!-- Version (column 2) -->
                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="LblVersion" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBox x:Name="VersionBox" Text="1.0"/>
                            <TextBlock x:Name="HintVersion" Style="{StaticResource FieldHint}"/>
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource SectionDivider}"/>

                    <!-- ===================================================
                         SOURCE FILES — translated folder + (optional)
                         originals snapshot. Both browse via OpenFolderDialog.
                         =================================================== -->
                    <TextBlock x:Name="SectionSourceHeader" Style="{StaticResource SectionHeader}"/>

                    <TextBlock x:Name="LblFolder" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FolderBox" Grid.Column="0"/>
                        <Button x:Name="BrowseFolderButton"
                                Grid.Column="1"
                                Style="{StaticResource DialogButton}"
                                Margin="8,0,0,0"
                                Click="BrowseFolderButton_Click"/>
                    </Grid>
                    <TextBlock x:Name="HintFolder" Style="{StaticResource FieldHint}"/>

                    <TextBlock x:Name="LblOriginals" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OriginalsBox" Grid.Column="0"/>
                        <Button x:Name="BrowseOriginalsButton"
                                Grid.Column="1"
                                Style="{StaticResource DialogButton}"
                                Margin="8,0,0,0"
                                Click="BrowseOriginalsButton_Click"/>
                    </Grid>
                    <TextBlock x:Name="HintOriginals" Style="{StaticResource FieldHint}"/>

                    <Border Style="{StaticResource SectionDivider}"/>

                    <!-- ===================================================
                         COMPATIBILITY — which mod versions this pack
                         supports. Pre-checks the current installed version
                         of the picked mod; extra versions go in the
                         comma-separated box.
                         =================================================== -->
                    <TextBlock x:Name="SectionCompatHeader" Style="{StaticResource SectionHeader}"/>
                    <TextBlock x:Name="LblCompat" Style="{StaticResource FieldLabel}"/>
                    <CheckBox x:Name="CompatCurrentCheck"
                              Foreground="#ddd"
                              FontSize="12"
                              IsChecked="True"
                              Margin="0,4,0,0"/>
                    <TextBlock x:Name="HintCompatExtra" Style="{StaticResource FieldHint}" Margin="0,10,0,4"/>
                    <TextBox x:Name="CompatExtraBox"/>

                    <Border Style="{StaticResource SectionDivider}"/>

                    <!-- ===================================================
                         OUTPUT — destination .zip path. Filename prefix
                         tracks the picked mod's id (wol-es.zip, imp-es.zip)
                         so multi-mod translators don't clobber each other's
                         output on the desktop.
                         =================================================== -->
                    <TextBlock x:Name="SectionOutputHeader" Style="{StaticResource SectionHeader}"/>
                    <TextBlock x:Name="LblOutput" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OutputBox" Grid.Column="0"/>
                        <Button x:Name="BrowseOutputButton"
                                Grid.Column="1"
                                Style="{StaticResource DialogButton}"
                                Margin="8,0,0,0"
                                Click="BrowseOutputButton_Click"/>
                    </Grid>

                    <!-- Status / error band, only visible after a failed
                         submit attempt. -->
                    <TextBlock x:Name="StatusText"
                               FontSize="12"
                               Foreground="{DynamicResource ErrorBrush}"
                               TextWrapping="Wrap"
                               Margin="0,14,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- ============= RESULT PANEL ============= -->
                <StackPanel x:Name="ResultPanel" Visibility="Collapsed">
                    <!-- Big check + heading -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="✓"
                                   FontSize="28"
                                   Foreground="#9bd99b"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="ResultHeaderText"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock x:Name="ResultPathText"
                                       FontSize="12"
                                       Foreground="#aab1bd"
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- "How players will see it" preview, mirrors
                         BuildLanguageMenuItem in MainWindow. -->
                    <TextBlock x:Name="LblPreview"
                               Style="{StaticResource FieldLabel}"
                               Margin="0,16,0,4"/>
                    <Border Background="{DynamicResource BgPanel}"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12,10">
                        <TextBlock x:Name="PreviewText"
                                   FontSize="13"
                                   Foreground="White"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <!-- Next-steps card for the translator. -->
                    <Border Background="#1f2a3a"
                            BorderBrush="#3a5c8c"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12,8"
                            Margin="0,14,0,8">
                        <TextBlock x:Name="ResultInstructionsText"
                                   FontSize="11"
                                   Foreground="#9bb8d9"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- =========================================================
             FOOTER — sticky action bar, swaps Cancel/Generate (form)
             for Open folder / Done (result) via Visibility.
             ========================================================= -->
        <Border Grid.Row="2"
                Background="{DynamicResource BgPanel}"
                Padding="24,14"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,1,0,0">
            <Grid>
                <!-- Form footer -->
                <StackPanel x:Name="FormFooter"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Style="{StaticResource DialogButton}"
                            MinWidth="100"
                            Margin="0,0,8,0"
                            Click="CancelButton_Click"/>
                    <Button x:Name="GenerateButton"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="180"
                            Click="GenerateButton_Click"/>
                </StackPanel>
                <!-- Result footer -->
                <StackPanel x:Name="ResultFooter"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Visibility="Collapsed">
                    <Button x:Name="OpenFolderButton"
                            Style="{StaticResource DialogButton}"
                            MinWidth="140"
                            Margin="0,0,8,0"
                            Click="OpenFolderButton_Click"/>
                    <Button x:Name="DoneButton"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="100"
                            Click="DoneButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
