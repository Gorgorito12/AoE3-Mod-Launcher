<Window x:Class="WarsOfLibertyLauncher.TranslationPackagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Empaquetar traducción"
        Width="640" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1d24"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Background" Value="#3a3d44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4a4d54"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#2a2d34"/>
                                <Setter Property="Foreground" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#c8102e"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e63950"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
        </Style>

        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2a2d34"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3a3d44"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============= FORM PANEL ============= -->
        <StackPanel x:Name="FormPanel" Grid.Row="0">
            <TextBlock x:Name="HeaderText"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="White"
                       Margin="0,0,0,4"/>
            <TextBlock x:Name="DescriptionText"
                       FontSize="12"
                       Foreground="#aaa"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <!-- ID -->
            <TextBlock x:Name="LblId" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="IdBox" Style="{StaticResource FieldBox}" Text="es"/>
            <TextBlock x:Name="HintId" Style="{StaticResource FieldHint}"/>

            <!-- Name -->
            <TextBlock x:Name="LblName" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="NameBox" Style="{StaticResource FieldBox}" Text="Español"/>

            <!-- Author -->
            <TextBlock x:Name="LblAuthor" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="AuthorBox" Style="{StaticResource FieldBox}"/>

            <!-- Version -->
            <TextBlock x:Name="LblVersion" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="VersionBox" Style="{StaticResource FieldBox}" Text="1.0"/>
            <TextBlock x:Name="HintVersion" Style="{StaticResource FieldHint}"/>

            <!-- Translated folder -->
            <TextBlock x:Name="LblFolder" Style="{StaticResource FieldLabel}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FolderBox"
                         Grid.Column="0"
                         Style="{StaticResource FieldBox}"/>
                <Button x:Name="BrowseFolderButton"
                        Grid.Column="1"
                        Style="{StaticResource DialogButton}"
                        Margin="8,0,0,0"
                        Click="BrowseFolderButton_Click"/>
            </Grid>
            <TextBlock x:Name="HintFolder" Style="{StaticResource FieldHint}"/>

            <!-- Originals folder -->
            <TextBlock x:Name="LblOriginals" Style="{StaticResource FieldLabel}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="OriginalsBox"
                         Grid.Column="0"
                         Style="{StaticResource FieldBox}"/>
                <Button x:Name="BrowseOriginalsButton"
                        Grid.Column="1"
                        Style="{StaticResource DialogButton}"
                        Margin="8,0,0,0"
                        Click="BrowseOriginalsButton_Click"/>
            </Grid>
            <TextBlock x:Name="HintOriginals" Style="{StaticResource FieldHint}"/>

            <!-- Compatibility -->
            <TextBlock x:Name="LblCompat" Style="{StaticResource FieldLabel}"/>
            <CheckBox x:Name="CompatCurrentCheck"
                      Foreground="#ddd"
                      FontSize="12"
                      IsChecked="True"
                      Margin="0,4,0,0"/>
            <TextBlock x:Name="HintCompatExtra" Style="{StaticResource FieldHint}"/>
            <TextBox x:Name="CompatExtraBox" Style="{StaticResource FieldBox}" Margin="0,4,0,0"/>

            <!-- Output -->
            <TextBlock x:Name="LblOutput" Style="{StaticResource FieldLabel}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="OutputBox"
                         Grid.Column="0"
                         Style="{StaticResource FieldBox}"/>
                <Button x:Name="BrowseOutputButton"
                        Grid.Column="1"
                        Style="{StaticResource DialogButton}"
                        Margin="8,0,0,0"
                        Click="BrowseOutputButton_Click"/>
            </Grid>

            <!-- Status / error -->
            <TextBlock x:Name="StatusText"
                       FontSize="12"
                       Foreground="#e63950"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"
                       Visibility="Collapsed"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="CancelButton"
                        Style="{StaticResource DialogButton}"
                        MinWidth="100"
                        Margin="0,0,8,0"
                        Click="CancelButton_Click"/>
                <Button x:Name="GenerateButton"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="160"
                        Click="GenerateButton_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- ============= RESULT PANEL ============= -->
        <StackPanel x:Name="ResultPanel" Grid.Row="0" Visibility="Collapsed">
            <!-- Big check + heading -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="✓"
                           FontSize="28"
                           Foreground="#9bd99b"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="ResultHeaderText"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock x:Name="ResultPathText"
                               FontSize="12"
                               Foreground="#aaa"
                               TextWrapping="Wrap"
                               FontFamily="Consolas"/>
                </StackPanel>
            </StackPanel>

            <!-- Menu preview — what the entry will look like to players -->
            <TextBlock x:Name="LblPreview"
                       Style="{StaticResource FieldLabel}"
                       Margin="0,12,0,4"/>
            <Border Background="#22252c"
                    BorderBrush="#3a3d44"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12,10">
                <TextBlock x:Name="PreviewText"
                           FontSize="13"
                           Foreground="White"
                           FontWeight="SemiBold"/>
            </Border>

            <!-- Instructions for the maintainer -->
            <Border Background="#1f2a3a"
                    BorderBrush="#3a5c8c"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12,8"
                    Margin="0,12,0,8">
                <TextBlock x:Name="ResultInstructionsText"
                           FontSize="11"
                           Foreground="#9bb8d9"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- JSON snippet -->
            <TextBlock x:Name="LblJsonSnippet"
                       Style="{StaticResource FieldLabel}"
                       Margin="0,8,0,4"/>
            <Border Background="#0f1218"
                    BorderBrush="#3a3d44"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBox x:Name="JsonSnippetBox"
                         Background="Transparent"
                         Foreground="#d4d4d4"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="11"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         MaxHeight="220"
                         Padding="10"/>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="OpenFolderButton"
                        Style="{StaticResource DialogButton}"
                        MinWidth="120"
                        Margin="0,0,8,0"
                        Click="OpenFolderButton_Click"/>
                <Button x:Name="CopyJsonButton"
                        Style="{StaticResource DialogButton}"
                        MinWidth="140"
                        Margin="0,0,8,0"
                        Click="CopyJsonButton_Click"/>
                <Button x:Name="DoneButton"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="100"
                        Click="DoneButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
