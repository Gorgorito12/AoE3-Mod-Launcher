<Window x:Class="WarsOfLibertyLauncher.CreateLobbyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WarsOfLibertyLauncher"
        xmlns:controls="clr-namespace:WarsOfLibertyLauncher.Controls"
        Title="Create a room"
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">
    <Window.Resources>
        <!-- Resolves a ModProfile (the mod ComboBoxItem's Tag) to its icon
             brush for the dropdown items. -->
        <local:ModProfileIconBrushConverter x:Key="ModProfileIconConv"/>

        <!-- Dark form controls shared by every field in this dialog.
             Keeping them local (instead of pushing into Styles/Inputs)
             so the create-room dialog can carry its own subtle
             personality (slightly chunkier paddings, blue focus ring)
             without affecting the rest of the launcher. -->
        <Style x:Key="MpFormTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource MpSurfaceAlt}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MpDivider}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="11,8"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource MpBlue}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MpFormPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource MpSurfaceAlt}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MpDivider}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="11,8"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource MpBlue}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#777"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource MpSurface}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dropdown that doesn't look like the default Windows
             combobox (which is the brief's specific complaint). We
             keep it stylistically aligned with the textboxes — same
             height, same border, blue focus ring. The popup is
             dark too. -->
        <Style x:Key="MpFormCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource MpSurfaceAlt}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MpDivider}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="11,7"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"/>
                            <ToggleButton x:Name="ToggleButton"
                                          Grid.Column="2"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderBrush="Transparent">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Path x:Name="Caret"
                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                  Fill="{DynamicResource TextSecondary}"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,14,0"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border Background="{DynamicResource MpSurfaceAlt}"
                                        BorderBrush="{DynamicResource MpDivider}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="240">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource MpBlue}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#777"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource MpSurface}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="12,7"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource MpBlueSubtle}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource MpBlue}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ModCombo dropdown items: mod ICON disc + name. Applied LOCALLY on
             the ModCombo element (ItemContainerStyle="{StaticResource ModComboItem}"),
             which overrides the plain-text item style MpFormCombo sets — so the
             shared combo (MaxPlayersCombo) keeps its number-only items. The
             item Content stays the mod NAME string, so the combo's selection
             box shows just the name (the disc beside the combo paints the
             selected icon); the dropdown icon is bound from the item's Tag
             (the ModProfile) via ModProfileIconConv. -->
        <Style x:Key="ModComboItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="20" Height="20"
                                        CornerRadius="10"
                                        Margin="0,0,9,0"
                                        VerticalAlignment="Center"
                                        Background="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource ModProfileIconConv}}"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource MpBlueSubtle}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource MpBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Custom CheckBox: square + a blue tint on check. -->
        <Style x:Key="MpCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="checkBorder"
                                    Width="16" Height="16"
                                    Background="{DynamicResource MpSurfaceAlt}"
                                    BorderBrush="{DynamicResource MpDivider}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    VerticalAlignment="Center">
                                <Path x:Name="checkMark"
                                      Data="M 2 7 L 6 11 L 14 3"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkBorder" Property="Background" Value="{DynamicResource MpBlue}"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource MpBlue}"/>
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource MpBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer chrome: opaque window surface. The 44 px global TitleBar +
         WindowChrome drag + rounded corners are applied centrally in
         App.OnAnyWindowLoaded; here we keep a thin 1 px frame. -->
    <Border Background="{DynamicResource BgBase}"
            BorderBrush="{DynamicResource MpDivider}"
            BorderThickness="1"
            CornerRadius="0">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>     <!-- Title bar -->
                <RowDefinition Height="Auto"/>     <!-- Body -->
                <RowDefinition Height="Auto"/>     <!-- Advanced details -->
                <RowDefinition Height="Auto"/>     <!-- Buttons -->
            </Grid.RowDefinitions>

            <controls:TitleBar Grid.Row="0"
                               x:Name="TitleBarControl"
                               ShowMinimize="False"
                               ShowMaximize="False"
                               ShowClose="True"/>

            <!-- Body. -->
            <StackPanel Grid.Row="1" Margin="22,0,22,4">
                <!-- Mod (display-only card; the picker drops out of
                     the form when only one mod is installed, but we
                     keep ModCombo present + invisible so the
                     existing code-behind selection logic still
                     runs and computes the fingerprint). -->
                <TextBlock x:Name="ModLabel" Style="{StaticResource LabelText}"/>
                <Border Background="{DynamicResource MpSurfaceAlt}"
                        BorderBrush="{DynamicResource MpDivider}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,8"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                x:Name="ModIconHost"
                                Width="24" Height="24"
                                Background="{DynamicResource MpBlueSubtle}"
                                CornerRadius="12"
                                Margin="0,0,10,0">
                            <TextBlock x:Name="ModIconEmoji"
                                       Text="🎮"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ComboBox Grid.Column="1"
                                  x:Name="ModCombo"
                                  Style="{StaticResource MpFormCombo}"
                                  ItemContainerStyle="{StaticResource ModComboItem}"
                                  Height="26"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  Padding="0,4"
                                  SelectionChanged="ModCombo_SelectionChanged"/>
                    </Grid>
                </Border>

                <!-- Room title with live char counter. -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               x:Name="TitleLabel"
                               Style="{StaticResource LabelText}"/>
                    <TextBlock Grid.Column="1"
                               x:Name="TitleCounter"
                               Style="{StaticResource LabelText}"
                               Foreground="{DynamicResource TextSecondary}"
                               Text="0 / 64"/>
                </Grid>
                <TextBox x:Name="RoomTitleBox"
                         Style="{StaticResource MpFormTextBox}"
                         MaxLength="64"
                         TextChanged="RoomTitleBox_TextChanged"
                         Margin="0,0,0,14"/>

                <!-- Max players + Private room + Password row.
                     We replace the old "MaxPlayers + Password"
                     side-by-side layout with a 3-column grid so the
                     private toggle has space without re-flowing
                     on small windows. -->
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="MaxPlayersLabel" Style="{StaticResource LabelText}"/>
                        <ComboBox x:Name="MaxPlayersCombo"
                                  Style="{StaticResource MpFormCombo}">
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="4"/>
                            <ComboBoxItem Content="5"/>
                            <ComboBoxItem Content="6"/>
                            <ComboBoxItem Content="7"/>
                            <ComboBoxItem Content="8" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <CheckBox x:Name="PrivateRoomCheck"
                                  Style="{StaticResource MpCheckBox}"
                                  Content="Private room (optional)"
                                  Margin="0,0,0,8"
                                  Checked="PrivateRoomCheck_Changed"
                                  Unchecked="PrivateRoomCheck_Changed"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource MpFormPasswordBox}"
                                     MaxLength="50"
                                     IsEnabled="False"/>
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="ErrorText"
                           Foreground="{DynamicResource MpStatusOffline}"
                           FontSize="{StaticResource FontSizeCaption}"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Advanced details: the fingerprint demoted from
                 first-class field to a collapsible block. Toggling
                 the chevron expands the value (still selectable so
                 power users can copy it). -->
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource MpDivider}"
                    BorderThickness="0,1,0,0"
                    Margin="22,16,22,0"
                    Padding="0,12,0,4">
                <StackPanel>
                    <Button x:Name="AdvancedToggle"
                            Click="AdvancedToggle_Click"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            HorizontalContentAlignment="Left"
                            Cursor="Hand"
                            Padding="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="AdvancedCaret"
                                       Text="▸"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="Advanced details"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="HashLabel"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="HashText"
                               Foreground="{DynamicResource TextSecondary}"
                               FontFamily="Consolas, Courier New, monospace"
                               FontSize="{StaticResource FontSizeCaption}"
                               TextTrimming="CharacterEllipsis"
                               Margin="14,6,0,4"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- Action row. -->
            <Border Grid.Row="3"
                    BorderBrush="{DynamicResource MpDivider}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14"
                    Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Click="CancelButton_Click"
                            Style="{StaticResource MpSecondaryButton}"
                            Padding="22,10"
                            MinWidth="110"
                            Margin="0,0,8,0"/>
                    <Button x:Name="CreateButton"
                            Click="CreateButton_Click"
                            Style="{StaticResource MpPrimaryButton}"
                            Padding="24,10"
                            MinWidth="140"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
