                          VerticalAlignment="Center"
                          Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"/>
                    <TextBlock Grid.Column="1"
                               x:Name="MoreButtonText"
                               x:FieldModifier="public"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                    <Path Grid.Column="2"
                          Width="6" Height="10"
                          Stretch="Uniform"
                          Fill="#888"
                          VerticalAlignment="Center"
                          Data="M0,0 L6,5 L0,10 Z"/>
                </Grid>
                <Button.ContextMenu>
                    <ContextMenu x:Name="MoreMenu"
                                 Background="{DynamicResource BgPanel}"
                                 BorderBrush="{DynamicResource MenuBorder}"
                                 BorderThickness="2"
                                 Padding="6"
                                 MinWidth="280">
                        <ContextMenu.Resources>
                            <!-- ContextMenu: custom template that drops the
                                 default "gutter column" (the white-ish left
                                 strip the default WPF style reserves for
                                 checkmarks). The result is a clean rounded
                                 panel where item hover fills the whole row. -->
                            <Style TargetType="ContextMenu">
                                <Setter Property="OverridesDefaultStyle" Value="True"/>
                                <Setter Property="SnapsToDevicePixels" Value="True"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ContextMenu">
                                            <!-- Outer near-black rim (1px) painted via
                                                 the Background + Padding of an outer Border
                                                 so the inner panel sits inset by 1px. Inner
                                                 panel keeps the existing MenuBorder bright
                                                 line (2px) for visibility against the dark
                                                 menu interior. Together this is the
                                                 two-tone "punched out" boundary documented
                                                 by MenuBorder/MenuBorderOuter in Colors.xaml. -->
                                            <Border Background="{DynamicResource MenuBorderOuter}"
                                                    CornerRadius="{StaticResource RadiusPopupOuter}"
                                                    Padding="1"
                                                    SnapsToDevicePixels="True">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="16"
                                                                      ShadowDepth="3"
                                                                      Color="Black"
                                                                      Opacity="0.55"/>
                                                </Border.Effect>
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="{StaticResource RadiusPopupInner}"
                                                        Padding="{TemplateBinding Padding}"
                                                        SnapsToDevicePixels="True">
                                                    <ItemsPresenter/>
                                                </Border>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <Style TargetType="Separator">
                                <Setter Property="Background" Value="#3a3d44"/>
                                <Setter Property="Margin" Value="6,4"/>
                                <Setter Property="Height" Value="1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Separator">
                                            <Border Background="{TemplateBinding Background}"
                                                    Height="{TemplateBinding Height}"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <Style TargetType="MenuItem">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="8,7"/>
                                <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="OverridesDefaultStyle" Value="True"/>
                                <Setter Property="ToolTipService.InitialShowDelay" Value="500"/>
                                <Setter Property="ToolTipService.ShowDuration" Value="10000"/>
                                <Setter Property="ToolTipService.BetweenShowDelay" Value="100"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="MenuItem">
                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="{StaticResource RadiusSm}"
                                                    Padding="{TemplateBinding Padding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="24"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ContentPresenter Grid.Column="0"
                                                                      ContentSource="Icon"
                                                                      VerticalAlignment="Center"
                                                                      HorizontalAlignment="Center"/>
                                                    <ContentPresenter Grid.Column="1"
                                                                      ContentSource="Header"
                                                                      VerticalAlignment="Center"
                                                                      Margin="6,0,12,0"
                                                                      RecognizesAccessKey="True"/>
                                                    <Path x:Name="arrow"
                                                          Grid.Column="2"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,4,0"
                                                          Width="6" Height="10"
                                                          Stretch="Uniform"
                                                          Fill="#888"
                                                          Data="M0,0 L6,5 L0,10 Z"
                                                          Visibility="Collapsed"/>
                                                    <Popup x:Name="PART_Popup"
                                                           IsOpen="{TemplateBinding IsSubmenuOpen}"
                                                           Placement="Right"
                                                           HorizontalOffset="-2"
                                                           VerticalOffset="-4"
                                                           AllowsTransparency="True"
                                                           PopupAnimation="Fade"
                                                           Focusable="False">
                                                        <!-- Submenu uses the same two-tone
                                                             "punched-out" rim as the parent
                                                             ContextMenu — 1px near-black
                                                             outer band + 2px bright inner
                                                             border — so cascaded submenus
                                                             share the same crisp boundary. -->
                                                        <Border Background="{DynamicResource MenuBorderOuter}"
                                                                CornerRadius="{StaticResource RadiusPopupSubmenuOuter}"
                                                                Padding="1"
                                                                Margin="4">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="12"
                                                                                  ShadowDepth="2"
                                                                                  Color="Black"
                                                                                  Opacity="0.5"/>
                                                            </Border.Effect>
                                                            <Border Background="{DynamicResource BgPanel}"
                                                                    BorderBrush="{DynamicResource MenuBorder}"
                                                                    BorderThickness="2"
                                                                    CornerRadius="{StaticResource RadiusPopupSubmenuInner}"
                                                                    Padding="4">
                                                                <StackPanel IsItemsHost="True"/>
                                                            </Border>
                                                        </Border>
                                                    </Popup>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="HasItems" Value="True">
                                                    <Setter TargetName="arrow" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                                <Trigger Property="IsHighlighted" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#3a3d44"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Foreground" Value="#666"/>
                                                    <Setter TargetName="arrow" Property="Fill" Value="#444"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <Style x:Key="MenuSectionHeader" TargetType="MenuItem">
                                <Setter Property="Foreground" Value="#f0f0f0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="8,8,8,4"/>
                                <Setter Property="FontSize" Value="{StaticResource FontSizeSubtitle}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="OverridesDefaultStyle" Value="True"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="MenuItem">
                                            <Border Background="Transparent"
                                                    Padding="{TemplateBinding Padding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="24"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ContentPresenter Grid.Column="0"
                                                                      ContentSource="Icon"
                                                                      VerticalAlignment="Center"
                                                                      HorizontalAlignment="Center"/>
                                                    <ContentPresenter Grid.Column="1"
                                                                      ContentSource="Header"
                                                                      VerticalAlignment="Center"
                                                                      Margin="6,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
