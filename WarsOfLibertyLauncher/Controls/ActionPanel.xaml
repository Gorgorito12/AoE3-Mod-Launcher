<UserControl x:Class="WarsOfLibertyLauncher.Controls.ActionPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Margin="0,16,0,0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <TextBlock x:Name="ActionsLabel"
                       x:FieldModifier="public"
                       Foreground="#666"
                       FontSize="{StaticResource FontSizeCaption}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>

            <!-- Primary action — Play / Install / Update / Stop depending
                 on state. SetPrimaryAction() updates PlayButtonText.Text +
                 the disc background + the dispatched click action. -->
            <Button x:Name="PlayButton"
                    x:FieldModifier="public"
                    Style="{StaticResource SidebarPrimaryButton}">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Path Width="14" Height="14"
                          Stretch="Uniform"
                          Fill="White"
                          VerticalAlignment="Center"
                          Data="M8,5.14V19.14L19,12.14L8,5.14Z"/>
                    <TextBlock x:Name="PlayButtonText"
                               x:FieldModifier="public"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Stop button kept for handler compatibility; the unified
                 primary covers stop now. Permanently collapsed. -->
            <Button x:Name="StopButton"
                    x:FieldModifier="public"
                    Style="{StaticResource SidebarSecondaryButton}"
                    Background="{DynamicResource StatusErrorBg}"
                    Foreground="{DynamicResource ErrorBrush}"
                    Visibility="Collapsed"
                    Margin="0,6,0,0"/>

            <!-- "Update" — only shown when the active mod is detected with
                 a known version AND has pending patches. -->
            <Button x:Name="UpdateButton"
                    x:FieldModifier="public"
                    Style="{StaticResource SidebarColoredButton}"
                    Background="#1a3a52"
                    BorderBrush="#3a8cd9"
                    HorizontalContentAlignment="Stretch"
                    Visibility="Collapsed"
                    Margin="0,6,0,0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Path Width="14" Height="14"
                          Stretch="Uniform"
                          Fill="White"
                          VerticalAlignment="Center"
                          Data="M19.35,10.04C18.67,6.59 15.64,4 12,4C9.11,4 6.6,5.64 5.35,8.04C2.34,8.36 0,10.91 0,14A6,6 0 0,0 6,20H19A5,5 0 0,0 24,15C24,12.36 21.95,10.22 19.35,10.04M19,18H6A4,4 0 0,1 2,14A4,4 0 0,1 6,10H6.71C7.37,7.69 9.5,6 12,6C15,6 17.5,8.5 17.5,11.5V12H19A3,3 0 0,1 22,15A3,3 0 0,1 19,18M8,13H10.55V16H13.45V13H16L12,9L8,13Z"/>
                    <TextBlock x:Name="UpdateButtonText"
                               x:FieldModifier="public"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="MoreButton"
