<UserControl x:Class="WarsOfLibertyLauncher.Controls.MultiplayerTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Subtab buttons (Rooms / Friends / Profile / History).
             TERTIARY BLUE recipe â€” dim gray when inactive, soft sky
             (FgHoverBlue) on hover, white + bold + blue underline
             when active (active state still set programmatically by
             UpdateSubtabHighlights via BorderBrush/Foreground).

             ControlTemplate is REQUIRED â€” without it WPF falls back
             to the Aero default which paints a sky-blue gradient
             on hover (the "muy blancos" bug). TemplateBinding the
             BorderBrush + BorderThickness so the code-behind active-
             state setters still work without re-templating. -->
        <Style x:Key="SubTab" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="2,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,24,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- No background fill, just lift the
                                     text to soft sky. The blue identity
                                     stays in the underline (active) +
                                     hover text, never in a tile. -->
                                <Setter Property="Foreground" Value="{DynamicResource FgHoverBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Right-aligned status pill (Connected / Reconnecting /
             Offline) shown in the top-right of the header. Pure
             cosmetic â€” UpdateConnectionStatus() fills the labels
             and the dot brush. -->
        <Style x:Key="HeaderStatChip" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="18,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgBase}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>     <!-- Header (subtabs + status bar) -->
            <RowDefinition Height="*"/>        <!-- Active view -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             Header: subtabs on the left, connection-status pill on
             the right. The status pill replaces the older "chat-line"
             approach where disconnect/reconnect events were dumped
             into the room chat â€” those now live here, where the user
             expects to look for them.
             ============================================================ -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,8,24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="SubtabRooms" Click="SubtabRooms_Click" Style="{StaticResource SubTab}"/>
                    <Button x:Name="SubtabFriends" Click="SubtabFriends_Click" Style="{StaticResource SubTab}"/>
                    <Button x:Name="SubtabProfile" Click="SubtabProfile_Click" Style="{StaticResource SubTab}"/>
                    <Button x:Name="SubtabHistory" Click="SubtabHistory_Click" Style="{StaticResource SubTab}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Connection status: a coloured dot + label
                         ("Connected", "Reconnectingâ€¦", "Offline").
                         Updated by UpdateConnectionStatus() from
                         the session / WS state â€” no more disconnect
                         messages leaking into the chat log. -->
                    <StackPanel Style="{StaticResource HeaderStatChip}">
                        <Ellipse x:Name="ConnDot"
                                 Width="8" Height="8"
                                 Fill="{DynamicResource MpStatusOnline}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>
                        <TextBlock x:Name="ConnStatusText"
                                   Text="Connected"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Live quota: "X players online Â· Y active
                         rooms". Pulled from /quota every ~30s by
                         RefreshQuotaAsync. -->
                    <StackPanel Style="{StaticResource HeaderStatChip}">
                        <TextBlock x:Name="QuotaText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- NAT badge â€” kept as-is, drives the colour
                         tint from NatTypeDetector probe. Pushed
                         right so the user sees it but it doesn't
                         dominate. -->
                    <Border x:Name="NatBadgeBorder"
                            Background="{DynamicResource MpSurfaceAlt}"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8,2"
                            Margin="14,0,0,0"
                            Cursor="Help">
                        <TextBlock x:Name="NatBadgeText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================================
             ROOMS view: sign-in gate / room list / current-room panel.
             Only one of the three groups is visible at a time, driven
             from code-behind by RefreshFromSession().
             ============================================================ -->
        <Grid Grid.Row="1" x:Name="RoomsView">

            <!-- Signed-out gate. -->
            <StackPanel x:Name="SignInPanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="480">
                <TextBlock x:Name="SignInTitleText"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="18"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="SignInBodyText"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,12,0,18"/>
                <Button x:Name="SignInButton"
                        Click="SignInButton_Click"
                        Style="{StaticResource MpPrimaryButton}"
                        HorizontalAlignment="Center"
                        Padding="20,10"
                        MinWidth="220"/>
                <TextBlock x:Name="SignInErrorText"
                           Foreground="{DynamicResource MpStatusOffline}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,12,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Browser (signed in, no current lobby). Top toolbar:
                 user chip on the left, Refresh + Create room on the
                 right. Below: table header row, then either the
                 list of rooms or the empty-state illustration. -->
            <Grid x:Name="BrowserPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Radmin banner -->
                    <RowDefinition Height="Auto"/>   <!-- toolbar -->
                    <RowDefinition Height="*"/>      <!-- rooms (left) + global chat (right) -->
                </Grid.RowDefinitions>

                <!-- Radmin VPN banner. Three live states driven by
                     RadminVpnService.GetStatus():
                       * NotInstalled  â†’ red warning + "Install" button
                       * NotConnected  â†’ blue info + "Open Radmin" button
                       * Connected     â†’ green check + network-name copier
                                         + numbered "how to join" instructions
                     Layout: a 3-row Grid. Row 0 is always-on (icon, title
                     line, primary button). Rows 1 & 2 are the network-name
                     panel and the numbered steps, both shown only in the
                     Connected state so they don't waste vertical space when
                     the user can't act on them yet. Colours come from
                     code-behind. Polls every 3 s while mounted. -->
                <Border Grid.Row="0"
                        x:Name="RadminBanner"
                        x:FieldModifier="private"
                        Background="#1f2c3d"
                        BorderBrush="#3a5a8c"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="24,12,24,0"
                        Padding="14,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>    <!-- title + primary button -->
                            <RowDefinition Height="Auto"/>    <!-- network-name copier -->
                            <RowDefinition Height="Auto"/>    <!-- numbered instructions -->
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status icon. Glyph + colour are set by
                             RefreshRadminBanner() in code-behind. -->
                        <Border Grid.Row="0" Grid.Column="0"
                                x:Name="RadminStatusIcon"
                                Width="24" Height="24"
                                CornerRadius="12"
                                Background="#3a5a8c"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                            <TextBlock x:Name="RadminStatusGlyph"
                                       Text="i"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Title + body -->
                        <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="RadminBannerTitle"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="RadminBannerBody"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Primary actions: [Show steps] opens the
                             guided assistant overlay; [Install /
                             Open Radmin] is the legacy one-click
                             quick action. Stacked horizontally so a
                             power user can hit "Open Radmin" without
                             going through the tutorial. -->
                        <StackPanel Grid.Row="0" Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0">
                            <Button x:Name="RadminShowStepsButton"
                                    Click="RadminShowStepsButton_Click"
                                    Style="{StaticResource MpSecondaryButton}"
                                    Padding="12,6"
                                    Margin="0,0,6,0"
                                    FontSize="11"/>
                            <Button x:Name="RadminPrimaryButton"
                                    Click="RadminPrimaryButton_Click"
                                    Style="{StaticResource MpSecondaryButton}"
                                    Padding="12,6"
                                    FontSize="11"/>
                        </StackPanel>

                        <!-- Network-name copier. A read-only TextBox so
                             the name can be selected and inspected
                             visually, paired with a "Copy" button that
                             pushes it to the clipboard without needing
                             to open Radmin first. Only shown in the
                             Connected state. -->
                        <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                x:Name="RadminNetworkNamePanel"
                                Background="#15282a"
                                BorderBrush="#3a8c5a"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,10,0,0"
                                Padding="8,6"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         x:Name="RadminNetworkNameBox"
                                         Text="Age of Empires III: The Asian Dynasties"
                                         IsReadOnly="True"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontFamily="Consolas, Courier New, monospace"
                                         FontSize="11"
                                         Foreground="{DynamicResource TextPrimary}"
                                         VerticalAlignment="Center"
                                         VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1"
                                        x:Name="RadminCopyNameButton"
                                        Click="RadminCopyNameButton_Click"
                                        Style="{StaticResource MpSecondaryButton}"
                                        Padding="10,4"
                                        Margin="8,0,0,0"
                                        FontSize="11"
                                        MinWidth="100"/>
                            </Grid>
                        </Border>

                        <!-- Numbered step-by-step instructions. Static
                             text set by RefreshRadminBanner() so it
                             follows the language switch. Only shown in
                             the Connected state. -->
                        <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                   x:Name="RadminInstructionsText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- Toolbar -->
                <Grid Grid.Row="1" Margin="24,18,24,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- User chip: avatar circle + login + sign out. -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="34" Height="34"
                                CornerRadius="17"
                                Background="{DynamicResource MpSurfaceAlt}"
                                BorderBrush="{DynamicResource BorderSubtle}"
                                BorderThickness="1"
                                Margin="0,0,10,0">
                            <Grid>
                                <Ellipse x:Name="UserAvatarEllipse">
                                    <Ellipse.Fill>
                                        <ImageBrush x:Name="UserAvatarBrush"
                                                    Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock x:Name="UserAvatarInitial"
                                           Text=""
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="SignedInAsText"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="|"
                                   Foreground="{DynamicResource BorderSubtle}"
                                   FontSize="13"
                                   Margin="8,0"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="SignOutLink"
                                Click="SignOutLink_Click"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="#7fb0ff"
                                FontSize="12"
                                Cursor="Hand"
                                Padding="0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            x:Name="RefreshButton"
                            Click="RefreshButton_Click"
                            Style="{StaticResource MpSecondaryButton}"
                            Padding="16,8"
                            MinWidth="110"
                            Margin="0,0,10,0"/>

                    <Button Grid.Column="2"
                            x:Name="CreateRoomButton"
                            Click="CreateRoomButton_Click"
                            Style="{StaticResource MpPrimaryButton}"
                            Padding="18,8"
                            MinWidth="150"/>
                </Grid>

                <!-- Row 2: two-column content — active rooms (left) +
                     persistent global chat (right). The rooms table and
                     the chat panel each live in their own card. -->
                <Grid Grid.Row="2" Margin="24,2,24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>     <!-- gutter -->
                        <ColumnDefinition Width="380"/>    <!-- global chat -->
                    </Grid.ColumnDefinitions>

                    <!-- ===================== LEFT: active rooms ===================== -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource MpSurface}"
                            BorderBrush="{DynamicResource MpDivider}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- section title -->
                                <RowDefinition Height="Auto"/>   <!-- table header -->
                                <RowDefinition Height="*"/>      <!-- rows / empty / error -->
                            </Grid.RowDefinitions>

                            <!-- Section title: people glyph + "Salas activas" -->
                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        Margin="20,16,20,12">
                                <TextBlock Text="👥"
                                           FontSize="15"
                                           VerticalAlignment="Center"
                                           Margin="0,0,9,0"/>
                                <TextBlock x:Name="RoomsSectionTitle"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Table header row. Column widths defined here so
                                 code-behind can mirror them when it builds each
                                 data row (BuildRoomRow). -->
                            <Border Grid.Row="1"
                        Background="{DynamicResource MpSurface}"
                        BorderBrush="{DynamicResource MpDivider}"
                        BorderThickness="0,1,0,1"
                        Padding="24,8,24,8">
                    <Grid x:Name="RoomsHeaderGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition Width="2.4*" MinWidth="160"/>
                            <ColumnDefinition Width="1.6*" MinWidth="110"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1"
                                   x:Name="ColHeaderRoom"
                                   Foreground="{DynamicResource MpTableHeader}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   x:Name="ColHeaderHost"
                                   Foreground="{DynamicResource MpTableHeader}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3"
                                   x:Name="ColHeaderPlayers"
                                   Foreground="{DynamicResource MpTableHeader}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4"
                                   x:Name="ColHeaderPing"
                                   Foreground="{DynamicResource MpTableHeader}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="5"
                                   x:Name="ColHeaderStatus"
                                   Foreground="{DynamicResource MpTableHeader}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="6"
                                   x:Name="ColHeaderAction"
                                   Foreground="{DynamicResource MpTableHeader}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Rows OR empty-state. ScrollViewer keeps it
                     scannable when many rooms exist; the inner
                     RoomsListPanel is the same x:Name the old
                     code-behind already populates, just with the
                     row builder updated to a Grid layout. -->
                <Grid Grid.Row="2">
                    <ScrollViewer x:Name="RoomsListScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="RoomsListPanel" Margin="0,0,0,12"/>
                    </ScrollViewer>

                    <!-- Empty-state card. Visibility is toggled by
                         RefreshLobbiesAsync() â€” hidden by default,
                         shown when /lobbies returns zero. Visible
                         over the scroll so it sits centered. -->
                    <Border x:Name="RoomsEmptyState"
                            Background="Transparent"
                            BorderBrush="{DynamicResource MpDivider}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Margin="40,30,40,30"
                            Padding="40,40"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <!-- Simple SVG-style illustration: a
                                 pair of crossed flags + a drum.
                                 Pure Path geometry so no asset
                                 file is needed and it tints with
                                 the foreground colour. -->
                            <Viewbox Width="96" Height="96" Margin="0,0,0,18">
                                <Canvas Width="64" Height="64">
                                    <!-- Left flag staff + flag -->
                                    <Path Stroke="{DynamicResource TextSecondary}"
                                          StrokeThickness="1.5"
                                          Fill="{DynamicResource MpSurfaceAlt}"
                                          Data="M 20 4 L 20 50"/>
                                    <Path Stroke="{DynamicResource TextSecondary}"
                                          StrokeThickness="1.2"
                                          Fill="{DynamicResource MpSurfaceAlt}"
                                          Data="M 20 6 L 32 10 L 20 16 Z"/>
                                    <!-- Right flag -->
                                    <Path Stroke="{DynamicResource TextSecondary}"
                                          StrokeThickness="1.5"
                                          Fill="{DynamicResource MpSurfaceAlt}"
                                          Data="M 44 4 L 44 50"/>
                                    <Path Stroke="{DynamicResource TextSecondary}"
                                          StrokeThickness="1.2"
                                          Fill="{DynamicResource MpSurfaceAlt}"
                                          Data="M 44 6 L 56 10 L 44 16 Z"/>
                                    <!-- Drum body -->
                                    <Ellipse Stroke="{DynamicResource TextSecondary}"
                                             StrokeThickness="1.6"
                                             Fill="{DynamicResource MpSurfaceAlt}"
                                             Canvas.Left="18" Canvas.Top="36"
                                             Width="28" Height="22"/>
                                    <Ellipse Stroke="{DynamicResource TextSecondary}"
                                             StrokeThickness="1.4"
                                             Fill="{DynamicResource MpSurface}"
                                             Canvas.Left="18" Canvas.Top="32"
                                             Width="28" Height="8"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="EmptyTitleText"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="EmptyBodyText"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       Margin="0,6,0,18"
                                       HorizontalAlignment="Center"/>
                            <Button x:Name="EmptyCreateButton"
                                    Click="CreateRoomButton_Click"
                                    Style="{StaticResource MpOutlineBlueButton}"
                                    MinWidth="170"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Errors box (network/API). Shown when
                         RefreshLobbiesAsync throws â€” populated by
                         setting RoomsErrorText.Text + visibility. -->
                    <Border x:Name="RoomsErrorBox"
                            VerticalAlignment="Top"
                            Margin="24,12,24,0"
                            Padding="14,10"
                            Background="{DynamicResource StatusErrorBg}"
                            BorderBrush="{DynamicResource MpStatusOffline}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Visibility="Collapsed">
                        <TextBlock x:Name="RoomsErrorText"
                                   Foreground="{DynamicResource MpStatusOffline}"
                                   FontSize="11"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>
                        </Grid>
                    </Border>
                    <!-- /LEFT card -->

                    <!-- ===================== RIGHT: global chat ===================== -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource MpSurface}"
                            BorderBrush="{DynamicResource MpDivider}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- title -->
                                <RowDefinition Height="Auto"/>   <!-- channel + presence -->
                                <RowDefinition Height="*"/>      <!-- messages -->
                                <RowDefinition Height="Auto"/>   <!-- input -->
                            </Grid.RowDefinitions>

                            <!-- Title: chat glyph + "Chat global" -->
                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        Margin="18,16,18,0">
                                <TextBlock Text="💬"
                                           FontSize="15"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBlock x:Name="GlobalChatHeaderText"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Channel label (left) + presence count (right) -->
                            <Grid Grid.Row="1" Margin="18,10,18,12">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{DynamicResource MpStatusOnline}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,7,0"/>
                                    <TextBlock x:Name="GlobalChatChannelText"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="GlobalChatPresenceText"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="12"/>
                            </Grid>

                            <!-- Messages list + empty/placeholder hint -->
                            <Grid Grid.Row="2">
                                <ScrollViewer x:Name="GlobalChatScroll"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="12,0,12,0">
                                    <StackPanel x:Name="GlobalChatPanel"/>
                                </ScrollViewer>
                                <TextBlock x:Name="GlobalChatEmptyHint"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="12"
                                           FontStyle="Italic"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Margin="24"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Grid>

                            <!-- Composer: text box + Send -->
                            <Border Grid.Row="3"
                                    BorderBrush="{DynamicResource MpDivider}"
                                    BorderThickness="0,1,0,0"
                                    Padding="12,10">
                                <StackPanel>
                                    <!-- Throttle / slow-mode hint: shown when the
                                         server drops a message, cleared on next keystroke. -->
                                    <TextBlock x:Name="GlobalChatNotice"
                                               Foreground="{DynamicResource MpStatusReconnect}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="2,0,2,6"
                                               Visibility="Collapsed"/>
                                    <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Margin="0,0,8,0">
                                        <TextBox x:Name="GlobalChatInput"
                                                 MaxLength="500"
                                                 VerticalContentAlignment="Center"
                                                 TextChanged="GlobalChatInput_TextChanged"
                                                 KeyDown="GlobalChatInput_KeyDown"/>
                                        <TextBlock x:Name="GlobalChatPlaceholder"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="12"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False"/>
                                    </Grid>
                                    <Button x:Name="GlobalChatSendButton"
                                            Grid.Column="1"
                                            Click="GlobalChatSendButton_Click"
                                            Style="{StaticResource MpPrimaryButton}"
                                            Padding="16,8"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                    <!-- /RIGHT global chat -->
                </Grid>
            </Grid>


            <!-- The lobby UI that used to live here as a non-modal
                 floating popup (Canvas + RoomPopupCard Border + 600 lines
                 of content) has moved to LobbyWindow.xaml. It is now a
                 real top-level Window opened from MultiplayerTab.xaml.cs
                 via OpenLobbyWindow() — see the comment block above that
                 method. The browser stays here, fully visible while the
                 lobby is open since the Window does not overlay it. -->
        </Grid>                 <!-- x:Name="RoomsView" -->

        <!-- Profile / History / Friends subviews. -->
        <Grid Grid.Row="1" x:Name="ProfileView" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="32,24" MaxWidth="640" HorizontalAlignment="Left">
                    <TextBlock x:Name="ProfileNameText"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="18"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="ProfileLoginText"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"
                               Margin="0,2,0,16"/>
                    <TextBlock x:Name="ProfileEloText"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="14"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="ProfileGamesText"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="1" x:Name="HistoryView" Visibility="Collapsed">
            <TextBlock Text="History â€” coming soon"
                       Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontStyle="Italic"/>
        </Grid>

        <Grid Grid.Row="1" x:Name="FriendsView" Visibility="Collapsed">
            <TextBlock Text="Friends â€” coming soon"
                       Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontStyle="Italic"/>
        </Grid>

    </Grid>
</UserControl>
