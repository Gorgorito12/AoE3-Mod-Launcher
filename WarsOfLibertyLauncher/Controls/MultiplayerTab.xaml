<UserControl x:Class="WarsOfLibertyLauncher.Controls.MultiplayerTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Subtab buttons (Rooms / Friends / Profile / History).
             Look matches the redesign brief: dim gray when inactive,
             white text + bright blue underline when active. Active
             state is set programmatically by UpdateSubtabHighlights. -->
        <Style x:Key="SubTab" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="2,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,24,0"/>
        </Style>

        <!-- Right-aligned status pill (Connected / Reconnecting /
             Offline) shown in the top-right of the header. Pure
             cosmetic — UpdateConnectionStatus() fills the labels
             and the dot brush. -->
        <Style x:Key="HeaderStatChip" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="18,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgBase}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>     <!-- Header (subtabs + status bar) -->
            <RowDefinition Height="*"/>        <!-- Active view -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             Header: subtabs on the left, connection-status pill on
             the right. The status pill replaces the older "chat-line"
             approach where disconnect/reconnect events were dumped
             into the room chat — those now live here, where the user
             expects to look for them.
             ============================================================ -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,8,24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="SubtabRooms" Click="SubtabRooms_Click" Style="{StaticResource SubTab}"/>
                    <Button x:Name="SubtabFriends" Click="SubtabFriends_Click" Style="{StaticResource SubTab}"/>
                    <Button x:Name="SubtabProfile" Click="SubtabProfile_Click" Style="{StaticResource SubTab}"/>
                    <Button x:Name="SubtabHistory" Click="SubtabHistory_Click" Style="{StaticResource SubTab}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Connection status: a coloured dot + label
                         ("Connected", "Reconnecting…", "Offline").
                         Updated by UpdateConnectionStatus() from
                         the session / WS state — no more disconnect
                         messages leaking into the chat log. -->
                    <StackPanel Style="{StaticResource HeaderStatChip}">
                        <Ellipse x:Name="ConnDot"
                                 Width="8" Height="8"
                                 Fill="{DynamicResource MpStatusOnline}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>
                        <TextBlock x:Name="ConnStatusText"
                                   Text="Connected"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Live quota: "X players online · Y active
                         rooms". Pulled from /quota every ~30s by
                         RefreshQuotaAsync. -->
                    <StackPanel Style="{StaticResource HeaderStatChip}">
                        <TextBlock x:Name="QuotaText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- NAT badge — kept as-is, drives the colour
                         tint from NatTypeDetector probe. Pushed
                         right so the user sees it but it doesn't
                         dominate. -->
                    <Border x:Name="NatBadgeBorder"
                            Background="{DynamicResource MpSurfaceAlt}"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8,2"
                            Margin="14,0,0,0"
                            Cursor="Help">
                        <TextBlock x:Name="NatBadgeText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================================
             ROOMS view: sign-in gate / room list / current-room panel.
             Only one of the three groups is visible at a time, driven
             from code-behind by RefreshFromSession().
             ============================================================ -->
        <Grid Grid.Row="1" x:Name="RoomsView">

            <!-- Signed-out gate. -->
            <StackPanel x:Name="SignInPanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="480">
                <TextBlock x:Name="SignInTitleText"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="18"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="SignInBodyText"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,12,0,18"/>
                <Button x:Name="SignInButton"
                        Click="SignInButton_Click"
                        Style="{StaticResource MpPrimaryButton}"
                        HorizontalAlignment="Center"
                        Padding="20,10"
                        MinWidth="220"/>
                <TextBlock x:Name="SignInErrorText"
                           Foreground="{DynamicResource MpStatusOffline}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,12,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Browser (signed in, no current lobby). Top toolbar:
                 user chip on the left, Refresh + Create room on the
                 right. Below: table header row, then either the
                 list of rooms or the empty-state illustration. -->
            <Grid x:Name="BrowserPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Radmin banner -->
                    <RowDefinition Height="Auto"/>   <!-- toolbar -->
                    <RowDefinition Height="Auto"/>   <!-- table header -->
                    <RowDefinition Height="*"/>      <!-- rows / empty state -->
                </Grid.RowDefinitions>

                <!-- Radmin VPN banner. The launcher only owns the
                     "meta" layer (rooms, chat, match history); the
                     actual game-to-game connection runs over Radmin
                     VPN, which the user installs once and joins the
                     community network manually. The banner is here so
                     a fresh installer knows what to do BEFORE they
                     try to start a game and get stuck on "Failed to
                     join". Dismissable so it doesn't nag once read. -->
                <Border Grid.Row="0"
                        x:Name="RadminBanner"
                        Background="#1f2c3d"
                        BorderBrush="#3a5a8c"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="24,12,24,0"
                        Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon (info dot) -->
                        <Border Grid.Column="0"
                                Width="24" Height="24"
                                CornerRadius="12"
                                Background="#3a5a8c"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                            <TextBlock Text="i"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Message -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Foreground="{DynamicResource TextPrimary}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap">
                                Multiplayer games need Radmin VPN
                            </TextBlock>
                            <TextBlock x:Name="RadminBannerBody"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0">
                                Install Radmin VPN and join the community network so AoE3 can see other players' games. Lobby chat works without it; the actual game does not.
                            </TextBlock>
                        </StackPanel>

                        <!-- Action buttons -->
                        <Button Grid.Column="2"
                                x:Name="RadminDownloadButton"
                                Click="RadminDownloadButton_Click"
                                Content="Download Radmin"
                                Style="{StaticResource MpSecondaryButton}"
                                Padding="12,6"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11"/>

                        <!-- Dismiss × -->
                        <Button Grid.Column="3"
                                x:Name="RadminDismissButton"
                                Click="RadminDismissButton_Click"
                                Content="✕"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="{DynamicResource TextSecondary}"
                                FontSize="14"
                                Cursor="Hand"
                                Padding="8,0"
                                Margin="6,0,0,0"
                                ToolTip="Hide this banner"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Toolbar -->
                <Grid Grid.Row="1" Margin="24,18,24,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- User chip: avatar circle + login + sign out. -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="34" Height="34"
                                CornerRadius="17"
                                Background="{DynamicResource MpSurfaceAlt}"
                                BorderBrush="{DynamicResource BorderSubtle}"
                                BorderThickness="1"
                                Margin="0,0,10,0">
                            <Grid>
                                <Ellipse x:Name="UserAvatarEllipse">
                                    <Ellipse.Fill>
                                        <ImageBrush x:Name="UserAvatarBrush"
                                                    Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock x:Name="UserAvatarInitial"
                                           Text=""
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="SignedInAsText"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="|"
                                   Foreground="{DynamicResource BorderSubtle}"
                                   FontSize="13"
                                   Margin="8,0"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="SignOutLink"
                                Click="SignOutLink_Click"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="#7fb0ff"
                                FontSize="12"
                                Cursor="Hand"
                                Padding="0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            x:Name="RefreshButton"
                            Click="RefreshButton_Click"
                            Style="{StaticResource MpSecondaryButton}"
                            Padding="16,8"
                            MinWidth="110"
                            Margin="0,0,10,0"/>

                    <Button Grid.Column="2"
                            x:Name="CreateRoomButton"
                            Click="CreateRoomButton_Click"
                            Style="{StaticResource MpPrimaryButton}"
                            Padding="18,8"
                            MinWidth="150"/>
                </Grid>

                <!-- Table header row. Column widths defined here so
                     code-behind can mirror them when it builds each
                     data row (BuildRoomRow). -->
                <Border Grid.Row="2"
                        Background="{DynamicResource MpSurface}"
                        BorderBrush="{DynamicResource MpDivider}"
                        BorderThickness="0,1,0,1"
                        Padding="24,8,24,8">
                    <Grid x:Name="RoomsHeaderGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition Width="2.4*" MinWidth="160"/>
                            <ColumnDefinition Width="1.6*" MinWidth="110"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1"
                                   x:Name="ColHeaderRoom"
                                   Foreground="{DynamicResource MpTableHeader}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   x:Name="ColHeaderHost"
                                   Foreground="{DynamicResource MpTableHeader}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3"
                                   x:Name="ColHeaderPlayers"
                                   Foreground="{DynamicResource MpTableHeader}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4"
                                   x:Name="ColHeaderPing"
                                   Foreground="{DynamicResource MpTableHeader}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="5"
                                   x:Name="ColHeaderStatus"
                                   Foreground="{DynamicResource MpTableHeader}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="6"
                                   x:Name="ColHeaderAction"
                                   Foreground="{DynamicResource MpTableHeader}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Rows OR empty-state. ScrollViewer keeps it
                     scannable when many rooms exist; the inner
                     RoomsListPanel is the same x:Name the old
                     code-behind already populates, just with the
                     row builder updated to a Grid layout. -->
                <Grid Grid.Row="3">
                    <ScrollViewer x:Name="RoomsListScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="RoomsListPanel" Margin="0,0,0,12"/>
                    </ScrollViewer>

                    <!-- Empty-state card. Visibility is toggled by
                         RefreshLobbiesAsync() — hidden by default,
                         shown when /lobbies returns zero. Visible
                         over the scroll so it sits centered. -->
                    <Border x:Name="RoomsEmptyState"
                            Background="Transparent"
                            BorderBrush="{DynamicResource MpDivider}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Margin="40,30,40,30"
                            Padding="40,40"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <!-- Simple SVG-style illustration: a
                                 pair of crossed flags + a drum.
                                 Pure Path geometry so no asset
                                 file is needed and it tints with
                                 the foreground colour. -->
                            <Viewbox Width="96" Height="96" Margin="0,0,0,18">
                                <Canvas Width="64" Height="64">
                                    <!-- Left flag staff + flag -->
                                    <Path Stroke="{DynamicResource TextSecondary}"
                                          StrokeThickness="1.5"
                                          Fill="{DynamicResource MpSurfaceAlt}"
                                          Data="M 20 4 L 20 50"/>
                                    <Path Stroke="{DynamicResource TextSecondary}"
                                          StrokeThickness="1.2"
                                          Fill="{DynamicResource MpSurfaceAlt}"
                                          Data="M 20 6 L 32 10 L 20 16 Z"/>
                                    <!-- Right flag -->
                                    <Path Stroke="{DynamicResource TextSecondary}"
                                          StrokeThickness="1.5"
                                          Fill="{DynamicResource MpSurfaceAlt}"
                                          Data="M 44 4 L 44 50"/>
                                    <Path Stroke="{DynamicResource TextSecondary}"
                                          StrokeThickness="1.2"
                                          Fill="{DynamicResource MpSurfaceAlt}"
                                          Data="M 44 6 L 56 10 L 44 16 Z"/>
                                    <!-- Drum body -->
                                    <Ellipse Stroke="{DynamicResource TextSecondary}"
                                             StrokeThickness="1.6"
                                             Fill="{DynamicResource MpSurfaceAlt}"
                                             Canvas.Left="18" Canvas.Top="36"
                                             Width="28" Height="22"/>
                                    <Ellipse Stroke="{DynamicResource TextSecondary}"
                                             StrokeThickness="1.4"
                                             Fill="{DynamicResource MpSurface}"
                                             Canvas.Left="18" Canvas.Top="32"
                                             Width="28" Height="8"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="EmptyTitleText"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="EmptyBodyText"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       Margin="0,6,0,18"
                                       HorizontalAlignment="Center"/>
                            <Button x:Name="EmptyCreateButton"
                                    Click="CreateRoomButton_Click"
                                    Style="{StaticResource MpOutlineBlueButton}"
                                    MinWidth="170"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Errors box (network/API). Shown when
                         RefreshLobbiesAsync throws — populated by
                         setting RoomsErrorText.Text + visibility. -->
                    <Border x:Name="RoomsErrorBox"
                            VerticalAlignment="Top"
                            Margin="24,12,24,0"
                            Padding="14,10"
                            Background="{DynamicResource StatusErrorBg}"
                            BorderBrush="{DynamicResource MpStatusOffline}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Visibility="Collapsed">
                        <TextBlock x:Name="RoomsErrorText"
                                   Foreground="{DynamicResource MpStatusOffline}"
                                   FontSize="11"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Grid>

            <!-- Inside-a-room view, rendered as a *non-modal*
                 floating popup positioned on a Canvas. The browser
                 stays fully interactive behind: the user can scroll
                 the rooms list, see who else is hosting, etc. The
                 popup is draggable by its header strip. During the
                 game-start countdown / InGame state it gets locked
                 (X hidden, drag disabled) so accidental clicks
                 don't kill an active match. -->
            <Grid x:Name="RoomPanel" Visibility="Collapsed">
                <Canvas x:Name="RoomPopupCanvas"
                        ClipToBounds="False"
                        SizeChanged="RoomPopupCanvas_SizeChanged">
                    <Border x:Name="RoomPopupCard"
                            Background="{DynamicResource BgBase}"
                            BorderBrush="{DynamicResource MpDivider}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Width="820"
                            Height="520"
                            SnapsToDevicePixels="True"
                            Canvas.Left="0"
                            Canvas.Top="0">
                    <Border.Effect>
                        <DropShadowEffect Color="Black"
                                          BlurRadius="28"
                                          ShadowDepth="0"
                                          Opacity="0.6"/>
                    </Border.Effect>
                    <!-- One Grid hosts everything inside the popup
                         card: the lobby content (header + body) +
                         the two overlays (countdown, in-game). The
                         overlays stack on top because they're later
                         in z-order; their Visibility flips when the
                         match phase changes. -->
                    <Grid x:Name="RoomPopupContentRoot">
                    <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Header strip -->
                    <RowDefinition Height="*"/>      <!-- Body (Players | Chat) -->
                </Grid.RowDefinitions>

                <!-- ========== Header strip ==========
                     Doubles as the popup's drag handle. Mouse-down
                     here captures the pointer and the move handler
                     in code-behind translates the card via
                     Canvas.SetLeft/SetTop. Drag is disabled while
                     the room is in the Starting / InGame state. -->
                <Border Grid.Row="0"
                        x:Name="RoomHeaderStrip"
                        Background="{DynamicResource MpSurface}"
                        BorderBrush="{DynamicResource MpDivider}"
                        BorderThickness="0,0,0,1"
                        Margin="14,14,14,0"
                        CornerRadius="6"
                        Cursor="SizeAll"
                        MouseLeftButtonDown="RoomHeaderStrip_MouseLeftButtonDown"
                        MouseLeftButtonUp="RoomHeaderStrip_MouseLeftButtonUp"
                        MouseMove="RoomHeaderStrip_MouseMove">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>   <!-- Blue icon square -->
                            <ColumnDefinition Width="Auto"/>   <!-- Title + status -->
                            <ColumnDefinition Width="*"/>      <!-- Stats blocks -->
                            <ColumnDefinition Width="Auto"/>   <!-- Close X -->
                        </Grid.ColumnDefinitions>

                        <!-- Crossed-swords icon square. -->
                        <Border Grid.Column="0"
                                Width="64"
                                Background="{DynamicResource MpBlueSubtle}"
                                BorderBrush="{DynamicResource MpDivider}"
                                BorderThickness="0,0,1,0"
                                CornerRadius="6,0,0,6">
                            <TextBlock Text="⚔"
                                       Foreground="{DynamicResource MpBlue}"
                                       FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Title + status line. -->
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="18,16,24,16">
                            <TextBlock x:Name="RoomTitleText"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       TextTrimming="CharacterEllipsis"/>
                            <!-- RoomMetaText kept for compatibility
                                 with the existing RenderRoomPanel
                                 — renders "In lobby · P2P LAN ready"
                                 with subtle colouring. -->
                            <TextBlock x:Name="RoomMetaText"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       Margin="0,4,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- Stat blocks: HOST / PLAYERS / ROOM ID.
                             Each is a tiny uppercase label over a
                             bigger value. Stretches to fill the
                             middle of the header so the right edge
                             stays anchored to the close X. -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,24,0">
                            <StackPanel Margin="0,0,40,0">
                                <TextBlock Text="HOST"
                                           Foreground="{DynamicResource MpTableHeader}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="RoomHostText"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,40,0">
                                <TextBlock Text="PLAYERS"
                                           Foreground="{DynamicResource MpTableHeader}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="RoomPlayersText"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="ROOM ID"
                                           Foreground="{DynamicResource MpTableHeader}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="RoomIdText"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           FontFamily="Consolas, Courier New, monospace"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Close X — same handler as Leave (so the
                             leave-room flow runs properly instead
                             of orphaning a room on the server). -->
                        <Button Grid.Column="3"
                                x:Name="RoomCloseXButton"
                                Click="LeaveRoomButton_Click"
                                Style="{StaticResource MpIconButton}"
                                Content="✕"
                                FontSize="16"
                                Width="40" Height="40"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                ToolTip="Leave room"/>
                    </Grid>
                </Border>

                <!-- ========== Body: Left (players + info + actions) | Right (chat) ========== -->
                <Grid Grid.Row="1" Margin="24,16,24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340"/>
                        <ColumnDefinition Width="16"/>     <!-- gutter -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ===== Left column ===== -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- PLAYERS header -->
                            <RowDefinition Height="*"/>      <!-- members list -->
                            <RowDefinition Height="Auto"/>   <!-- info card -->
                            <RowDefinition Height="Auto"/>   <!-- actions -->
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="PLAYERS"
                                   Foreground="{DynamicResource MpTableHeader}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Margin="2,0,0,10"/>

                        <Border Grid.Row="1"
                                Background="{DynamicResource MpSurface}"
                                BorderBrush="{DynamicResource MpDivider}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,0,0,14">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="RoomMembersPanel"/>
                            </ScrollViewer>
                        </Border>

                        <!-- Room & Network info card. Built by
                             RenderRoomPanel() from session state. -->
                        <Border Grid.Row="2"
                                Background="{DynamicResource MpSurface}"
                                BorderBrush="{DynamicResource MpDivider}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14,12"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,10">
                                    <TextBlock Text="📡 "
                                               Foreground="{DynamicResource MpBlue}"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="ROOM &amp; NETWORK INFO"
                                               Foreground="{DynamicResource MpTableHeader}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- 2x2 grid of label/value pairs.
                                     Compact so the card stays
                                     under 130 px and leaves room
                                     for the action buttons below. -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                        <TextBlock Text="Connection"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="10"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock x:Name="RoomConnectionText"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                                        <TextBlock Text="Mod"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="10"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock x:Name="RoomModText"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                        <TextBlock Text="Max players"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="10"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock x:Name="RoomMaxPlayersText"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="Password"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="10"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock x:Name="RoomPasswordText"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Stacked actions. Hierarchy as per brief:
                             Ready = positive (green-outline), Start
                             = primary blue + bigger weight, Leave =
                             dark red. -->
                        <StackPanel Grid.Row="3">
                            <Button x:Name="ReadyButton"
                                    Click="ReadyButton_Click"
                                    Style="{StaticResource MpReadyButton}"
                                    Margin="0,0,0,8"/>
                            <Button x:Name="StartButton"
                                    Click="StartButton_Click"
                                    Style="{StaticResource MpPrimaryButton}"
                                    Padding="14,12"
                                    HorizontalContentAlignment="Center"
                                    FontSize="13"
                                    Margin="0,0,0,8"
                                    Visibility="Collapsed"/>
                            <Button x:Name="LeaveRoomButton"
                                    Click="LeaveRoomButton_Click"
                                    Style="{StaticResource MpDangerButton}"
                                    Padding="14,12"
                                    HorizontalContentAlignment="Center"
                                    FontSize="13"/>
                        </StackPanel>
                    </Grid>

                    <!-- ===== Right column: Chat & Activity ===== -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource MpSurface}"
                            BorderBrush="{DynamicResource MpDivider}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- header -->
                                <RowDefinition Height="*"/>      <!-- chat log -->
                                <RowDefinition Height="Auto"/>   <!-- input -->
                            </Grid.RowDefinitions>

                            <!-- Header: title left, Clear chat right. -->
                            <Border Grid.Row="0"
                                    BorderBrush="{DynamicResource MpDivider}"
                                    BorderThickness="0,0,0,1"
                                    Padding="20,14,14,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="CHAT &amp; ACTIVITY"
                                               Foreground="{DynamicResource MpTableHeader}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            x:Name="ClearChatButton"
                                            Click="ClearChatButton_Click"
                                            Style="{StaticResource MpQuietButton}"
                                            Content="🗑  Clear chat"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1"
                                          x:Name="ChatScroll"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="20,14,14,8">
                                <StackPanel x:Name="ChatLogPanel"/>
                            </ScrollViewer>

                            <!-- Input bar. Emoji icon (decorative
                                 placeholder for now, future emoji
                                 picker) + textbox + Send. -->
                            <Border Grid.Row="2"
                                    BorderBrush="{DynamicResource MpDivider}"
                                    BorderThickness="0,1,0,0"
                                    Padding="14,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Textbox with a faux placeholder
                                         drawn via overlay TextBlock —
                                         WPF TextBox has no native
                                         placeholder. Hidden when the
                                         user types. -->
                                    <Grid Grid.Column="0">
                                        <TextBox x:Name="ChatInputBox"
                                                 Background="{DynamicResource MpSurfaceAlt}"
                                                 Foreground="White"
                                                 CaretBrush="White"
                                                 BorderBrush="{DynamicResource MpDivider}"
                                                 BorderThickness="1"
                                                 Padding="12,9"
                                                 FontSize="12"
                                                 MaxLength="500"
                                                 KeyDown="ChatInputBox_KeyDown"
                                                 TextChanged="ChatInputBox_TextChanged"/>
                                        <TextBlock x:Name="ChatPlaceholderText"
                                                   Text="Type a message..."
                                                   Foreground="#777"
                                                   FontSize="12"
                                                   FontStyle="Italic"
                                                   IsHitTestVisible="False"
                                                   VerticalAlignment="Center"
                                                   Margin="14,0,0,0"/>
                                    </Grid>

                                    <Button Grid.Column="1"
                                            x:Name="ChatEmojiButton"
                                            Click="ChatEmojiButton_Click"
                                            Style="{StaticResource MpIconButton}"
                                            Width="36" Height="36"
                                            Margin="6,0,0,0"
                                            Content="😊"
                                            FontSize="14"
                                            ToolTip="Insert emoji"/>

                                    <Button Grid.Column="2"
                                            x:Name="ChatSendButton"
                                            Click="ChatSendButton_Click"
                                            Style="{StaticResource MpPrimaryButton}"
                                            MinWidth="86"
                                            Padding="16,8"
                                            Margin="8,0,0,0"
                                            Content="Send"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
                    </Grid>     <!-- inner Grid wrapping the popup card content -->

                    <!-- ===== Countdown overlay =====
                         Shown over the popup contents during the 3-s
                         "Starting…" window before AoE3 launches. Sits
                         inside the card so the drop-shadow + corners
                         carry over. Hidden by default; toggled by
                         StartCountdown() in code-behind. -->
                    <Border x:Name="CountdownOverlay"
                            Background="#E61a1d24"
                            CornerRadius="8"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="CountdownLabel"
                                       Text="Starting in"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="CountdownNumber"
                                       Text="3"
                                       Foreground="{DynamicResource MpBlue}"
                                       FontSize="96"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="CountdownHint"
                                       Text="AoE3 will open automatically — keep the launcher running."
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- ===== In-game P2P status overlay =====
                         Replaces the lobby contents while the match
                         is running. Shows a pulsing "live" dot, a
                         match timer, per-peer connection quality +
                         RTT + bytes transferred, and a single big
                         "Cancel game" / "Leave game" button.
                         Code-behind refreshes it every ~1 s by
                         reading PeerMesh state — no Worker calls. -->
                    <Border x:Name="InGameOverlay"
                            Background="{DynamicResource BgBase}"
                            CornerRadius="8"
                            Visibility="Collapsed">
                        <Grid Margin="32,28">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>     <!-- live header -->
                                <RowDefinition Height="Auto"/>     <!-- match meta line -->
                                <RowDefinition Height="*"/>        <!-- peers list -->
                                <RowDefinition Height="Auto"/>     <!-- action -->
                            </Grid.RowDefinitions>

                            <!-- Pulsing dot + headline. -->
                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Ellipse x:Name="InGameLiveDot"
                                         Width="14" Height="14"
                                         Fill="{DynamicResource MpStatusOnline}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,12,0"/>
                                <TextBlock Text="GAME IN PROGRESS"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="InGameModeText"
                                           Text=" — Connected via P2P LAN"
                                           Foreground="{DynamicResource MpStatusOnline}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                            </StackPanel>

                            <!-- Match timer + total traffic counter. -->
                            <Grid Grid.Row="1" Margin="0,16,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="MATCH TIME"
                                               Foreground="{DynamicResource MpTableHeader}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="InGameMatchTimer"
                                               Text="00:00"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="20"
                                               FontFamily="Consolas, Courier New, monospace"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="TRAFFIC"
                                               Foreground="{DynamicResource MpTableHeader}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="InGameTrafficText"
                                               Text="0 KB"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="20"
                                               FontFamily="Consolas, Courier New, monospace"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="ROOM"
                                               Foreground="{DynamicResource MpTableHeader}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="InGameRoomText"
                                               Text=""
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>

                            <!-- Per-peer connection rows. -->
                            <Border Grid.Row="2"
                                    Background="{DynamicResource MpSurface}"
                                    BorderBrush="{DynamicResource MpDivider}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="14,10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="InGamePeersPanel"/>
                                </ScrollViewer>
                            </Border>

                            <!-- Cancel / Leave action. Caption +
                                 colour change is driven from code-
                                 behind depending on whether the
                                 current user is the host. -->
                            <Button Grid.Row="3"
                                    x:Name="InGameCancelButton"
                                    Click="InGameCancelButton_Click"
                                    Style="{StaticResource MpDangerButton}"
                                    Padding="18,12"
                                    Margin="0,18,0,0"
                                    HorizontalContentAlignment="Center"
                                    FontSize="13"
                                    Content="⚠  Cancel game"/>
                        </Grid>
                    </Border>
                    </Grid>        <!-- x:Name="RoomPopupContentRoot" -->
                </Border>          <!-- floating card -->
                </Canvas>          <!-- popup canvas -->
            </Grid>             <!-- x:Name="RoomPanel" -->
        </Grid>                 <!-- x:Name="RoomsView" -->

        <!-- Profile / History / Friends subviews. -->
        <Grid Grid.Row="1" x:Name="ProfileView" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="32,24" MaxWidth="640" HorizontalAlignment="Left">
                    <TextBlock x:Name="ProfileNameText"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="18"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="ProfileLoginText"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"
                               Margin="0,2,0,16"/>
                    <TextBlock x:Name="ProfileEloText"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="14"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="ProfileGamesText"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="1" x:Name="HistoryView" Visibility="Collapsed">
            <TextBlock Text="History — coming soon"
                       Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontStyle="Italic"/>
        </Grid>

        <Grid Grid.Row="1" x:Name="FriendsView" Visibility="Collapsed">
            <TextBlock Text="Friends — coming soon"
                       Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontStyle="Italic"/>
        </Grid>

    </Grid>
</UserControl>
