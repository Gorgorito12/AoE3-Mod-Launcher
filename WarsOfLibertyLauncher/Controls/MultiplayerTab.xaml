<UserControl x:Class="WarsOfLibertyLauncher.Controls.MultiplayerTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SubTab" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="2,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,22,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgBase}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>     <!-- Header (subtabs + quota) -->
            <RowDefinition Height="*"/>         <!-- Active view -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             Header: subtabs on the left, quota bar on the right.
             ============================================================ -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,12,24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="SubtabRooms" Click="SubtabRooms_Click" Style="{StaticResource SubTab}"/>
                    <Button x:Name="SubtabFriends" Click="SubtabFriends_Click" Style="{StaticResource SubTab}"/>
                    <Button x:Name="SubtabProfile" Click="SubtabProfile_Click" Style="{StaticResource SubTab}"/>
                    <Button x:Name="SubtabHistory" Click="SubtabHistory_Click" Style="{StaticResource SubTab}"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- NAT badge — populated by NatTypeDetector probe.
                         Background colour changes with the result so a
                         glance at the header tells the user whether
                         their network is going to give them trouble. -->
                    <Border x:Name="NatBadgeBorder"
                            Background="{DynamicResource BgPanelAlt}"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8,3"
                            Margin="0,0,12,0"
                            Cursor="Help">
                        <TextBlock x:Name="NatBadgeText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock x:Name="QuotaText"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================================
             ROOMS view: WinDivert gate / sign-in gate / room list /
             current-room panel. Only one of the four groups is visible
             at a time, driven from code-behind by RefreshFromSession().
             ============================================================ -->
        <Grid Grid.Row="1" x:Name="RoomsView">

            <!-- WinDivert bootstrap gate. The launcher needs WinDivert
                 (DLL + signed kernel driver) to capture AoE3's LAN
                 broadcasts and bridge them to peers over the P2P mesh.
                 Without it, even with hole-punching working, AoE3 sees
                 no other players. Supersedes the sign-in gate because
                 there's no point signing in if game traffic can't flow. -->
            <StackPanel x:Name="VlanBootstrapPanel"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="520">
                <TextBlock x:Name="VlanBootstrapTitle"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="18"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="VlanBootstrapBody"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,12,0,18"/>
                <ProgressBar x:Name="VlanBootstrapProgress"
                             Height="4"
                             Visibility="Collapsed"
                             Margin="0,0,0,12"/>
                <Button x:Name="VlanActionButton"
                        Click="VlanActionButton_Click"
                        Style="{StaticResource SidebarPrimaryButton}"
                        HorizontalAlignment="Center"
                        MinWidth="220"/>
                <TextBlock x:Name="VlanErrorText"
                           Foreground="Salmon"
                           FontSize="11"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,12,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- (ZeroTier bootstrap panel removed — superseded by WinDivert) -->

            <!-- Signed-out gate. -->
            <StackPanel x:Name="SignInPanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="480">
                <TextBlock x:Name="SignInTitleText"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="18"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="SignInBodyText"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,12,0,18"/>
                <Button x:Name="SignInButton"
                        Click="SignInButton_Click"
                        Style="{StaticResource SidebarPrimaryButton}"
                        HorizontalAlignment="Center"
                        MinWidth="220"/>
                <TextBlock x:Name="SignInErrorText"
                           Foreground="Salmon"
                           FontSize="11"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,12,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Browser (signed in, no current lobby). -->
            <Grid x:Name="BrowserPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>     <!-- toolbar -->
                    <RowDefinition Height="*"/>        <!-- list -->
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="24,14"
                        BorderBrush="{DynamicResource BorderSubtle}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="SignedInAsText"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="SignOutLink"
                                    Click="SignOutLink_Click"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Foreground="{DynamicResource TextSecondary}"
                                    FontSize="11"
                                    Cursor="Hand"
                                    Margin="8,0,0,0"
                                    Padding="0"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                x:Name="RefreshButton"
                                Click="RefreshButton_Click"
                                Style="{StaticResource SidebarPrimaryButton}"
                                Padding="14,6"
                                MinWidth="110"
                                Background="#3a3d44"
                                Margin="0,0,8,0"/>
                        <Button Grid.Column="2"
                                x:Name="CreateRoomButton"
                                Click="CreateRoomButton_Click"
                                Style="{StaticResource SidebarPrimaryButton}"
                                Padding="14,6"
                                MinWidth="140"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="RoomsListPanel" Margin="24,12,8,24"/>
                </ScrollViewer>
            </Grid>

            <!-- Inside-a-room panel. -->
            <Grid x:Name="RoomPanel" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Members + actions sidebar. -->
                <Border Grid.Column="0"
                        Background="{DynamicResource BgBase}"
                        BorderBrush="{DynamicResource BorderSubtle}"
                        BorderThickness="0,0,1,0"
                        Padding="18,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   x:Name="RoomTitleText"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="1"
                                   x:Name="RoomMetaText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   Margin="0,4,0,12"
                                   TextWrapping="Wrap"/>
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="RoomMembersPanel"/>
                        </ScrollViewer>
                        <StackPanel Grid.Row="3" Margin="0,12,0,0">
                            <Button x:Name="ReadyButton"
                                    Click="ReadyButton_Click"
                                    Style="{StaticResource SidebarPrimaryButton}"
                                    Margin="0,0,0,6"
                                    Background="#3a3d44"/>
                            <Button x:Name="StartButton"
                                    Click="StartButton_Click"
                                    Style="{StaticResource SidebarPrimaryButton}"
                                    Margin="0,0,0,6"
                                    Visibility="Collapsed"/>
                            <Button x:Name="LeaveRoomButton"
                                    Click="LeaveRoomButton_Click"
                                    Style="{StaticResource SidebarPrimaryButton}"
                                    Background="#7a2030"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Chat. -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0"
                                  x:Name="ChatScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="20,16,12,12">
                        <StackPanel x:Name="ChatLogPanel"/>
                    </ScrollViewer>
                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="0,1,0,0"
                            Padding="20,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     x:Name="ChatInputBox"
                                     Background="#2a2d34"
                                     Foreground="White"
                                     BorderBrush="#3a3d44"
                                     BorderThickness="1"
                                     Padding="8,6"
                                     FontSize="12"
                                     MaxLength="500"
                                     KeyDown="ChatInputBox_KeyDown"/>
                            <Button Grid.Column="1"
                                    x:Name="ChatSendButton"
                                    Click="ChatSendButton_Click"
                                    Style="{StaticResource SidebarPrimaryButton}"
                                    MinWidth="100"
                                    Padding="14,6"
                                    Margin="8,0,0,0"
                                    Content="Send"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Profile / History / Friends subviews: minimal placeholders for v1.0
             first cut. Filled in by RefreshFromSession() with cached data. -->
        <Grid Grid.Row="1" x:Name="ProfileView" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="32,24" MaxWidth="640" HorizontalAlignment="Left">
                    <TextBlock x:Name="ProfileNameText"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="18"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="ProfileLoginText"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"
                               Margin="0,2,0,16"/>
                    <TextBlock x:Name="ProfileEloText"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="14"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="ProfileGamesText"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="1" x:Name="HistoryView" Visibility="Collapsed">
            <TextBlock Text="History — coming soon"
                       Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontStyle="Italic"/>
        </Grid>

        <Grid Grid.Row="1" x:Name="FriendsView" Visibility="Collapsed">
            <TextBlock Text="Friends — coming soon"
                       Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontStyle="Italic"/>
        </Grid>
    </Grid>
</UserControl>
