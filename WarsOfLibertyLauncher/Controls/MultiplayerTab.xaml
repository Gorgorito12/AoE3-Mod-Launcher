<UserControl x:Class="WarsOfLibertyLauncher.Controls.MultiplayerTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Subtab buttons (Rooms / Friends / Profile / History).
             TERTIARY BLUE recipe â€” dim gray when inactive, soft sky
             (FgHoverBlue) on hover, white + bold + blue underline
             when active (active state still set programmatically by
             UpdateSubtabHighlights via BorderBrush/Foreground).

             ControlTemplate is REQUIRED â€” without it WPF falls back
             to the Aero default which paints a sky-blue gradient
             on hover (the "muy blancos" bug). TemplateBinding the
             BorderBrush + BorderThickness so the code-behind active-
             state setters still work without re-templating. -->
        <Style x:Key="SubTab" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="2,8"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,24,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- No background fill, just lift the
                                     text to soft sky. The blue identity
                                     stays in the underline (active) +
                                     hover text, never in a tile. -->
                                <Setter Property="Foreground" Value="{DynamicResource FgHoverBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Right-aligned status pill (Connected / Reconnecting /
             Offline) shown in the top-right of the header. Pure
             cosmetic â€” UpdateConnectionStatus() fills the labels
             and the dot brush. -->
        <Style x:Key="HeaderStatChip" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="18,0,0,0"/>
        </Style>

        <!-- Room ROW (table row, NOT a floating card). A flush surface with
             a hairline bottom divider and a subtle hover tint — so the list
             reads as a clean table like the reference mockup, not a stack of
             gapped cards. The row body (title, mod chip, host, players, ping,
             status badge, action button) is built in code-behind by
             BuildRoomCard so all the load-bearing state logic (action caption,
             in-place ping, mod-installed gating) is preserved. Left inset =
             Padding.Left 14 + ScrollViewer pad 16 = 30, matched by the header
             strip's 30px left margin so columns line up under the labels. -->
        <Style x:Key="MpRoomCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MpRoomRowBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MpDivider}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="14,9,14,9"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource MpRoomRowHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Clickable, sortable column header. Transparent button that shows
             the column label + a sort arrow (set in code-behind); brightens on
             hover. Left-aligned so the label sits flush over its column. Zero
             left padding keeps the ROOM label aligned with the 30px row inset. -->
        <Style x:Key="MpColHeaderButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- x:Name="TabRootGrid" — host for MpAlertOverlay notice/confirm cards
         (the themed replacement for MessageBox on the join / create / mod
         error paths that fire from the tab, outside a lobby window). -->
    <Grid x:Name="TabRootGrid" Background="{DynamicResource MpTabBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>     <!-- Header (subtabs + status bar) -->
            <RowDefinition Height="*"/>        <!-- Active view -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             Header: subtabs on the left, connection-status pill on
             the right. The status pill replaces the older "chat-line"
             approach where disconnect/reconnect events were dumped
             into the room chat â€” those now live here, where the user
             expects to look for them.
             ============================================================ -->
        <Border Grid.Row="0"
                Background="Transparent"
                BorderBrush="{DynamicResource MpDivider}"
                BorderThickness="0,0,0,1"
                Padding="24,8,24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Grid>
                        <Button x:Name="SubtabRooms" Click="SubtabRooms_Click" Style="{StaticResource SubTab}"/>
                        <!-- "New room created" dot: shown via SetNewRoomIndicator(true)
                             from MainWindow's poll, cleared when this subtab opens. -->
                        <Ellipse x:Name="RoomsSubtabDot"
                                 Width="7" Height="7"
                                 Fill="#E5484D"
                                 Stroke="{DynamicResource MpSurface}"
                                 StrokeThickness="1"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="0,4,4,0"
                                 IsHitTestVisible="False"
                                 Visibility="Collapsed"/>
                    </Grid>
                    <Button x:Name="SubtabFriends" Click="SubtabFriends_Click" Style="{StaticResource SubTab}"/>
                    <Button x:Name="SubtabProfile" Click="SubtabProfile_Click" Style="{StaticResource SubTab}"/>
                    <Button x:Name="SubtabHistory" Click="SubtabHistory_Click" Style="{StaticResource SubTab}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Connection status: a coloured dot + label
                         ("Connected", "Reconnectingâ€¦", "Offline").
                         Updated by UpdateConnectionStatus() from
                         the session / WS state â€” no more disconnect
                         messages leaking into the chat log. -->
                    <StackPanel Style="{StaticResource HeaderStatChip}">
                        <Ellipse x:Name="ConnDot"
                                 Width="8" Height="8"
                                 Fill="{DynamicResource MpStatusOnline}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>
                        <TextBlock x:Name="ConnStatusText"
                                   Text="Connected"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Live quota: "X players online Â· Y active
                         rooms". Pulled from /quota every ~30s by
                         RefreshQuotaAsync. -->
                    <StackPanel Style="{StaticResource HeaderStatChip}">
                        <TextBlock x:Name="QuotaText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- NAT badge â€” kept as-is, drives the colour
                         tint from NatTypeDetector probe. Pushed
                         right so the user sees it but it doesn't
                         dominate. -->
                    <Border x:Name="NatBadgeBorder"
                            Background="{DynamicResource MpSurfaceAlt}"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}"
                            Padding="8,2"
                            Margin="14,0,0,0"
                            Cursor="Help">
                        <TextBlock x:Name="NatBadgeText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================================
             ROOMS view: sign-in gate / room list / current-room panel.
             Only one of the three groups is visible at a time, driven
             from code-behind by RefreshFromSession().
             ============================================================ -->
        <Grid Grid.Row="1" x:Name="RoomsView">

            <!-- Signed-out gate. -->
            <StackPanel x:Name="SignInPanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="480">
                <TextBlock x:Name="SignInTitleText"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="{StaticResource FontSizeHeading}"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="SignInBodyText"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="{StaticResource FontSizeBody}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,12,0,18"/>
                <Button x:Name="SignInButton"
                        Click="SignInButton_Click"
                        Style="{StaticResource MpPrimaryButton}"
                        HorizontalAlignment="Center"
                        Padding="20,10"
                        MinWidth="220"/>
                <TextBlock x:Name="SignInErrorText"
                           Foreground="{DynamicResource MpStatusOffline}"
                           FontSize="{StaticResource FontSizeCaption}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,12,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Browser (signed in, no current lobby). Top toolbar:
                 user chip on the left, Refresh + Create room on the
                 right. Below: table header row, then either the
                 list of rooms or the empty-state illustration. -->
            <Grid x:Name="BrowserPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Radmin banner -->
                    <RowDefinition Height="Auto"/>   <!-- toolbar -->
                    <RowDefinition Height="*"/>      <!-- rooms (left) + global chat (right) -->
                </Grid.RowDefinitions>

                <!-- Radmin VPN banner. Three live states driven by
                     RadminVpnService.GetStatus():
                       * NotInstalled  â†’ red warning + "Install" button
                       * NotConnected  â†’ blue info + "Open Radmin" button
                       * Connected     â†’ green check + network-name copier
                                         + numbered "how to join" instructions
                     Layout: a 3-row Grid. Row 0 is always-on (icon, title
                     line, primary button). Rows 1 & 2 are the network-name
                     panel and the numbered steps, both shown only in the
                     Connected state so they don't waste vertical space when
                     the user can't act on them yet. Colours come from
                     code-behind. Polls every 3 s while mounted. -->
                <Border Grid.Row="0"
                        x:Name="RadminBanner"
                        x:FieldModifier="private"
                        Background="#1f2c3d"
                        BorderBrush="#3a5a8c"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMd}"
                        Margin="24,12,24,0"
                        Padding="12,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>    <!-- title + primary button -->
                            <RowDefinition Height="Auto"/>    <!-- network-name copier -->
                            <RowDefinition Height="Auto"/>    <!-- numbered instructions -->
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status icon. Glyph + colour are set by
                             RefreshRadminBanner() in code-behind. -->
                        <Border Grid.Row="0" Grid.Column="0"
                                x:Name="RadminStatusIcon"
                                Width="{StaticResource DiscSizeSm}" Height="{StaticResource DiscSizeSm}"
                                CornerRadius="{StaticResource DiscRadiusSm}"
                                Background="#3a5a8c"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                            <TextBlock x:Name="RadminStatusGlyph"
                                       Text="i"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Title + body -->
                        <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="RadminBannerTitle"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="RadminBannerBody"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Primary actions: [Show steps] opens the
                             guided assistant overlay; [Install /
                             Open Radmin] is the legacy one-click
                             quick action. Stacked horizontally so a
                             power user can hit "Open Radmin" without
                             going through the tutorial. -->
                        <StackPanel Grid.Row="0" Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0">
                            <Button x:Name="RadminShowStepsButton"
                                    Click="RadminShowStepsButton_Click"
                                    Style="{StaticResource MpSecondaryButton}"
                                    Padding="12,6"
                                    Margin="0,0,6,0"
                                    FontSize="{StaticResource FontSizeCaption}"/>
                            <Button x:Name="RadminPrimaryButton"
                                    Click="RadminPrimaryButton_Click"
                                    Style="{StaticResource MpSecondaryButton}"
                                    Padding="12,6"
                                    FontSize="{StaticResource FontSizeCaption}"/>
                        </StackPanel>

                        <!-- Network-name copier. A read-only TextBox so
                             the name can be selected and inspected
                             visually, paired with a "Copy" button that
                             pushes it to the clipboard without needing
                             to open Radmin first. Only shown in the
                             Connected state. -->
                        <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                x:Name="RadminNetworkNamePanel"
                                Background="#15282a"
                                BorderBrush="#3a8c5a"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}"
                                Margin="0,10,0,0"
                                Padding="8,6"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         x:Name="RadminNetworkNameBox"
                                         Text="Age of Empires III: The Asian Dynasties"
                                         IsReadOnly="True"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontFamily="Consolas, Courier New, monospace"
                                         FontSize="{StaticResource FontSizeCaption}"
                                         Foreground="{DynamicResource TextPrimary}"
                                         VerticalAlignment="Center"
                                         VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1"
                                        x:Name="RadminCopyNameButton"
                                        Click="RadminCopyNameButton_Click"
                                        Style="{StaticResource MpSecondaryButton}"
                                        Padding="10,4"
                                        Margin="8,0,0,0"
                                        FontSize="{StaticResource FontSizeCaption}"
                                        MinWidth="100"/>
                            </Grid>
                        </Border>

                        <!-- Numbered step-by-step instructions. Static
                             text set by RefreshRadminBanner() so it
                             follows the language switch. Only shown in
                             the Connected state. -->
                        <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                   x:Name="RadminInstructionsText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- Toolbar -->
                <Grid Grid.Row="1" Margin="24,18,24,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- User chip: avatar circle + login + sign out. -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="{StaticResource DiscSizeMd}" Height="{StaticResource DiscSizeMd}"
                                CornerRadius="{StaticResource DiscRadiusMd}"
                                Background="{DynamicResource MpSurfaceAlt}"
                                BorderBrush="{DynamicResource BorderSubtle}"
                                BorderThickness="1"
                                Margin="0,0,10,0">
                            <Grid>
                                <Ellipse x:Name="UserAvatarEllipse">
                                    <Ellipse.Fill>
                                        <ImageBrush x:Name="UserAvatarBrush"
                                                    Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock x:Name="UserAvatarInitial"
                                           Text=""
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="SignedInAsText"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="|"
                                   Foreground="{DynamicResource BorderSubtle}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Margin="8,0"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="SignOutLink"
                                Click="SignOutLink_Click"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="{DynamicResource MpBlue}"
                                FontSize="{StaticResource FontSizeBody}"
                                Cursor="Hand"
                                Padding="0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            x:Name="RefreshButton"
                            Click="RefreshButton_Click"
                            Style="{StaticResource MpSecondaryButton}"
                            Padding="16,8"
                            MinWidth="110"
                            Margin="0,0,10,0"/>

                    <Button Grid.Column="2"
                            x:Name="CreateRoomButton"
                            Click="CreateRoomButton_Click"
                            Style="{StaticResource MpPrimaryButton}"
                            Padding="18,8"
                            MinWidth="150"/>
                </Grid>

                <!-- Row 2: two-column content — active rooms (left) +
                     persistent global chat (right). The rooms table and
                     the chat panel each live in their own card. -->
                <Grid Grid.Row="2" Margin="24,2,24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="16"/>     <!-- gutter -->
                        <!-- Global chat ≈24-25%. Flexible: shrinks to 320, caps
                             at 360 (so the rooms table takes ~75%). -->
                        <ColumnDefinition Width="*" MinWidth="320" MaxWidth="360"/>
                    </Grid.ColumnDefinitions>

                    <!-- ===================== LEFT: active rooms ===================== -->
                    <!-- Wrapper: glow underlay (Effect, no children) BEHIND the
                         real content card (no Effect → text stays ClearType-crisp). -->
                    <Grid Grid.Column="0">
                    <Border Background="{DynamicResource MpSurface}"
                            CornerRadius="{StaticResource RadiusLg}"
                            Margin="1">
                        <Border.Effect>
                            <DropShadowEffect Color="#3A6BD0" BlurRadius="18" ShadowDepth="0" Opacity="0.28"/>
                        </Border.Effect>
                    </Border>
                    <Border Background="{DynamicResource MpSurface}"
                            BorderBrush="{DynamicResource MpCardBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusLg}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- section title -->
                                <RowDefinition Height="Auto"/>   <!-- table header -->
                                <RowDefinition Height="*"/>      <!-- rows / empty / error -->
                                <RowDefinition Height="Auto"/>   <!-- footer: "Showing N rooms" -->
                            </Grid.RowDefinitions>

                            <!-- Section title: people glyph + "Salas activas"
                                 on the left, "last updated" timestamp on the
                                 right (set by UpdateRoomsUpdatedLabel). -->
                            <Grid Grid.Row="0" Margin="20,16,20,12">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="👥"
                                               FontSize="{StaticResource FontSizeSubtitle}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,9,0"/>
                                    <TextBlock x:Name="RoomsSectionTitle"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="{StaticResource FontSizeSubtitle}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="RoomsUpdatedText"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="{StaticResource FontSizeCaption}"/>
                            </Grid>

                            <!-- Column headers for the room list. The rows
                                 (BuildRoomCard) mirror these EXACT 7 column defs,
                                 and the 30px side margin matches each row's
                                 content inset (ScrollViewer pad 16 + row padding
                                 14; the row has no side border) so the columns
                                 line up under the labels. Keep the two grids in
                                 sync (lockstep invariant). Columns 0-5 are
                                 clickable/sortable buttons (label + sort arrow,
                                 arrows set by UpdateSortArrows); ACTION (6) is a
                                 plain centered label. Columns are STAR-sized with
                                 Min/Max so the row never overflows a narrow
                                 window (horizontal scroll is disabled); ROOM has
                                 no MaxWidth so it absorbs slack (no empty band).
                                 The right margin is bumped by the scrollbar width
                                 at runtime (SyncHeaderScrollbarGutter) so the
                                 header tracks the rows when the vbar shows. -->
                            <Border Grid.Row="1"
                                    Background="#0C1626"
                                    BorderBrush="{DynamicResource MpDivider}"
                                    BorderThickness="0,0,0,1">
                            <Grid x:Name="RoomsHeaderStrip" Margin="30,7,30,7">
                                <!-- Proportional, NO MaxWidth: on a wide window
                                     every column grows together so the "air"
                                     distributes evenly (symmetric) instead of
                                     ROOM absorbing all slack. Low MinWidths so
                                     the 7 columns still fit a small window with
                                     the ACTION button visible. Keep IDENTICAL to
                                     BuildRoomCard (lockstep). -->
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.3*" MinWidth="120"/>
                                    <ColumnDefinition Width="1.05*" MinWidth="58"/>
                                    <ColumnDefinition Width="1.35*" MinWidth="66"/>
                                    <ColumnDefinition Width="0.62*" MinWidth="46"/>
                                    <ColumnDefinition Width="0.62*" MinWidth="48"/>
                                    <ColumnDefinition Width="0.9*" MinWidth="60"/>
                                    <ColumnDefinition Width="0.95*" MinWidth="100"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource MpColHeaderButton}" Tag="Room" Click="RoomHeader_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="ColHeaderRoom" Foreground="{DynamicResource MpTableHeader}" FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="SortArrowRoom" Text="⇅" Foreground="{DynamicResource MpTableHeader}" FontSize="{StaticResource FontSizeCaption}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Style="{StaticResource MpColHeaderButton}" Tag="Mod" Click="RoomHeader_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="ColHeaderMod" Foreground="{DynamicResource MpTableHeader}" FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="SortArrowMod" Text="⇅" Foreground="{DynamicResource MpTableHeader}" FontSize="{StaticResource FontSizeCaption}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2" Style="{StaticResource MpColHeaderButton}" Tag="Host" Click="RoomHeader_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="ColHeaderHost" Foreground="{DynamicResource MpTableHeader}" FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="SortArrowHost" Text="⇅" Foreground="{DynamicResource MpTableHeader}" FontSize="{StaticResource FontSizeCaption}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="3" Style="{StaticResource MpColHeaderButton}" Tag="Players" Click="RoomHeader_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="ColHeaderPlayers" Foreground="{DynamicResource MpTableHeader}" FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="SortArrowPlayers" Text="⇅" Foreground="{DynamicResource MpTableHeader}" FontSize="{StaticResource FontSizeCaption}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="4" Style="{StaticResource MpColHeaderButton}" Tag="Ping" Click="RoomHeader_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="ColHeaderPing" Foreground="{DynamicResource MpTableHeader}" FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="SortArrowPing" Text="⇅" Foreground="{DynamicResource MpTableHeader}" FontSize="{StaticResource FontSizeCaption}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="5" Style="{StaticResource MpColHeaderButton}" Tag="Status" Click="RoomHeader_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="ColHeaderStatus" Foreground="{DynamicResource MpTableHeader}" FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="SortArrowStatus" Text="⇅" Foreground="{DynamicResource MpTableHeader}" FontSize="{StaticResource FontSizeCaption}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Grid.Column="6" x:Name="ColHeaderAction"
                                           Foreground="{DynamicResource MpTableHeader}"
                                           FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            </Border>

                <!-- Cards OR empty-state. ScrollViewer keeps it scannable
                     when many rooms exist; RoomsListPanel is a StackPanel so
                     each card stretches edge-to-edge (full-width list rows). -->
                <Grid Grid.Row="2">
                    <ScrollViewer x:Name="RoomsListScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="16,10,16,10">
                        <StackPanel x:Name="RoomsListPanel"/>
                    </ScrollViewer>

                    <!-- Empty-state card. Visibility is toggled by
                         RefreshLobbiesAsync() â€” hidden by default,
                         shown when /lobbies returns zero. Visible
                         over the scroll so it sits centered. -->
                    <Border x:Name="RoomsEmptyState"
                            Background="Transparent"
                            BorderBrush="{DynamicResource MpDivider}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusMd}"
                            Margin="40,30,40,30"
                            Padding="40,40"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <!-- Simple SVG-style illustration: a
                                 pair of crossed flags + a drum.
                                 Pure Path geometry so no asset
                                 file is needed and it tints with
                                 the foreground colour. -->
                            <Viewbox Width="96" Height="96" Margin="0,0,0,18">
                                <Canvas Width="64" Height="64">
                                    <!-- Left flag staff + flag -->
                                    <Path Stroke="{DynamicResource TextSecondary}"
                                          StrokeThickness="1.5"
                                          Fill="{DynamicResource MpSurfaceAlt}"
                                          Data="M 20 4 L 20 50"/>
                                    <Path Stroke="{DynamicResource TextSecondary}"
                                          StrokeThickness="1.2"
                                          Fill="{DynamicResource MpSurfaceAlt}"
                                          Data="M 20 6 L 32 10 L 20 16 Z"/>
                                    <!-- Right flag -->
                                    <Path Stroke="{DynamicResource TextSecondary}"
                                          StrokeThickness="1.5"
                                          Fill="{DynamicResource MpSurfaceAlt}"
                                          Data="M 44 4 L 44 50"/>
                                    <Path Stroke="{DynamicResource TextSecondary}"
                                          StrokeThickness="1.2"
                                          Fill="{DynamicResource MpSurfaceAlt}"
                                          Data="M 44 6 L 56 10 L 44 16 Z"/>
                                    <!-- Drum body -->
                                    <Ellipse Stroke="{DynamicResource TextSecondary}"
                                             StrokeThickness="1.6"
                                             Fill="{DynamicResource MpSurfaceAlt}"
                                             Canvas.Left="18" Canvas.Top="36"
                                             Width="28" Height="22"/>
                                    <Ellipse Stroke="{DynamicResource TextSecondary}"
                                             StrokeThickness="1.4"
                                             Fill="{DynamicResource MpSurface}"
                                             Canvas.Left="18" Canvas.Top="32"
                                             Width="28" Height="8"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="EmptyTitleText"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="{StaticResource FontSizeSubtitle}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="EmptyBodyText"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Margin="0,6,0,18"
                                       HorizontalAlignment="Center"/>
                            <Button x:Name="EmptyCreateButton"
                                    Click="CreateRoomButton_Click"
                                    Style="{StaticResource MpOutlineBlueButton}"
                                    MinWidth="170"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Errors box (network/API). Shown when
                         RefreshLobbiesAsync throws â€” populated by
                         setting RoomsErrorText.Text + visibility. -->
                    <Border x:Name="RoomsErrorBox"
                            VerticalAlignment="Top"
                            Margin="24,12,24,0"
                            Padding="14,10"
                            Background="{DynamicResource StatusErrorBg}"
                            BorderBrush="{DynamicResource MpStatusOffline}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}"
                            Visibility="Collapsed">
                        <TextBlock x:Name="RoomsErrorText"
                                   Foreground="{DynamicResource MpStatusOffline}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>

                            <!-- Footer: room count (no pagination — the list
                                 scrolls). Left inset matches the header/rows
                                 (30px). -->
                            <Border Grid.Row="3"
                                    BorderBrush="{DynamicResource MpDivider}"
                                    BorderThickness="0,1,0,0"
                                    Padding="30,10,30,12">
                                <TextBlock x:Name="RoomsShowingCount"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                    </Grid>
                    <!-- /LEFT card -->

                    <!-- ===================== RIGHT: global chat ===================== -->
                    <Grid Grid.Column="2">
                    <Border Background="{DynamicResource MpSurface}"
                            CornerRadius="{StaticResource RadiusLg}"
                            Margin="1">
                        <Border.Effect>
                            <DropShadowEffect Color="#3A6BD0" BlurRadius="18" ShadowDepth="0" Opacity="0.28"/>
                        </Border.Effect>
                    </Border>
                    <Border Background="{DynamicResource MpSurface}"
                            BorderBrush="{DynamicResource MpCardBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusLg}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- title -->
                                <RowDefinition Height="Auto"/>   <!-- channel + presence -->
                                <RowDefinition Height="*"/>      <!-- messages -->
                                <RowDefinition Height="Auto"/>   <!-- input -->
                            </Grid.RowDefinitions>

                            <!-- Title + presence merged onto one line:
                                 "💬 Chat global · ● N conectado". The old
                                 separate "Canal general" label + right-aligned
                                 presence count were consolidated here so the
                                 header reads as a single status line. -->
                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        Margin="18,16,18,12"
                                        VerticalAlignment="Center">
                                <TextBlock Text="💬"
                                           FontSize="{StaticResource FontSizeSubtitle}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBlock x:Name="GlobalChatHeaderText"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="{StaticResource FontSizeSubtitle}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="·"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="{StaticResource FontSizeSubtitle}"
                                           Margin="8,0,8,0"
                                           VerticalAlignment="Center"/>
                                <Ellipse Width="8" Height="8"
                                         Fill="{DynamicResource MpStatusOnline}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0"/>
                                <TextBlock x:Name="GlobalChatPresenceText"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Thin divider under the merged header. -->
                            <Border Grid.Row="1"
                                    Height="1"
                                    Background="{DynamicResource MpDivider}"
                                    Margin="18,0,18,0"/>

                            <!-- Messages list + empty/placeholder hint -->
                            <Grid Grid.Row="2">
                                <ScrollViewer x:Name="GlobalChatScroll"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="12,0,12,0">
                                    <StackPanel x:Name="GlobalChatPanel"/>
                                </ScrollViewer>
                                <TextBlock x:Name="GlobalChatEmptyHint"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           FontStyle="Italic"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Margin="24"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Grid>

                            <!-- Composer: text box + Send -->
                            <Border Grid.Row="3"
                                    BorderBrush="{DynamicResource MpDivider}"
                                    BorderThickness="0,1,0,0"
                                    Padding="12,10">
                                <StackPanel>
                                    <!-- Throttle / slow-mode hint: shown when the
                                         server drops a message, cleared on next keystroke. -->
                                    <TextBlock x:Name="GlobalChatNotice"
                                               Foreground="{DynamicResource MpStatusReconnect}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               TextWrapping="Wrap"
                                               Margin="2,0,2,6"
                                               Visibility="Collapsed"/>
                                    <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Margin="0,0,8,0">
                                        <TextBox x:Name="GlobalChatInput"
                                                 MaxLength="500"
                                                 MinHeight="40"
                                                 Padding="10,0,0,0"
                                                 VerticalContentAlignment="Center"
                                                 TextChanged="GlobalChatInput_TextChanged"
                                                 KeyDown="GlobalChatInput_KeyDown"/>
                                        <TextBlock x:Name="GlobalChatPlaceholder"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False"/>
                                    </Grid>
                                    <!-- Send: compact icon button (paper-plane
                                         glyph). Localized caption lives on the
                                         ToolTip now (set in ApplyStrings). -->
                                    <Button x:Name="GlobalChatSendButton"
                                            Grid.Column="1"
                                            Click="GlobalChatSendButton_Click"
                                            Style="{StaticResource MpPrimaryButton}"
                                            Width="44"
                                            Height="40"
                                            Padding="0">
                                        <TextBlock Text="&#xE724;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                    </Grid>
                    <!-- /RIGHT global chat -->
                </Grid>
            </Grid>


            <!-- The lobby UI that used to live here as a non-modal
                 floating popup (Canvas + RoomPopupCard Border + 600 lines
                 of content) has moved to LobbyWindow.xaml. It is now a
                 real top-level Window opened from MultiplayerTab.xaml.cs
                 via OpenLobbyWindow() — see the comment block above that
                 method. The browser stays here, fully visible while the
                 lobby is open since the Window does not overlay it. -->
        </Grid>                 <!-- x:Name="RoomsView" -->

        <!-- Profile / History / Friends subviews. -->
        <Grid Grid.Row="1" x:Name="ProfileView" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="32,24" MaxWidth="640" HorizontalAlignment="Left">
                    <TextBlock x:Name="ProfileNameText"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="{StaticResource FontSizeHeading}"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="ProfileLoginText"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="{StaticResource FontSizeBody}"
                               Margin="0,2,0,16"/>
                    <TextBlock x:Name="ProfileEloText"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="{StaticResource FontSizeBodyStrong}"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="ProfileGamesText"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="{StaticResource FontSizeBody}"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="1" x:Name="HistoryView" Visibility="Collapsed">
            <TextBlock Text="History â€” coming soon"
                       Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontStyle="Italic"/>
        </Grid>

        <Grid Grid.Row="1" x:Name="FriendsView" Visibility="Collapsed">
            <TextBlock Text="Friends â€” coming soon"
                       Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontStyle="Italic"/>
        </Grid>

    </Grid>
</UserControl>
