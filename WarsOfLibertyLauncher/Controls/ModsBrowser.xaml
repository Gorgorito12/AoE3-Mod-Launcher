<UserControl x:Class="WarsOfLibertyLauncher.Controls.ModsBrowser"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Compact button used for the filter chips. The selected chip
             gets a CatalogBlue background via code-behind so we don't
             need a trigger-heavy template for the four-state look.

             BasedOn={x:Type Button} pulls in the implicit Button style
             from Styles/Buttons.xaml — that's where the overlay-scrim
             hover template lives. Without BasedOn, this Style would
             fall back to the Aero default and the chip would paint a
             sky-blue gradient on hover. -->
        <Style x:Key="FilterChip" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource BgPanelAlt}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <!-- Subtab buttons (My mods / Catalog). TERTIARY NEUTRAL recipe —
             same fix as the multiplayer SubTab: without an explicit
             ControlTemplate, WPF Aero default paints a sky-blue gradient
             on hover. Template binding the BorderBrush so the
             selected-state setter in code-behind still works. -->
        <Style x:Key="SubTab" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="2,6"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,22,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource FgHoverNeutral}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgBase}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============================================================
             HEADER — three logical rows:
              1. Title + actions (search, refresh catalog, add local, ...)
              2. Subtabs (Mis mods / Catálogo)
              3. Filters + sort
             ============================================================ -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,16,24,0">
            <StackPanel>

                <!-- Row 1: title + actions. -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock x:Name="HeaderTitle"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="{StaticResource FontSizeHeading}"
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="HeaderSubtitle"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <!-- Search. -->
                        <Border Background="{DynamicResource BgBase}"
                                BorderBrush="{DynamicResource BorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}"
                                Padding="10,3"
                                Width="200"
                                Margin="0,0,10,0">
                            <Grid>
                                <TextBlock x:Name="SearchPlaceholderText"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           FontStyle="Italic"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>
                                <TextBox x:Name="SearchBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="8,3"
                                         Foreground="{DynamicResource TextPrimary}"
                                         CaretBrush="{DynamicResource TextPrimary}"
                                         FontSize="{StaticResource FontSizeBody}"
                                         VerticalContentAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Button x:Name="RefreshCatalogButton"
                                Background="{DynamicResource BgPanelAlt}"
                                Foreground="{DynamicResource TextPrimary}"
                                BorderBrush="{DynamicResource BorderSubtle}"
                                BorderThickness="1"
                                Padding="16,8"
                                Margin="0,0,8,0"
                                FontSize="{StaticResource FontSizeBody}"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Height="36"/>

                        <Button x:Name="AddLocalModButton"
                                Background="{DynamicResource CatalogBlue}"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="18,8"
                                Margin="0,0,8,0"
                                FontSize="{StaticResource FontSizeBody}"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Height="36"/>

                        <!-- Publish wizard — promoted out of the ⋮ overflow into a
                             first-class accent-outlined header button so modders can
                             find it. Outlined (not filled) keeps it visually distinct
                             from the blue "add to my mods" primary action. -->
                        <Button x:Name="PublishModButton"
                                Background="Transparent"
                                Foreground="{DynamicResource AccentBrush}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                BorderThickness="1"
                                Padding="16,8"
                                Margin="0,0,8,0"
                                FontSize="{StaticResource FontSizeBody}"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Height="36"/>

                        <Button x:Name="MoreMenuButton"
                                Background="Transparent"
                                Foreground="{DynamicResource TextPrimary}"
                                BorderBrush="{DynamicResource BorderSubtle}"
                                BorderThickness="1"
                                Padding="8,3"
                                FontSize="{StaticResource FontSizeTitle}"
                                FontWeight="Bold"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Content="⋮">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="MoreMenu"/>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Row 2: subtabs. -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button x:Name="SubTabMyMods" Style="{StaticResource SubTab}"/>
                    <Button x:Name="SubTabCatalog" Style="{StaticResource SubTab}"/>
                </StackPanel>

                <!-- Row 3: filters + sort. -->
                <Grid Margin="0,8,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock x:Name="FiltersLabel"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <Button x:Name="FilterAll"          Style="{StaticResource FilterChip}"/>
                        <Button x:Name="FilterInstalled"    Style="{StaticResource FilterChip}"/>
                        <Button x:Name="FilterNotInstalled" Style="{StaticResource FilterChip}"/>
                        <Button x:Name="FilterUpdates"      Style="{StaticResource FilterChip}"/>
                        <Button x:Name="FilterCompatible"   Style="{StaticResource FilterChip}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="SortLabel"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <ComboBox x:Name="SortBox"
                                  Background="{DynamicResource BgPanelAlt}"
                                  Foreground="{DynamicResource TextPrimary}"
                                  BorderBrush="{DynamicResource BorderSubtle}"
                                  Width="160"
                                  FontSize="{StaticResource FontSizeBody}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ============================================================
             BODY — two columns:
              Left: scrollable list of compact mod rows.
              Right: persistent detail panel for the selected mod.
             Column widths are star-based so the layout shrinks down
             gracefully on narrow / non-maximised windows.
             ============================================================ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="58*"/>
                <ColumnDefinition Width="42*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left: list. -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="ListSummary"
                           Grid.Row="0"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="{StaticResource FontSizeCaption}"
                           FontWeight="SemiBold"
                           Margin="24,14,16,8"/>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="24,0,16,16">
                    <StackPanel>
                        <StackPanel x:Name="RowsPanel"/>
                        <TextBlock x:Name="EmptyText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   Margin="0,40,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Right: detail panel. Always visible — empty state when no
                 row is selected. -->
            <Border Grid.Column="1"
                    Background="{DynamicResource BgPanel}"
                    BorderBrush="{DynamicResource BorderSubtle}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <!-- Empty state when no mod is selected. -->
                    <StackPanel x:Name="DetailEmptyPanel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="280">
                        <TextBlock x:Name="DetailEmptyText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Detail content. -->
                    <Grid x:Name="DetailContent" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Banner / hero. -->
                        <Border Grid.Row="0"
                                x:Name="DetailBanner"
                                Height="150"
                                CornerRadius="0">
                            <Grid>
                                <Image x:Name="DetailBannerImage"
                                       Stretch="UniformToFill"/>
                                <!-- Monogram overlay shown only when there's
                                     no real banner; otherwise the Image
                                     covers everything. -->
                                <Border x:Name="DetailMonogramHero"
                                        Width="{StaticResource DiscSizeXxl}" Height="{StaticResource DiscSizeXxl}"
                                        CornerRadius="{StaticResource DiscRadiusXxl}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,20,-36">
                                    <TextBlock x:Name="DetailMonogram"
                                               FontSize="{StaticResource FontSizeDisplay}"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Body (scrollable). -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="20,52,20,20">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DetailTitle"
                                               Grid.Column="0"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="{StaticResource FontSizeHeading}"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                    <Border x:Name="DetailStateBadge"
                                            Grid.Column="1"
                                            CornerRadius="{StaticResource RadiusSm}"
                                            Padding="8,3"
                                            VerticalAlignment="Center">
                                        <TextBlock x:Name="DetailStateBadgeText"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>

                                <TextBlock x:Name="DetailDescription"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,16"/>

                                <!-- Screenshot/GIF gallery: large viewer + a
                                     horizontal strip of clickable thumbnails.
                                     The whole section is hidden by code-behind
                                     when the mod ships no screenshots. -->
                                <StackPanel x:Name="DetailGallerySection"
                                            Margin="0,0,0,16"
                                            Visibility="Collapsed">
                                    <TextBlock x:Name="DetailGalleryTitle"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>
                                    <Border Background="{DynamicResource BgPanel}"
                                            CornerRadius="{StaticResource RadiusMd}"
                                            Height="260"
                                            Margin="0,0,0,8">
                                        <Image x:Name="DetailGalleryViewer"
                                               Stretch="Uniform"
                                               Margin="6"/>
                                    </Border>
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Disabled">
                                        <StackPanel x:Name="DetailGalleryStrip"
                                                    Orientation="Horizontal"/>
                                    </ScrollViewer>
                                </StackPanel>

                                <!-- Metadata two-column grid. Each row is
                                     created in code-behind so empty fields
                                     can be skipped — keeps the panel from
                                     showing dashes for data we don't have. -->
                                <Grid x:Name="DetailMetaGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel x:Name="DetailMetaLeft"  Grid.Column="0" Margin="0,0,8,0"/>
                                    <StackPanel x:Name="DetailMetaRight" Grid.Column="1" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- Features list. Hidden when the mod
                                     doesn't expose a features field — for
                                     now this is the description.keys list
                                     repurposed as 'available languages'. -->
                                <TextBlock x:Name="DetailFeaturesTitle"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           FontWeight="SemiBold"
                                           Margin="0,16,0,6"
                                           Visibility="Collapsed"/>
                                <StackPanel x:Name="DetailFeaturesPanel"/>

                                <!-- Community links (Discord / ModDB / forum /
                                     …) declared by the mod's manifest. Built
                                     in code-behind so the whole block can be
                                     collapsed when a mod declares none — which
                                     is every built-in and every manifest that
                                     predates the field, so the panel is
                                     unchanged in the common case. -->
                                <TextBlock x:Name="DetailLinksTitle"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           FontWeight="SemiBold"
                                           Margin="0,16,0,6"
                                           Visibility="Collapsed"/>
                                <WrapPanel x:Name="DetailLinksPanel"
                                           Orientation="Horizontal"
                                           Visibility="Collapsed"/>

                                <!-- Compatibility banner. Shown only when a
                                     blocker (incompatible AoE3 version,
                                     missing dependency, …) applies — empty
                                     for now since we don't yet model that
                                     in ModProfile. -->
                                <Border x:Name="DetailCompatBanner"
                                        Background="{DynamicResource StatusIncompatibleBg}"
                                        BorderBrush="{DynamicResource StatusIncompatibleFg}"
                                        BorderThickness="0,0,0,0"
                                        CornerRadius="{StaticResource RadiusSm}"
                                        Padding="12,8"
                                        Margin="0,16,0,0"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="DetailCompatText"
                                               Foreground="{DynamicResource StatusIncompatibleFg}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Action bar pinned to the bottom. Primary +
                             secondary buttons are rebuilt by code-behind
                             per selection so the labels follow the row
                             status (Install / Update / Play / Repair / …). -->
                        <Border Grid.Row="2"
                                Background="{DynamicResource BgPanelAlt}"
                                BorderBrush="{DynamicResource BorderSubtle}"
                                BorderThickness="0,1,0,0"
                                Padding="20,14">
                            <Grid>
                                <!-- Three columns since the "view mod page" button was
                                     removed: the official website is a pill in the
                                     community-links row now, so every external link
                                     sits in one place. -->
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="DetailPrimaryButton"
                                        Grid.Column="0"
                                        Background="{DynamicResource CatalogBlue}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Padding="0,10"
                                        FontWeight="SemiBold"
                                        FontSize="{StaticResource FontSizeBodyStrong}"
                                        Cursor="Hand"
                                        Margin="0,0,8,0"/>
                                <!-- Removing from the collection lives here, not in
                                     the primary slot: it's the one destructive-looking
                                     action in the panel and shouldn't be the easiest
                                     button to hit. Collapsed unless the mod is in the
                                     collection. -->
                                <Button x:Name="DetailRemoveButton"
                                        Grid.Column="1"
                                        Visibility="Collapsed"
                                        Background="{DynamicResource BgPanelAlt}"
                                        Foreground="{DynamicResource TextSecondary}"
                                        BorderBrush="{DynamicResource BorderSubtle}"
                                        BorderThickness="1"
                                        Padding="12,10"
                                        FontSize="{StaticResource FontSizeBody}"
                                        Cursor="Hand"
                                        Margin="0,0,6,0"/>
                                <Button x:Name="DetailMoreButton"
                                        Grid.Column="2"
                                        Background="Transparent"
                                        Foreground="{DynamicResource TextPrimary}"
                                        BorderBrush="{DynamicResource BorderSubtle}"
                                        BorderThickness="1"
                                        Padding="10,8"
                                        FontSize="{StaticResource FontSizeTitle}"
                                        FontWeight="Bold"
                                        Cursor="Hand"
                                        Content="⋯">
                                    <Button.ContextMenu>
                                        <ContextMenu x:Name="DetailMoreMenu"/>
                                    </Button.ContextMenu>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
