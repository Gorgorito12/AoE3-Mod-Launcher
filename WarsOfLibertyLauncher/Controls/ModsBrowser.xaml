<UserControl x:Class="WarsOfLibertyLauncher.Controls.ModsBrowser"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource BgBase}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header. Title block + filter row (search box + installed toggle).
             "Publish my mod" entry point lands in a later v0.9 commit. -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="HeaderTitle"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="HeaderSubtitle"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Filter row: search box + "only installed" toggle. Both
                     re-render via ApplyFilters(); the underlying profile
                     list is cached so MainWindow only repopulates on real
                     state changes (mod switch / catalog refresh / install). -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Background="{DynamicResource BgBase}"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,4"
                            Width="220"
                            Margin="0,0,12,0">
                        <Grid>
                            <TextBlock x:Name="SearchPlaceholderText"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       FontStyle="Italic"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                            <TextBox x:Name="SearchBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimary}"
                                     CaretBrush="{DynamicResource TextPrimary}"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>
                    <CheckBox x:Name="OnlyInstalledToggle"
                              Foreground="{DynamicResource TextPrimary}"
                              VerticalAlignment="Center"
                              FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,20,16,20">
            <StackPanel>
                <WrapPanel x:Name="CardsPanel" Orientation="Horizontal"/>
                <TextBlock x:Name="EmptyText"
                           Foreground="{DynamicResource TextSecondary}"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"
                           Margin="0,40,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
