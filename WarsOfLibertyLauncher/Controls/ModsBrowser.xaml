<UserControl x:Class="WarsOfLibertyLauncher.Controls.ModsBrowser"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource BgBase}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header. Filter / "Publish my mod" controls land in this row in
             subsequent v0.9 commits; for now it's just the title block. -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="HeaderTitle"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="HeaderSubtitle"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,20,16,20">
            <StackPanel>
                <WrapPanel x:Name="CardsPanel" Orientation="Horizontal"/>
                <TextBlock x:Name="EmptyText"
                           Foreground="{DynamicResource TextSecondary}"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"
                           Margin="0,40,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
