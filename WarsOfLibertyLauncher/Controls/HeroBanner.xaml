<UserControl x:Class="WarsOfLibertyLauncher.Controls.HeroBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="ModBannerHost"
            Height="140"
            CornerRadius="8"
            BorderBrush="{StaticResource BorderSubtle}"
            BorderThickness="1"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="1"
                        Margin="14,0,14,12"
                        VerticalAlignment="Bottom">
                <TextBlock x:Name="TitleText"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock x:Name="SubtitleText"
                           FontSize="11"
                           Foreground="#ccc"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
