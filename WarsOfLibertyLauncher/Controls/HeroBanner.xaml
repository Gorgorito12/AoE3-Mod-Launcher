<UserControl x:Class="WarsOfLibertyLauncher.Controls.HeroBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ROLLBACK: restored to the pre-Fase 3 simple banner — fixed
         140 px tall, plain title/subtitle in the bottom-left. The
         dorado palette swap from Fase 1 still applies (TextPrimary,
         BorderSubtle, etc. are now warm-gold tones via Colors.xaml). -->
    <Border x:Name="ModBannerHost"
            Height="140"
            CornerRadius="{StaticResource RadiusMd}"
            BorderBrush="{DynamicResource BorderSubtle}"
            BorderThickness="1"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="1"
                        Margin="14,0,14,12"
                        VerticalAlignment="Bottom">
                <TextBlock x:Name="TitleText"
                           FontSize="{StaticResource FontSizeHeading}"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock x:Name="SubtitleText"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="#ccc"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
