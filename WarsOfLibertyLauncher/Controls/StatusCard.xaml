<UserControl x:Class="WarsOfLibertyLauncher.Controls.StatusCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource BgPanel}"
            BorderBrush="{StaticResource BorderSubtle}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="14,12">
        <StackPanel>
            <!-- Estado row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Path Grid.Column="0"
                      x:Name="StatusRowIcon"
                      Width="14" Height="14"
                      Stretch="Uniform"
                      Fill="{StaticResource SuccessBrush}"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      Data="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z"/>
                <TextBlock Grid.Column="1"
                           Text="Estado:"
                           Foreground="#888"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           x:Name="StatusValueText"
                           Text="—"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource SuccessBrush}"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Versión actual row -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Path Grid.Column="0"
                      Width="14" Height="14"
                      Stretch="Uniform"
                      Fill="#888"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      Data="M21.41,11.58L12.41,2.58C12.05,2.22 11.55,2 11,2H4C2.89,2 2,2.89 2,4V11C2,11.55 2.22,12.05 2.59,12.41L11.58,21.41C11.95,21.78 12.45,22 13,22C13.55,22 14.05,21.78 14.41,21.41L21.41,14.41C21.78,14.05 22,13.55 22,13C22,12.45 21.77,11.94 21.41,11.58M5.5,7A1.5,1.5 0 0,1 4,5.5A1.5,1.5 0 0,1 5.5,4A1.5,1.5 0 0,1 7,5.5A1.5,1.5 0 0,1 5.5,7Z"/>
                <TextBlock Grid.Column="1"
                           x:Name="StatusInstalledLabel"
                           Foreground="#888"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           x:Name="CurrentVersionText"
                           Text="—"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Última versión row -->
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Path Grid.Column="0"
                      Width="14" Height="14"
                      Stretch="Uniform"
                      Fill="#888"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      Data="M19.35,10.04C18.67,6.59 15.64,4 12,4C9.11,4 6.6,5.64 5.35,8.04C2.34,8.36 0,10.91 0,14A6,6 0 0,0 6,20H19A5,5 0 0,0 24,15C24,12.36 21.95,10.22 19.35,10.04Z"/>
                <TextBlock Grid.Column="1"
                           x:Name="StatusLatestLabel"
                           Foreground="#888"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           x:Name="LatestVersionText"
                           Text="—"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- AoE3 missing row — collapsed by default; shown when
                 GameLauncher.FindAoe3Install can't resolve the game. -->
            <Grid x:Name="AoE3MissingRow"
                  Visibility="Collapsed"
                  Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Path Grid.Column="0"
                      Width="14" Height="14"
                      Stretch="Uniform"
                      Fill="{StaticResource ErrorBrush}"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      Data="M13,14H11V10H13M13,18H11V16H13M1,21H23L12,2L1,21Z"/>
                <TextBlock Grid.Column="1"
                           x:Name="AoE3MissingLabel"
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
                <Button Grid.Column="2"
                        x:Name="BrowseAoE3Button"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource InfoBrush}"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Padding="6,2"
                        Click="BrowseAoE3Button_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
