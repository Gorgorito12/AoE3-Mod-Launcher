<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ============================================================
         GEOMETRY SCALE — semantic spacing / radius / icon-disc /
         button-padding tokens. Same idea + rules as the FontSize scale
         in App.xaml: one knob per role, StaticResource (app-lifetime
         constants), consumed by Buttons.xaml / Inputs.xaml and every
         Controls/*.xaml. New UI binds to a token; it must not hardcode
         a literal size.

         WHY A SEPARATE DICTIONARY MERGED FIRST (not inline in App.xaml):
         a `{StaticResource}` used INSIDE a ControlTemplate body in a
         merged dictionary (Buttons/Inputs) can only resolve resources in
         dictionaries merged BEFORE it — NOT App.xaml's inline resources
         (those are added after the MergedDictionaries block, so a
         template-body lookup never sees them and throws "resource not
         found" at load). The FontSize tokens get away with living inline
         because they're only referenced from Setters (deferred) + direct
         element attributes, never from a merged-dictionary template body.
         These geometry tokens ARE referenced from template bodies (button
         + input corner radii), so they must live here and be merged ahead
         of Buttons.xaml / Inputs.xaml. (Same reason Colors.xaml is merged
         first — its brushes resolve inside those templates too.)

         The window-size scaler (Controls/UiScale.cs) scales the RENDER via
         a transform, not these token VALUES, so StaticResource stays
         correct. Load-bearing exemptions that deliberately stay literal:
         the two-tone popup-rim radii (kept here as a paired set, outer =
         inner + 1, NOT folded into the Radius scale), the gold brand-popup
         rim, the hero subtree, Segoe MDL2 glyph / monogram sizes, and the
         intentional fixed widths (chat 380, lobby left 340, hero icon 64).
         See CLAUDE.md before changing any of those.
         ============================================================ -->

    <!-- Spacing (Thickness). 4px base grid. CardPadding is the dominant
         existing card padding (kept at 14,12 to avoid drift);
         SectionPadding is the header gutter. -->
    <Thickness x:Key="SpaceXs">4</Thickness>
    <Thickness x:Key="SpaceSm">8</Thickness>
    <Thickness x:Key="SpaceMd">12</Thickness>
    <Thickness x:Key="SpaceLg">16</Thickness>
    <Thickness x:Key="SpaceXl">24</Thickness>
    <Thickness x:Key="CardPadding">14,12</Thickness>
    <Thickness x:Key="SectionPadding">24,16</Thickness>

    <!-- Corner radius (CornerRadius). Sm = buttons/inputs/badges,
         Md = cards/panels/info boxes, Lg = prominent tiles. -->
    <CornerRadius x:Key="RadiusSm">4</CornerRadius>
    <CornerRadius x:Key="RadiusMd">6</CornerRadius>
    <CornerRadius x:Key="RadiusLg">10</CornerRadius>
    <!-- Two-tone "punched-out" popup rim — NOT part of the scale. Outer
         MUST stay inner+1 (the 1px near-black band over the 2px bright
         inner line). See the popup-rim gotcha in CLAUDE.md. -->
    <CornerRadius x:Key="RadiusPopupInner">6</CornerRadius>
    <CornerRadius x:Key="RadiusPopupOuter">7</CornerRadius>
    <CornerRadius x:Key="RadiusPopupSubmenuInner">4</CornerRadius>
    <CornerRadius x:Key="RadiusPopupSubmenuOuter">5</CornerRadius>

    <!-- Icon-disc sizes (sys:Double for Width/Height) + paired radii
         (CornerRadius = size/2). Use the IconDisc* Border styles in
         Buttons.xaml so the radius can't drift from the size. Only for
         CIRCULAR discs — rounded squares (the 64px hero icon host) use a
         Radius* token instead. -->
    <sys:Double x:Key="DiscSizeSm">24</sys:Double>
    <sys:Double x:Key="DiscSizeMd">36</sys:Double>
    <sys:Double x:Key="DiscSizeXxl">72</sys:Double>
    <CornerRadius x:Key="DiscRadiusSm">12</CornerRadius>
    <CornerRadius x:Key="DiscRadiusMd">18</CornerRadius>
    <CornerRadius x:Key="DiscRadiusXxl">36</CornerRadius>

    <!-- Button padding (Thickness). The default family normalises the old
         7/8/9 vertical values to 8. -->
    <Thickness x:Key="BtnPadCompact">10,5</Thickness>
    <Thickness x:Key="BtnPadDefault">14,8</Thickness>
    <Thickness x:Key="BtnPadRow">14,10</Thickness>
    <Thickness x:Key="BtnPadRoomy">18,8</Thickness>
    <Thickness x:Key="BtnPadCta">14,14</Thickness>

    <!-- ============================================================
         TITLE BAR — the SINGLE source of truth for the global custom
         window chrome bar (Controls/TitleBar). Every window's title bar
         height, its WindowChrome CaptionHeight (set centrally in
         App.OnAnyWindowLoaded), and the min/max/close button geometry all
         read these. Don't hardcode a bar height or button size anywhere
         else — change it here once and every window follows.
         ============================================================ -->
    <!-- Bar height. Compact desktop caption. Sized to the MINIMUM that fits
         the original 24px title centred without clipping — the title size wins,
         the bar only grows enough to hold it (still far slimmer than the old
         ~64px padded rows). CaptionHeight matches this so the whole bar stays
         the native drag/double-click region. Single global knob — every
         window's bar + WindowChrome caption follow it; never hardcode a height
         per window. Independent of TitleBarTitleSize below. -->
    <sys:Double x:Key="TitleBarHeight">36</sys:Double>
    <!-- Caption-button footprint. Width is the classic 46px hit target;
         height fills the bar so they read as one strip. -->
    <sys:Double x:Key="TitleBarButtonWidth">46</sys:Double>
    <!-- Segoe MDL2 glyph size for the min/max/restore/close icons. -->
    <sys:Double x:Key="TitleBarGlyphSize">10</sys:Double>
    <!-- Title text size — the original window-title size (was Heading 24 per
         dialog before the global bar). Kept at 24 so titles stay as legible as
         before; this is its OWN knob, independent of TitleBarHeight (shrinking
         the bar must never shrink the title — the bar grows to fit instead). -->
    <sys:Double x:Key="TitleBarTitleSize">24</sys:Double>
    <!-- Left gutter before the icon/title; right side is flush with the
         buttons. -->
    <Thickness x:Key="TitleBarContentPadding">12,0,8,0</Thickness>

    <!-- ============================================================
         SIDEBAR NAV RAIL — the settings/properties dialogs' left tab rail
         (SidebarNavButton). The rail column is `Width="Auto"` clamped to this
         [min,max] so it sizes to the WIDEST nav item (icon + text + padding +
         active stripe) instead of a hardcoded 200px that clipped long labels
         like "CATÁLOGO DE MODS". Min keeps the prior visual footprint; max
         stops a freakishly long label from eating the content area (the label
         then ellipsises via SidebarNavLabel). Single source — both dialogs
         read these, no per-dialog literal.
         ============================================================ -->
    <sys:Double x:Key="SidebarRailMinWidth">200</sys:Double>
    <sys:Double x:Key="SidebarRailMaxWidth">340</sys:Double>
    <!-- Nav-item text size (SidebarNavLabel). Its OWN knob, independent of the
         normal body text (FontSizeBody) and of the rail width: the rail grows
         to fit this, the text is never shrunk to fit the rail. 16 = the size
         the SidebarNavButton style was already designed around. -->
    <sys:Double x:Key="SidebarNavTextSize">16</sys:Double>

    <!-- MainWindow top-tab text size (NavTabButton: LIBRARY/WORKSHOP/
         MULTIPLAYER). Its OWN knob, independent of the title and the dialog-rail
         nav. 20 = a touch larger than the old 18 so the main tabs read as the
         primary navigation without being oversized. -->
    <sys:Double x:Key="NavTabTextSize">14</sys:Double>

</ResourceDictionary>
