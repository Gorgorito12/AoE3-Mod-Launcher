<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surfaces -->
    <SolidColorBrush x:Key="BgBase" Color="#1a1d24"/>
    <SolidColorBrush x:Key="BgPanel" Color="#22252c"/>
    <SolidColorBrush x:Key="BgPanelAlt" Color="#2a2d34"/>
    <SolidColorBrush x:Key="BgNeutral" Color="#3a3d44"/>
    <SolidColorBrush x:Key="BgNeutralHover" Color="#4a4d54"/>
    <SolidColorBrush x:Key="BgNeutralPressed" Color="#5a5d64"/>

    <!-- Border -->
    <SolidColorBrush x:Key="BorderSubtle" Color="#3a3d44"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#f0f0f0"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#b8b8b8"/>

    <!-- Accent: per-mod theme. Static here today; swapped to a runtime
         DynamicResource on mod switch in commit 5. -->
    <SolidColorBrush x:Key="AccentBrush" Color="#c8102e"/>
    <SolidColorBrush x:Key="AccentBrushHover" Color="#e63950"/>

    <!-- Destructive (Uninstall). Stays static — never themed per mod. -->
    <SolidColorBrush x:Key="DangerBrush" Color="#8b0000"/>
    <SolidColorBrush x:Key="DangerBrushHover" Color="#a71d1d"/>

    <!-- Status foregrounds -->
    <SolidColorBrush x:Key="ErrorBrush" Color="#e63950"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#9bd99b"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#5b9bd5"/>
    <SolidColorBrush x:Key="InfoBrushHover" Color="#3a8cd9"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#d4a04a"/>

    <!-- Catalog redesign palette. Selection / primary CTA are blue (NOT
         the per-mod accent — that would make the selected row scream
         in WoL red). Status badges use desaturated tints so the list
         doesn't feel like a Christmas tree when many mods are shown. -->
    <SolidColorBrush x:Key="CatalogBlue" Color="#2f6fed"/>
    <SolidColorBrush x:Key="CatalogBlueHover" Color="#4581f0"/>
    <SolidColorBrush x:Key="CatalogBlueSubtle" Color="#1d2a44"/>

    <!-- Status badge backgrounds (use the matching *Text brush for fg). -->
    <SolidColorBrush x:Key="StatusInstalledBg" Color="#1f3a25"/>
    <SolidColorBrush x:Key="StatusInstalledFg" Color="#7ed28b"/>
    <SolidColorBrush x:Key="StatusNotInstalledBg" Color="#2c2f36"/>
    <SolidColorBrush x:Key="StatusNotInstalledFg" Color="#b8b8b8"/>
    <SolidColorBrush x:Key="StatusUpdateBg" Color="#3a2f1a"/>
    <SolidColorBrush x:Key="StatusUpdateFg" Color="#e0b85f"/>
    <SolidColorBrush x:Key="StatusIncompatibleBg" Color="#2a223a"/>
    <SolidColorBrush x:Key="StatusIncompatibleFg" Color="#a98cd6"/>
    <SolidColorBrush x:Key="StatusErrorBg" Color="#3a1a20"/>
    <SolidColorBrush x:Key="StatusErrorFg" Color="#e63950"/>

    <!-- =========================================================
         Multiplayer-tab specific palette.
         Multiplayer uses blue (not the per-mod red accent) as its
         primary action colour so the section is visually distinct
         from the mod-management screens and so red can be reserved
         for purely destructive states (leave room, disconnected,
         errors). All keys are prefixed Mp* so a quick grep tells
         you what's part of the multiplayer redesign vs. shared.
         ========================================================= -->

    <!-- Primary CTA blue + subtle variants. -->
    <SolidColorBrush x:Key="MpBlue" Color="#2f6fed"/>
    <SolidColorBrush x:Key="MpBlueHover" Color="#4581f0"/>
    <SolidColorBrush x:Key="MpBluePressed" Color="#245bc7"/>
    <!-- Subtle "blue tint" used for selected rows / hover backgrounds
         and for the outline variant of the empty-state Create room
         button. Low-saturation so it doesn't fight the dark base. -->
    <SolidColorBrush x:Key="MpBlueSubtle" Color="#1d2a44"/>

    <!-- Surfaces specific to multiplayer: slightly lighter than the
         shared BgPanel so the room table / chat bar feel "raised". -->
    <SolidColorBrush x:Key="MpSurface" Color="#1e222a"/>
    <SolidColorBrush x:Key="MpSurfaceAlt" Color="#262a33"/>
    <SolidColorBrush x:Key="MpDivider" Color="#2e323b"/>
    <SolidColorBrush x:Key="MpTableHeader" Color="#9aa0aa"/>

    <!-- Status dots used in the top-right connection pill, status
         column of the rooms table, and the inline lobby-chat status
         indicator. Online matches the existing SuccessBrush family. -->
    <SolidColorBrush x:Key="MpStatusOnline" Color="#3ec46d"/>
    <SolidColorBrush x:Key="MpStatusReconnect" Color="#e0b85f"/>
    <SolidColorBrush x:Key="MpStatusOffline" Color="#e63950"/>
    <SolidColorBrush x:Key="MpStatusWaiting" Color="#5b9bd5"/>
    <SolidColorBrush x:Key="MpStatusInGame" Color="#3ec46d"/>

    <!-- Destructive (Leave room). Darker than the shared DangerBrush
         so it doesn't compete with the blue primary. -->
    <SolidColorBrush x:Key="MpDanger" Color="#7a2030"/>
    <SolidColorBrush x:Key="MpDangerHover" Color="#962a3c"/>

    <!-- Ping bars — green / yellow / red. Used by the rooms-table
         "Ping" column and the in-room per-member RTT indicator. -->
    <SolidColorBrush x:Key="MpPingGood" Color="#3ec46d"/>
    <SolidColorBrush x:Key="MpPingMedium" Color="#e0b85f"/>
    <SolidColorBrush x:Key="MpPingBad" Color="#e63950"/>

</ResourceDictionary>
