                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- GOLD outline (room-card "Unirse"/"Reingresar"). Same shape as
         MpOutlineBlueButton but in the launcher's dorado accent — used on the
         room cards to match the reference mockup. Disabled state dims. -->
    <Style x:Key="MpOutlineGoldButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="{StaticResource BtnPadDefault}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusSm}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#22D8B66A"/>
                            <Setter Property="Foreground" Value="#F0DCA8"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Destructive (Leave room). Darker red than DangerBrush. -->
    <Style x:Key="MpDangerButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource MpDanger}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="{StaticResource BtnPadDefault}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusSm}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource MpDangerHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource BgNeutral}"/>
                            <Setter Property="Foreground" Value="#888"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Transparent square icon button (favorite star, close X, etc).
         Foreground gets coloured per-instance for the favorite-filled
         vs favorite-empty state. -->
    <Style x:Key="MpIconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusSm}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <!-- GHOST BLUE recipe: tint surface
                                 (MpSurfaceAlt) so the glyph reads as
                                 a hit-target square. Restored after
                                 the global pass blanked the fill. -->
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource MpSurfaceAlt}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ready button (room sidebar). Looks like a "checkbox in button
         form": green-outlined and transparent when idle, SOLID GREEN
         when active. Toggled by the code-behind via Tag="ready" /
         Tag="" (RenderRoomPanel) so we keep one visual style and one
         click handler.

         The Tag="ready" trigger is the ONLY thing that paints the
         active state — it was missing for a long time, so the button
         set its Tag, swapped its ✓/○ label, and never turned green
         ("el botón grande de marcar no se pone verde"). If the green
         ever disappears again, suspect this trigger, not the
         code-behind.

         Trigger ORDER is load-bearing: for a given property the LAST
         active trigger wins, so Tag="ready" must come AFTER IsMouseOver
         (else hovering a ready button would wash the green away), the
         ready+hover MultiTrigger after both (so a ready button still
         reacts to the mouse instead of feeling dead), and IsEnabled
         last so disabled always overrides. This works without a local
         Background/Foreground on the button (LobbyWindow.xaml sets
         neither) — a local value would beat every trigger here. -->
    <Style x:Key="MpReadyButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#dadde2"/>
        <Setter Property="BorderBrush" Value="{DynamicResource MpPingGood}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="{StaticResource BtnPadRow}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusSm}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#152a1d"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="Tag" Value="ready">
                            <Setter TargetName="border" Property="Background" Value="#15803D"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource MpStatusReady}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Tag" Value="ready"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="Background" Value="#16A34A"/>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource BgNeutral}"/>
                            <Setter Property="Foreground" Value="#666"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Compact secondary used for "Clear chat" in the room view
         header. Smaller padding + lighter weight than the global
         MpSecondaryButton so it sits as a quiet header utility,
         not a primary action. -->
    <Style x:Key="MpQuietButton" TargetType="Button" BasedOn="{StaticResource MpSecondaryButton}">
        <Setter Property="Padding" Value="{StaticResource BtnPadCompact}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <!-- Row-level Join button: the small one inside each room row in
         the rooms table. Looks like Secondary but with hover that
         shifts to MpBlue so it reads as "the primary action of this
         row" without competing with the global Create room button. -->
    <Style x:Key="MpRowJoinButton" TargetType="Button" BasedOn="{StaticResource MpSecondaryButton}">
        <Setter Property="MinWidth" Value="74"/>
        <Setter Property="Padding" Value="14,5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusSm}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource MpBlue}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource MpBlue}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource BgPanel}"/>
                            <Setter Property="Foreground" Value="#666"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         Icon-disc styles (circular icon/avatar holders). Size + radius
         are paired from the App.xaml geometry tokens so the radius can
         never drift from size/2 (a manual Width=36 / CornerRadius=18 is
         easy to get wrong on edit). Apply ONLY to CIRCULAR discs —
         rounded SQUARES (e.g. the 64px dashboard hero icon host) use a
         Radius* token directly instead. -->
    <Style x:Key="IconDiscSm" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource DiscSizeSm}"/>
        <Setter Property="Height" Value="{StaticResource DiscSizeSm}"/>
        <Setter Property="CornerRadius" Value="{StaticResource DiscRadiusSm}"/>
    </Style>
    <Style x:Key="IconDiscMd" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource DiscSizeMd}"/>
        <Setter Property="Height" Value="{StaticResource DiscSizeMd}"/>
        <Setter Property="CornerRadius" Value="{StaticResource DiscRadiusMd}"/>
    </Style>
    <Style x:Key="IconDiscXxl" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource DiscSizeXxl}"/>
        <Setter Property="Height" Value="{StaticResource DiscSizeXxl}"/>
        <Setter Property="CornerRadius" Value="{StaticResource DiscRadiusXxl}"/>
    </Style>

    <!-- ============================================================
         NOTIFICATION BELL PANEL — header link buttons + list rows.
         Used by the Steam-style notification popup in MainWindow.
         ============================================================ -->

    <!-- Small text "link" button for the panel header (Mark all read / Clear). -->
    <Style x:Key="NotifLinkButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Notification BELL button (title bar). Steam-style: a filled, rounded,
         inset tile so it reads as a clear hit-target instead of a faint glyph.
         Gold tile = both the launcher's accent AND a "notifications/attention"
         colour; dark glyph for max contrast. Hover lifts to the brighter gold,
         press to the deep gold. The red unread badge (in MainWindow) sits on
         top of this tile. -->
    <Style x:Key="NotificationBellButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="48"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <!-- Dark blue-grey tile (a touch darker than the bar): filled at
                         rest, a bit lighter on hover, lighter still while pressed or
                         while the panel is open (Tag=open). The bell (a Path in the
                         content) is translucent white with a thin black outline. -->
                    <Border x:Name="border"
                            Background="#283844"
                            CornerRadius="6"
                            Margin="0,3"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#2E4150"/>
                        </Trigger>
                        <Trigger Property="Tag" Value="open">
                            <Setter TargetName="border" Property="Background" Value="#3C5468"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#3C5468"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Clean tooltip for the notification bell (the default WPF tooltip
         inherits the theme's light Foreground over a pale background → an
         unreadable "black box"). Dark readable card, rounded, small. -->
    <Style x:Key="NotifToolTipStyle" TargetType="ToolTip">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="HasDropShadow" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{DynamicResource BgBase}"
                            BorderBrush="{DynamicResource MpDivider}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,4">
                        <ContentPresenter TextElement.Foreground="{DynamicResource TextPrimary}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Full-width clickable notification row: transparent idle, subtle tint
         on hover (so the whole row reads as a hit-target). -->
    <Style x:Key="NotifRowButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Stretch"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource MpSurfaceAlt}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
