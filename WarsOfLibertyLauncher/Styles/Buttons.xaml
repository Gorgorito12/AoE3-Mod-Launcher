    <!-- Outline blue (empty-state Create button under the illustration). -->
    <Style x:Key="MpOutlineBlueButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#7fb0ff"/>
        <Setter Property="BorderBrush" Value="{DynamicResource MpBlue}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="{StaticResource BtnPadDefault}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusSm}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <!-- SECONDARY BLUE outline recipe:
                                 MpBlueSubtle fill (low-alpha blue) +
                                 white text. The MpBlue outline stays
                                 (it's the identity of this button). -->
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource MpBlueSubtle}"/>
                            <Setter Property="Foreground" Value="White"/>
