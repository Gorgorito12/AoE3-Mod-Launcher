<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surfaces -->
    <SolidColorBrush x:Key="BgBase" Color="#f5f5f7"/>
    <SolidColorBrush x:Key="BgPanel" Color="#ffffff"/>
    <SolidColorBrush x:Key="BgPanelAlt" Color="#f0f0f3"/>
    <SolidColorBrush x:Key="BgNeutral" Color="#e0e0e5"/>
    <SolidColorBrush x:Key="BgNeutralHover" Color="#d0d0d8"/>
    <SolidColorBrush x:Key="BgNeutralPressed" Color="#c0c0c8"/>

    <!-- Border -->
    <SolidColorBrush x:Key="BorderSubtle" Color="#d0d0d8"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#1a1a1a"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#555555"/>

    <!-- Accent: per-mod theme, swapped at runtime by UpdateAccentResources. -->
    <SolidColorBrush x:Key="AccentBrush" Color="#c8102e"/>
    <SolidColorBrush x:Key="AccentBrushHover" Color="#e63950"/>

    <!-- Destructive (Uninstall). Stays static across themes. -->
    <SolidColorBrush x:Key="DangerBrush" Color="#8b0000"/>
    <SolidColorBrush x:Key="DangerBrushHover" Color="#a71d1d"/>

    <!-- Status foregrounds — darker variants on white for contrast. -->
    <SolidColorBrush x:Key="ErrorBrush" Color="#c8102e"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#2e7d32"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#1976d2"/>
    <SolidColorBrush x:Key="InfoBrushHover" Color="#0d47a1"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#ed6c02"/>

</ResourceDictionary>
