<Window x:Class="WarsOfLibertyLauncher.TranslationApplyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WarsOfLibertyLauncher.Controls"
        Title="Aplicar traducción"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
            <Setter Property="Height" Value="6"/>
        </Style>
    </Window.Resources>

    <!-- Opaque window surface. The 44 px global TitleBar + WindowChrome drag +
         rounded corners are applied centrally in App.OnAnyWindowLoaded; here we
         keep a thin 1 px frame. -->
    <Border CornerRadius="0"
            Background="{DynamicResource BgBase}"
            BorderBrush="{DynamicResource BorderSubtle}"
            BorderThickness="1">
        <StackPanel>
            <controls:TitleBar Grid.Row="0"
                               x:Name="TitleBarControl"
                               ShowMinimize="False"
                               ShowMaximize="False"
                               ShowClose="True"/>

            <StackPanel Margin="24,8,24,24">
                <!-- Header: language monogram chip + name + version -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Border Width="46" Height="46"
                            CornerRadius="8"
                            Background="{DynamicResource BgPanelAlt}"
                            BorderBrush="{DynamicResource BorderAccentBadge}"
                            BorderThickness="1"
                            Margin="0,0,14,0"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="FlagText"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="{DynamicResource DisplayFont}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="NameText"
                                   FontSize="{StaticResource FontSizeHeading}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="AuthorText"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Compatibility badge (color-coded in code-behind) -->
                <Border x:Name="CompatBadge"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,12,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="CompatIcon"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock x:Name="CompatText"
                                   FontSize="{StaticResource FontSizeBody}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="430"/>
                    </StackPanel>
                </Border>

                <!-- Metadata grid: compatible mod versions + size -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               x:Name="LblModVersions"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Margin="0,0,12,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               x:Name="ModVersionsText"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="{StaticResource FontSizeBody}"
                               FontFamily="Consolas"
                               Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               x:Name="LblSize"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Margin="0,0,12,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               x:Name="SizeText"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="{StaticResource FontSizeBody}"/>
                </Grid>

                <!-- Optional translator's note — highlighted gold card so the
                     pack's free-form description stands out (was a plain muted
                     TextBlock that got lost). Same tinted-card pattern as the
                     CompatBadge above. -->
                <Border x:Name="DescriptionPanel"
                        Background="{DynamicResource TintAccentBadge}"
                        BorderBrush="{DynamicResource BorderAccentBadge}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMd}"
                        Padding="{StaticResource CardPadding}"
                        Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="DescriptionLabel"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="DescriptionText"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource TextPrimary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Download progress block (visible only during download) -->
                <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,12">
                    <Grid Margin="0,0,0,4">
                        <TextBlock x:Name="ProgressLabelText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="{StaticResource FontSizeCaption}"/>
                        <TextBlock x:Name="ProgressPercentText"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="{StaticResource FontSizeCaption}"/>
                    </Grid>
                    <ProgressBar x:Name="DownloadProgress"/>
                    <TextBlock x:Name="ProgressBytesText"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Inline message (error or info — color set in code-behind) -->
                <Border x:Name="MessagePanel"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <TextBlock x:Name="MessageText"
                               FontSize="{StaticResource FontSizeBody}"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Style="{StaticResource DialogButton}"
                            MinWidth="100"
                            Margin="0,0,8,0"
                            Click="CancelButton_Click"/>
                    <Button x:Name="ApplyButton"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="120"
                            IsDefault="True"
                            Click="ApplyButton_Click"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
