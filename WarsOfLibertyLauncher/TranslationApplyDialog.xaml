<Window x:Class="WarsOfLibertyLauncher.TranslationApplyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aplicar traducción"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
            <Setter Property="Height" Value="6"/>
        </Style>

        <!-- Title-bar close ✕ — neutral, reddens on hover. Built on the
             global implicit Button (transparent + overlay-hover template). -->
        <Style x:Key="DialogCloseX" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Content" Value="✕"/>
            <Setter Property="ToolTip" Value="Close"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Rounded dark surface (the Window itself is transparent so the
         corners clip cleanly — same chrome recipe as CreateLobbyDialog). -->
    <Border CornerRadius="8"
            Background="{DynamicResource BgBase}"
            BorderBrush="{DynamicResource BorderSubtle}"
            BorderThickness="1">
        <StackPanel>
            <!-- Custom title bar: drag anywhere on the strip + close ✕. -->
            <Grid Margin="20,12,10,0" MouseLeftButtonDown="HeaderDrag_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TitleBarText"
                           Grid.Column="0"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="{StaticResource FontSizeBody}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button x:Name="CloseXButton"
                        Grid.Column="1"
                        Style="{StaticResource DialogCloseX}"
                        Click="CancelButton_Click"/>
            </Grid>

            <StackPanel Margin="24,8,24,24">
                <!-- Header: language monogram chip + name + version -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Border Width="46" Height="46"
                            CornerRadius="8"
                            Background="{DynamicResource BgPanelAlt}"
                            BorderBrush="{DynamicResource BorderAccentBadge}"
                            BorderThickness="1"
                            Margin="0,0,14,0"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="FlagText"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="{DynamicResource DisplayFont}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="NameText"
                                   FontSize="{StaticResource FontSizeHeading}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="AuthorText"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Compatibility badge (color-coded in code-behind) -->
                <Border x:Name="CompatBadge"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,12,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="CompatIcon"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock x:Name="CompatText"
                                   FontSize="{StaticResource FontSizeBody}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="430"/>
                    </StackPanel>
                </Border>

                <!-- Metadata grid: compatible mod versions + size -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               x:Name="LblModVersions"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Margin="0,0,12,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               x:Name="ModVersionsText"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="{StaticResource FontSizeBody}"
                               FontFamily="Consolas"
                               Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               x:Name="LblSize"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Margin="0,0,12,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               x:Name="SizeText"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="{StaticResource FontSizeBody}"/>
                </Grid>

                <!-- Optional description -->
                <TextBlock x:Name="DescriptionText"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondary}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Visibility="Collapsed"/>

                <!-- Download progress block (visible only during download) -->
                <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,12">
                    <Grid Margin="0,0,0,4">
                        <TextBlock x:Name="ProgressLabelText"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="{StaticResource FontSizeCaption}"/>
                        <TextBlock x:Name="ProgressPercentText"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="{StaticResource FontSizeCaption}"/>
                    </Grid>
                    <ProgressBar x:Name="DownloadProgress"/>
                    <TextBlock x:Name="ProgressBytesText"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Inline message (error or info — color set in code-behind) -->
                <Border x:Name="MessagePanel"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <TextBlock x:Name="MessageText"
                               FontSize="{StaticResource FontSizeBody}"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Style="{StaticResource DialogButton}"
                            MinWidth="100"
                            Margin="0,0,8,0"
                            Click="CancelButton_Click"/>
                    <Button x:Name="ApplyButton"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="120"
                            IsDefault="True"
                            Click="ApplyButton_Click"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
