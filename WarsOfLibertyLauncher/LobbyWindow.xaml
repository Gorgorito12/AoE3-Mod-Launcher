<Window x:Class="WarsOfLibertyLauncher.LobbyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Lobby"
        Height="520" Width="820"
        MinHeight="420" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">

    <!--
        Non-modal lobby window. Replaces the in-tab Canvas overlay that
        used to live inside MultiplayerTab (`RoomPanel` Grid + Canvas +
        floating-card Border). Same content; the chrome is now real OS
        chrome instead of a hand-rolled floating card, which means:

          • Native edge-drag resize from any side/corner (no custom
            Thumb grip — the resize thumb that was added in a previous
            iteration is gone).
          • Native title-bar drag from anywhere in the CaptionHeight=40
            strip at the top (no MouseLeftButtonDown handlers on the
            sub-header strip).
          • The window can be moved outside the launcher's bounds,
            alt-tabbed to, and minimised independently of the main
            launcher window — which was the whole point of this
            refactor versus the in-tab popup.

        Single-instance + non-modal contract (same as LauncherSettings
        and ModProperties — see the bullet in CLAUDE.md under Runtime
        conventions): opened via .Show() from MultiplayerTab, tracked
        in a single-instance field there; the window's Closed event
        triggers the leave-room flow on the session.

        Chrome:
          • WindowStyle=None + WindowChrome — dark dorado-imperial
            title bar, no Windows-native white caption
          • Single ✕ close button top-right (DialogCloseButton recipe,
            replicated locally because that style is per-Window scoped)
          • Caption=40 px, ResizeBorderThickness=6 px so edge resize
            still works even though WindowStyle=None hides the OS
            chrome

        Layout (inside the content row below the title bar):
          • RoomHeaderStrip — rich sub-header: crossed-swords icon
            square + room code + status meta + HOST/PLAYERS/ROOM ID
            stats. Used to double as a drag handle in the in-tab
            popup; now passive (Window chrome handles drag). The
            close ✕ that lived here is gone — the title bar's own
            close is the single dismiss path.
          • Body — 2-column grid: left = players list + room/network
            info card + Ready/Start/Leave actions; right = chat panel
            with header, scrollable log, and input bar.
          • CountdownOverlay + InGameOverlay — full-Grid covers shown
            during Starting / InGame match phases, hiding the lobby
            body underneath.
    -->

    <!-- CaptionHeight 40 → 30: matches the new compact title-bar Padding
         below so the drag area covers the whole visible chrome row but
         nothing below. Previously the caption claimed 40 px and the
         visible bar was ~52 px (10 + 32 button + 10) → wasted vertical
         space at the top of the window. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
                      ResizeBorderThickness="6"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Minimize / Maximize / Restore button recipe. Inline template
             instead of a shared style because none of the existing
             shared button styles target chrome glyphs. Same dimensions
             as DialogCloseButton (below) so all three sit on the same
             horizontal axis in the title bar. Neutral white-alpha hover
             tile because reserving the red "danger" hover for the close
             ✕ is what tells the user which button is destructive at a
             glance — Windows itself uses the same convention. -->
        <Style x:Key="TitleBarChromeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Secondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- #22ffffff = white at ~13% alpha;
                                     just a soft tile to show the hit
                                     zone without painting a hard
                                     button on every hover. -->
                                <Setter TargetName="border" Property="Background" Value="#22ffffff"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Title-bar close ✕. Inline template instead of {StaticResource
             DialogCloseButton} because that style is local to the
             ModPropertiesDialog Window scope (same rationale as the
             duplicated copy in LauncherSettingsDialog).
             Height shrunk 32 → 26 to match the compact title-bar
             padding — keeps the X centred in the chrome row without
             towering above the title text. -->
        <Style x:Key="DialogCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Secondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerAlert}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title bar (chrome) -->
            <RowDefinition Height="*"/>      <!-- Lobby content -->
        </Grid.RowDefinitions>

        <!-- =========================================================
             TITLE BAR — compact, dark, just title + close. Acts as
             the Window's drag area via WindowChrome.CaptionHeight=30.
             The rich room info (host/players/room id stats) lives
             below in RoomHeaderStrip — keeps the title bar honest as
             "this is a window" without duplicating data.
             Padding shrunk 22,10,8,10 → 22,4,8,4 (~12 px less tall)
             so the chrome row sits closer to a typical OS title-bar
             height instead of looking like a fat banner.
             ========================================================= -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgSidebar}"
                BorderBrush="{DynamicResource BorderSecondary}"
                BorderThickness="0,0,0,1"
                Padding="22,4,8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="TitleText"
                           Text="Lobby"
                           FontFamily="{DynamicResource DisplayFont}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"/>
                <!-- Chrome buttons: minimise / maximise-restore / close.
                     Order matches Windows convention (left→right). All
                     three carry IsHitTestVisibleInChrome=True so clicks
                     get routed to the Button instead of starting a
                     window drag on the CaptionHeight=30 strip behind
                     them. The maximise glyph swaps to "restore" via
                     OnStateChanged in code-behind when the window is
                     already maximised. -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="MinimizeBtn"
                            Style="{StaticResource TitleBarChromeButton}"
                            Content="&#xE921;"
                            ToolTip="Minimize"
                            Click="MinimizeBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="MaximizeBtn"
                            Style="{StaticResource TitleBarChromeButton}"
                            Content="&#xE922;"
                            ToolTip="Maximize"
                            Click="MaximizeBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="CloseHeaderBtn"
                            Style="{StaticResource DialogCloseButton}"
                            Content="&#xE8BB;"
                            ToolTip="Close"
                            Click="CloseHeaderBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- =========================================================
             LOBBY CONTENT — one Grid hosts the lobby body + the two
             match-phase overlays. Overlays sit on top by z-order
             (later children render later); their Visibility is
             flipped from ApplyMatchPhaseUi() in code-behind.
             ========================================================= -->
        <Grid Grid.Row="1">

            <!-- =====================================================
                 LOBBY BODY — sub-header strip + 2-column body.
                 ===================================================== -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Sub-header (rich) -->
                    <RowDefinition Height="*"/>      <!-- Body (Players | Chat) -->
                </Grid.RowDefinitions>

                <!-- ========== Sub-header strip ==========
                     Was the popup's drag handle in the old in-tab
                     popup. Now passive (Window chrome at the very
                     top handles drag) — keep it as a rich
                     description strip with icon + room code +
                     status + HOST/PLAYERS/ROOM ID stats. The close
                     ✕ that used to sit on the right is gone — the
                     title bar's ✕ is the single dismiss path. -->
                <Border Grid.Row="0"
                        x:Name="RoomHeaderStrip"
                        Background="{DynamicResource MpSurface}"
                        BorderBrush="{DynamicResource MpDivider}"
                        BorderThickness="0,0,0,1"
                        Margin="14,14,14,0"
                        CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>   <!-- Blue icon square -->
                            <ColumnDefinition Width="Auto"/>   <!-- Title + status -->
                            <ColumnDefinition Width="*"/>      <!-- Stats blocks -->
                        </Grid.ColumnDefinitions>

                        <!-- Crossed-swords icon square. -->
                        <Border Grid.Column="0"
                                Width="64"
                                Background="{DynamicResource MpBlueSubtle}"
                                BorderBrush="{DynamicResource MpDivider}"
                                BorderThickness="0,0,1,0"
                                CornerRadius="6,0,0,6">
                            <TextBlock Text="⚔"
                                       Foreground="{DynamicResource MpBlue}"
                                       FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Title + status line. -->
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="18,16,24,16">
                            <TextBlock x:Name="RoomTitleText"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       TextTrimming="CharacterEllipsis"/>
                            <!-- RoomMetaText kept for compatibility
                                 with the existing RenderRoomPanel
                                 — renders "In lobby · P2P LAN ready"
                                 with subtle colouring. -->
                            <TextBlock x:Name="RoomMetaText"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       Margin="0,4,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- Stat blocks: HOST / PLAYERS / ROOM ID. -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,24,0">
                            <StackPanel Margin="0,0,40,0">
                                <TextBlock Text="HOST"
                                           Foreground="{DynamicResource MpTableHeader}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="RoomHostText"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,40,0">
                                <TextBlock Text="PLAYERS"
                                           Foreground="{DynamicResource MpTableHeader}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="RoomPlayersText"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="ROOM ID"
                                           Foreground="{DynamicResource MpTableHeader}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="RoomIdText"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           FontFamily="Consolas, Courier New, monospace"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ========== Body: Left (players + info + actions) | Right (chat) ========== -->
                <Grid Grid.Row="1" Margin="24,16,24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340"/>
                        <ColumnDefinition Width="16"/>     <!-- gutter -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ===== Left column ===== -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- PLAYERS header -->
                            <RowDefinition Height="*"/>      <!-- members list -->
                            <RowDefinition Height="Auto"/>   <!-- info card -->
                            <RowDefinition Height="Auto"/>   <!-- actions -->
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="PLAYERS"
                                   Foreground="{DynamicResource MpTableHeader}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Margin="2,0,0,10"/>

                        <Border Grid.Row="1"
                                Background="{DynamicResource MpSurface}"
                                BorderBrush="{DynamicResource MpDivider}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,0,0,14">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="RoomMembersPanel"/>
                            </ScrollViewer>
                        </Border>

                        <!-- Room & Network info card. Built by
                             RenderRoomPanel() from session state. -->
                        <Border Grid.Row="2"
                                Background="{DynamicResource MpSurface}"
                                BorderBrush="{DynamicResource MpDivider}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14,12"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,10">
                                    <TextBlock Text="📡 "
                                               Foreground="{DynamicResource MpBlue}"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="ROOM &amp; NETWORK INFO"
                                               Foreground="{DynamicResource MpTableHeader}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                        <TextBlock Text="Connection"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="10"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock x:Name="RoomConnectionText"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                                        <TextBlock Text="Mod"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="10"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock x:Name="RoomModText"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                        <TextBlock Text="Max players"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="10"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock x:Name="RoomMaxPlayersText"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="Password"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="10"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock x:Name="RoomPasswordText"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Stacked actions. Ready = positive
                             (green-outline), Start = primary blue
                             + bigger weight, Leave = dark red. -->
                        <StackPanel Grid.Row="3">
                            <Button x:Name="ReadyButton"
                                    Click="ReadyButton_Click"
                                    Style="{StaticResource MpReadyButton}"
                                    Margin="0,0,0,8"/>
                            <Button x:Name="StartButton"
                                    Click="StartButton_Click"
                                    Style="{StaticResource MpPrimaryButton}"
                                    Padding="14,12"
                                    HorizontalContentAlignment="Center"
                                    FontSize="13"
                                    Margin="0,0,0,8"
                                    Visibility="Collapsed"/>
                            <Button x:Name="LeaveRoomButton"
                                    Click="LeaveRoomButton_Click"
                                    Style="{StaticResource MpDangerButton}"
                                    Padding="14,12"
                                    HorizontalContentAlignment="Center"
                                    FontSize="13"/>
                        </StackPanel>
                    </Grid>

                    <!-- ===== Right column: Chat & Activity ===== -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource MpSurface}"
                            BorderBrush="{DynamicResource MpDivider}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- header -->
                                <RowDefinition Height="*"/>      <!-- chat log -->
                                <RowDefinition Height="Auto"/>   <!-- input -->
                            </Grid.RowDefinitions>

                            <!-- Header: title left, Clear chat right. -->
                            <Border Grid.Row="0"
                                    BorderBrush="{DynamicResource MpDivider}"
                                    BorderThickness="0,0,0,1"
                                    Padding="20,14,14,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="CHAT &amp; ACTIVITY"
                                               Foreground="{DynamicResource MpTableHeader}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            x:Name="ClearChatButton"
                                            Click="ClearChatButton_Click"
                                            Style="{StaticResource MpQuietButton}"
                                            Content="🗑  Clear chat"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1"
                                          x:Name="ChatScroll"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="20,14,14,8">
                                <StackPanel x:Name="ChatLogPanel"/>
                            </ScrollViewer>

                            <!-- Input bar. Emoji icon (decorative
                                 placeholder for now, future emoji
                                 picker) + textbox + Send. -->
                            <Border Grid.Row="2"
                                    BorderBrush="{DynamicResource MpDivider}"
                                    BorderThickness="0,1,0,0"
                                    Padding="14,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <TextBox x:Name="ChatInputBox"
                                                 Background="{DynamicResource MpSurfaceAlt}"
                                                 Foreground="White"
                                                 CaretBrush="White"
                                                 BorderBrush="{DynamicResource MpDivider}"
                                                 BorderThickness="1"
                                                 Padding="12,9"
                                                 FontSize="12"
                                                 MaxLength="500"
                                                 KeyDown="ChatInputBox_KeyDown"
                                                 TextChanged="ChatInputBox_TextChanged"/>
                                        <TextBlock x:Name="ChatPlaceholderText"
                                                   Text="Type a message..."
                                                   Foreground="#777"
                                                   FontSize="12"
                                                   FontStyle="Italic"
                                                   IsHitTestVisible="False"
                                                   VerticalAlignment="Center"
                                                   Margin="14,0,0,0"/>
                                    </Grid>

                                    <Button Grid.Column="1"
                                            x:Name="ChatEmojiButton"
                                            Click="ChatEmojiButton_Click"
                                            Style="{StaticResource MpIconButton}"
                                            Width="36" Height="36"
                                            Margin="6,0,0,0"
                                            Content="😊"
                                            FontSize="14"
                                            ToolTip="Insert emoji"/>

                                    <Button Grid.Column="2"
                                            x:Name="ChatSendButton"
                                            Click="ChatSendButton_Click"
                                            Style="{StaticResource MpPrimaryButton}"
                                            MinWidth="86"
                                            Padding="16,8"
                                            Margin="8,0,0,0"
                                            Content="Send"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- =====================================================
                 COUNTDOWN OVERLAY — shown over the lobby body during
                 the 3-s "Starting…" window before AoE3 launches.
                 Hidden by default; toggled by StartCountdown() in
                 code-behind.
                 ===================================================== -->
            <Border x:Name="CountdownOverlay"
                    Background="#E61a1d24"
                    Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="CountdownLabel"
                               Text="Starting in"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="CountdownNumber"
                               Text="3"
                               Foreground="{DynamicResource MpBlue}"
                               FontSize="96"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CountdownHint"
                               Text="AoE3 will open automatically — keep the launcher running."
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- =====================================================
                 IN-GAME P2P STATUS OVERLAY — replaces the lobby body
                 while the match is running. Pulsing "live" dot, a
                 match timer, per-peer connection quality + RTT +
                 bytes transferred, and a single big "Cancel game" /
                 "Leave game" button. Code-behind refreshes it every
                 ~1 s.
                 ===================================================== -->
            <Border x:Name="InGameOverlay"
                    Background="{DynamicResource BgBase}"
                    Visibility="Collapsed">
                <Grid Margin="32,28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>     <!-- live header -->
                        <RowDefinition Height="Auto"/>     <!-- match meta line -->
                        <RowDefinition Height="*"/>        <!-- peers list -->
                        <RowDefinition Height="Auto"/>     <!-- action -->
                    </Grid.RowDefinitions>

                    <!-- Pulsing dot + headline. -->
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse x:Name="InGameLiveDot"
                                 Width="14" Height="14"
                                 Fill="{DynamicResource MpStatusOnline}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,12,0"/>
                        <TextBlock Text="GAME IN PROGRESS"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="InGameModeText"
                                   Text=" — Connected via P2P LAN"
                                   Foreground="{DynamicResource MpStatusOnline}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"/>
                    </StackPanel>

                    <!-- Match timer + total traffic counter. -->
                    <Grid Grid.Row="1" Margin="0,16,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="MATCH TIME"
                                       Foreground="{DynamicResource MpTableHeader}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="InGameMatchTimer"
                                       Text="00:00"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="20"
                                       FontFamily="Consolas, Courier New, monospace"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TRAFFIC"
                                       Foreground="{DynamicResource MpTableHeader}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="InGameTrafficText"
                                       Text="0 KB"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="20"
                                       FontFamily="Consolas, Courier New, monospace"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ROOM"
                                       Foreground="{DynamicResource MpTableHeader}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="InGameRoomText"
                                       Text=""
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>

                    <!-- Per-peer connection rows. -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource MpSurface}"
                            BorderBrush="{DynamicResource MpDivider}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="InGamePeersPanel"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Cancel / Leave action. Caption + colour
                         change is driven from code-behind depending
                         on whether the current user is the host. -->
                    <Button Grid.Row="3"
                            x:Name="InGameCancelButton"
                            Click="InGameCancelButton_Click"
                            Style="{StaticResource MpDangerButton}"
                            Padding="18,12"
                            Margin="0,18,0,0"
                            HorizontalContentAlignment="Center"
                            FontSize="13"
                            Content="⚠  Cancel game"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
