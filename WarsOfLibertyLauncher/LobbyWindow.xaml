<Window x:Class="WarsOfLibertyLauncher.LobbyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:WarsOfLibertyLauncher.Controls"
        Title="Lobby"
        Height="660" Width="920"
        MinHeight="420" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="True">

    <!--
        Non-modal lobby window. Replaces the in-tab Canvas overlay that
        used to live inside MultiplayerTab (`RoomPanel` Grid + Canvas +
        floating-card Border). Same content; the chrome is now real OS
        chrome instead of a hand-rolled floating card, which means:

          • Native edge-drag resize from any side/corner (no custom
            Thumb grip — the resize thumb that was added in a previous
            iteration is gone).
          • Native title-bar drag from anywhere in the CaptionHeight=40
            strip at the top (no MouseLeftButtonDown handlers on the
            sub-header strip).
          • The window can be moved outside the launcher's bounds,
            alt-tabbed to, and minimised independently of the main
            launcher window — which was the whole point of this
            refactor versus the in-tab popup.

        Single-instance + non-modal contract (same as LauncherSettings
        and ModProperties — see the bullet in CLAUDE.md under Runtime
        conventions): opened via .Show() from MultiplayerTab, tracked
        in a single-instance field there; the window's Closed event
        triggers the leave-room flow on the session.

        Chrome:
          • WindowStyle=None + WindowChrome — dark dorado-imperial
            title bar, no Windows-native white caption
          • Single ✕ close button top-right (DialogCloseButton recipe,
            replicated locally because that style is per-Window scoped)
          • Caption=40 px, ResizeBorderThickness=6 px so edge resize
            still works even though WindowStyle=None hides the OS
            chrome

        Layout (inside the content row below the title bar):
          • RoomHeaderStrip — rich sub-header: crossed-swords icon
            square + room code + status meta + HOST/PLAYERS/ROOM ID
            stats. Used to double as a drag handle in the in-tab
            popup; now passive (Window chrome handles drag). The
            close ✕ that lived here is gone — the title bar's own
            close is the single dismiss path.
          • Body — 2-column grid: left = players list + room/network
            info card + Ready/Start/Leave actions; right = chat panel
            with header, scrollable log, and input bar.
          • CountdownOverlay — despite the name, a THIN BAR that is its
            own layout row above the body (not an overlay), shown during
            the Starting phase. It pushes the body down so the players
            list AND the chat both stay visible/interactive — players can
            ask to abort and the host can Cancel from the bar. InGameOverlay
            — full-content cover during the InGame phase (AoE3 is foreground
            then). See the inline comments.
    -->

    <!-- WindowChrome (caption drag + edge-resize) is applied centrally in
         App.OnAnyWindowLoaded from the TitleBarHeight token; the title bar is
         the shared controls:TitleBar below. -->

    <!-- 1 px frame so the dark window reads as a distinct panel instead of
         melting into the (equally dark) launcher behind it. A literal black
         line can't separate two dark surfaces; this uses the app's standard
         border tone. AllowsTransparency=False rules out a drop shadow, so a
         hard edge is the tool available. -->
    <Border
            BorderBrush="{DynamicResource BorderSecondary}"
            BorderThickness="1"
            Background="{DynamicResource BgBase}">
    <!-- x:Name="LobbyRootGrid" — host for MpAlertOverlay confirm cards
         (the in-lobby themed replacement for MessageBox). The overlay is
         injected as the last child BEFORE the MinimizedPill so the pill,
         when shown, still covers everything; in practice the two never
         overlap (you can't pill while a confirm is up). -->
    <Grid x:Name="LobbyRootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title bar (chrome) -->
            <RowDefinition Height="*"/>      <!-- Lobby content -->
        </Grid.RowDefinitions>

        <!-- =========================================================
             TITLE BAR — shared global bar. min/max/restore/close (this
             is an independent, resizable, taskbar window). The rich room
             info (host/players/room id stats) lives below in
             RoomHeaderStrip — the title bar stays honest as "a window"
             without duplicating data. Drag/double-click/restore-on-drag
             come from the central WindowChrome.
             ========================================================= -->
        <controls:TitleBar Grid.Row="0"
                           x:Name="TitleBarControl"
                           Title="Lobby"
                           ShowMinimize="True"
                           ShowMaximize="True"
                           ShowClose="True"/>

        <!-- =========================================================
             LOBBY CONTENT — one Grid hosts the lobby body + the two
             match-phase overlays. Overlays sit on top by z-order
             (later children render later); their Visibility is
             flipped from ApplyMatchPhaseUi() in code-behind.
             ========================================================= -->
        <Grid Grid.Row="1" x:Name="LobbyContentRoot">

            <!-- =====================================================
                 LOBBY BODY — sub-header strip + 2-column body.
                 ===================================================== -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Sub-header (rich) -->
                    <RowDefinition Height="*"/>      <!-- Body (Players | Chat) -->
                </Grid.RowDefinitions>

                <!-- ========== Sub-header strip ==========
                     Was the popup's drag handle in the old in-tab
                     popup. Now passive (Window chrome at the very
                     top handles drag) — keep it as a rich
                     description strip with icon + room code +
                     status + HOST/PLAYERS/ROOM ID stats. The close
                     ✕ that used to sit on the right is gone — the
                     title bar's ✕ is the single dismiss path. -->
                <Border Grid.Row="0"
                        x:Name="RoomHeaderStrip"
                        Background="{DynamicResource MpSurface}"
                        BorderBrush="{DynamicResource MpDivider}"
                        BorderThickness="0,0,0,1"
                        Margin="14,14,14,0"
                        CornerRadius="{StaticResource RadiusMd}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>   <!-- Blue icon square -->
                            <ColumnDefinition Width="Auto"/>   <!-- Title + status -->
                            <ColumnDefinition Width="*"/>      <!-- Stats blocks -->
                        </Grid.ColumnDefinitions>

                        <!-- Crossed-swords icon square. -->
                        <Border Grid.Column="0"
                                Width="64"
                                Background="{DynamicResource MpBlueSubtle}"
                                BorderBrush="{DynamicResource MpDivider}"
                                BorderThickness="0,0,1,0"
                                CornerRadius="6,0,0,6">
                            <TextBlock Text="⚔"
                                       Foreground="{DynamicResource MpBlue}"
                                       FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Title + status line. -->
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="18,16,24,16">
                            <!-- Title + host-only rename button. The name must
                                 stay in a bounded '*' column so it ellipsises
                                 instead of pushing the button off-screen; the
                                 ✏ mirrors the 📋 beside ROOM ID below, and is
                                 shown only for the host (RenderRoomPanel). -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="RoomTitleText"
                                           Grid.Column="0"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="{StaticResource FontSizeHeading}"
                                           FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis"/>
                                <Button x:Name="RenameRoomButton"
                                        Grid.Column="1"
                                        Click="RenameRoomButton_Click"
                                        Style="{StaticResource MpIconButton}"
                                        Width="26" Height="22"
                                        Padding="0"
                                        Margin="8,0,0,0"
                                        FontSize="{StaticResource FontSizeBody}"
                                        Content="✏"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed"/>
                            </Grid>
                            <!-- RoomMetaText kept for compatibility
                                 with the existing RenderRoomPanel
                                 — renders "In lobby · P2P LAN ready"
                                 with subtle colouring. -->
                            <TextBlock x:Name="RoomMetaText"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Margin="0,4,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- Stat blocks: PLAYERS / ROOM ID. The HOST stat
                             that used to sit here was dropped — the roster
                             below already marks the host with a badge, so a
                             separate stat just repeated it. ROOM ID carries
                             a copy-to-clipboard button so the code is easy
                             to share without retyping. -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,24,0">
                            <StackPanel Margin="0,0,40,0">
                                <TextBlock x:Name="PlayersStatHeader"
                                           Text="PLAYERS"
                                           Foreground="{DynamicResource MpTableHeader}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="RoomPlayersText"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="{StaticResource FontSizeBodyStrong}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <!-- Connection latency = your internet RTT. Not a
                                 per-rival ping — per-player ping needs peer IPs
                                 the launcher can't see (see CLAUDE.md). -->
                            <StackPanel Margin="0,0,40,0">
                                <TextBlock x:Name="RoomConnHeader"
                                           Text="CONNECTION"
                                           Foreground="{DynamicResource MpTableHeader}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="RoomConnText"
                                           Text="…"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="{StaticResource FontSizeBodyStrong}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock x:Name="RoomIdStatHeader"
                                           Text="ROOM ID"
                                           Foreground="{DynamicResource MpTableHeader}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="RoomIdText"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="{StaticResource FontSizeBodyStrong}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               FontFamily="Consolas, Courier New, monospace"/>
                                    <Button x:Name="CopyRoomIdButton"
                                            Click="CopyRoomIdButton_Click"
                                            Style="{StaticResource MpIconButton}"
                                            Width="26" Height="22"
                                            Padding="0"
                                            Margin="8,0,0,0"
                                            FontSize="{StaticResource FontSizeBody}"
                                            Content="📋"
                                            VerticalAlignment="Center"
                                            ToolTip="Copy code"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ========== Body: Left (players + info + actions) | Right (chat) ========== -->
                <Grid Grid.Row="1" Margin="24,16,24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340"/>
                        <ColumnDefinition Width="16"/>     <!-- gutter -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ===== Left column ===== -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- PLAYERS header -->
                            <RowDefinition Height="*"/>      <!-- members list -->
                            <RowDefinition Height="Auto"/>   <!-- info card -->
                            <RowDefinition Height="Auto"/>   <!-- actions -->
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   x:Name="PlayersListHeader"
                                   Text="PLAYERS"
                                   Foreground="{DynamicResource MpTableHeader}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   FontWeight="SemiBold"
                                   Margin="2,0,0,10"/>

                        <Border Grid.Row="1"
                                Background="{DynamicResource MpSurface}"
                                BorderBrush="{DynamicResource MpDivider}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusMd}"
                                Padding="10,8"
                                Margin="0,0,0,14">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="RoomMembersPanel"/>
                            </ScrollViewer>
                        </Border>

                        <!-- Room info card. Built by RenderRoomPanel() from
                             session state. Trimmed to Mod + Password: the old
                             "Connection" cell duplicated the P2P status already
                             shown in the header meta line, and "Max players"
                             duplicated the PLAYERS stat. The whole card is
                             collapsed when neither field has data. -->
                        <Border Grid.Row="2"
                                x:Name="RoomInfoCard"
                                Background="{DynamicResource MpSurface}"
                                BorderBrush="{DynamicResource MpDivider}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusMd}"
                                Padding="{StaticResource CardPadding}"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,10">
                                    <TextBlock Text="ℹ "
                                               Foreground="{DynamicResource MpBlue}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="RoomInfoHeaderText"
                                               Text="ROOM INFO"
                                               Foreground="{DynamicResource MpTableHeader}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock x:Name="RoomModLabel"
                                                   Text="Mod"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock x:Name="RoomModText"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock x:Name="RoomPasswordLabel"
                                                   Text="Password"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock x:Name="RoomPasswordText"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                                <!-- Which install copy this room uses. Shown only
                                     when the room's mod has 2+ installed copies. -->
                                <StackPanel x:Name="RoomCopyRow"
                                            Margin="0,10,0,0"
                                            Visibility="Collapsed">
                                    <TextBlock x:Name="RoomCopyLabel"
                                               Text="Copy"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Margin="0,0,0,2"/>
                                    <TextBlock x:Name="RoomCopyText"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Stacked actions. Ready = positive
                             (green-outline), Start = primary blue
                             + bigger weight, Leave = dark red. -->
                        <StackPanel Grid.Row="3">
                            <Button x:Name="ReadyButton"
                                    Click="ReadyButton_Click"
                                    Style="{StaticResource MpReadyButton}"
                                    Margin="0,0,0,8"/>
                            <Button x:Name="StartButton"
                                    Click="StartButton_Click"
                                    Style="{StaticResource MpPrimaryButton}"
                                    Padding="14,12"
                                    HorizontalContentAlignment="Center"
                                    FontSize="{StaticResource FontSizeBody}"
                                    Margin="0,0,0,8"
                                    Visibility="Collapsed"/>
                            <Button x:Name="LeaveRoomButton"
                                    Click="LeaveRoomButton_Click"
                                    Style="{StaticResource MpDangerButton}"
                                    Padding="14,12"
                                    HorizontalContentAlignment="Center"
                                    FontSize="{StaticResource FontSizeBody}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ===== Right column: Chat & Activity ===== -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource MpSurface}"
                            BorderBrush="{DynamicResource MpDivider}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusMd}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- header -->
                                <RowDefinition Height="*"/>      <!-- chat log -->
                                <RowDefinition Height="Auto"/>   <!-- countdown line (0 px when collapsed) -->
                                <RowDefinition Height="Auto"/>   <!-- input -->
                            </Grid.RowDefinitions>

                            <!-- Header: title left, Clear chat right. -->
                            <Border Grid.Row="0"
                                    BorderBrush="{DynamicResource MpDivider}"
                                    BorderThickness="0,0,0,1"
                                    Padding="20,14,14,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               x:Name="ChatHeaderText"
                                               Text="CHAT &amp; ACTIVITY"
                                               Foreground="{DynamicResource MpTableHeader}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            x:Name="ClearChatButton"
                                            Click="ClearChatButton_Click"
                                            Style="{StaticResource MpQuietButton}"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1"
                                          x:Name="ChatScroll"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="20,14,14,8">
                                <StackPanel x:Name="ChatLogPanel"/>
                            </ScrollViewer>

                            <!-- Empty-state hint, centred over the (empty)
                                 chat log. Toggled from UpdateChatEmptyState()
                                 in code-behind whenever rows are added/cleared. -->
                            <TextBlock Grid.Row="1"
                                       x:Name="ChatEmptyHint"
                                       Text="No messages yet — say hi!"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       FontStyle="Italic"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed"/>

                            <!-- ===== Countdown line (lives INSIDE the chat) =====
                                 The pre-launch countdown shows here as a single
                                 live line in the chat panel — it used to be a
                                 thin glowing bar above the whole body. Collapsed
                                 → 0 px (Row is Auto); StartCountdown flips it
                                 Visible via ApplyMatchPhaseUi and
                                 UpdateCountdownTick rewrites CountdownNumber in
                                 place (5→4→3…). x:Name stays "CountdownOverlay"
                                 (despite no longer being an overlay) so the
                                 code-behind visibility toggle + CountdownLabel /
                                 CountdownNumber wiring need no change. The chat
                                 stays fully usable during the countdown so
                                 players can still ask to abort. -->
                            <Border Grid.Row="2"
                                    x:Name="CountdownOverlay"
                                    Background="{DynamicResource MpBlueSubtle}"
                                    BorderBrush="{DynamicResource MpBlue}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusMd}"
                                    Margin="20,0,14,10"
                                    Padding="14,9"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="⏱"
                                               Foreground="{DynamicResource MpBlue}"
                                               FontSize="{StaticResource FontSizeSubtitle}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBlock x:Name="CountdownLabel"
                                               Text="Starting in"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <!-- Default "5" (not "3") so even the
                                         first paint before UpdateCountdownTick
                                         runs shows the right starting number. -->
                                    <TextBlock x:Name="CountdownNumber"
                                               Text="10"
                                               Foreground="{DynamicResource MpBlue}"
                                               FontSize="{StaticResource FontSizeHeading}"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Input bar. Emoji icon (decorative
                                 placeholder for now, future emoji
                                 picker) + textbox + Send. -->
                            <Border Grid.Row="3"
                                    BorderBrush="{DynamicResource MpDivider}"
                                    BorderThickness="0,1,0,0"
                                    Padding="14,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <TextBox x:Name="ChatInputBox"
                                                 Background="{DynamicResource MpSurfaceAlt}"
                                                 Foreground="White"
                                                 CaretBrush="White"
                                                 BorderBrush="{DynamicResource MpDivider}"
                                                 BorderThickness="1"
                                                 Padding="12,9"
                                                 FontSize="{StaticResource FontSizeBody}"
                                                 MaxLength="500"
                                                 KeyDown="ChatInputBox_KeyDown"
                                                 TextChanged="ChatInputBox_TextChanged"/>
                                        <TextBlock x:Name="ChatPlaceholderText"
                                                   Text="Type a message..."
                                                   Foreground="#777"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   FontStyle="Italic"
                                                   IsHitTestVisible="False"
                                                   VerticalAlignment="Center"
                                                   Margin="14,0,0,0"/>
                                    </Grid>

                                    <Button Grid.Column="1"
                                            x:Name="ChatEmojiButton"
                                            Click="ChatEmojiButton_Click"
                                            Style="{StaticResource MpIconButton}"
                                            Width="36" Height="36"
                                            Margin="6,0,0,0"
                                            Content="😊"
                                            FontSize="{StaticResource FontSizeBodyStrong}"
                                            ToolTip="Insert emoji"/>

                                    <Button Grid.Column="2"
                                            x:Name="ChatSendButton"
                                            Click="ChatSendButton_Click"
                                            Style="{StaticResource MpPrimaryButton}"
                                            MinWidth="86"
                                            Padding="16,8"
                                            Margin="8,0,0,0"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- =====================================================
                         IN-GAME PANEL — shown while the match is running.
                         CONFINED to the LEFT column (Grid.Column="0": it
                         covers the roster + Ready/Start/Leave actions) ON
                         PURPOSE, so the chat panel (Column 2) stays VISIBLE
                         and usable during the game. That's the "chat is
                         always accessible" rule: once AoE3 launches (the
                         countdown hits 0) the room controls are blocked —
                         this opaque panel sits over them — but players can
                         still talk. It used to be a full-content cover that
                         hid the chat too; it was moved INTO the body grid +
                         relaid out vertically (stats in a 2×2 grid instead
                         of a 4-wide row) to fit the 340 px column. Pulsing
                         "live" dot, match timer / traffic / connection /
                         room stats, a peer list, and one big Cancel/Leave
                         button. RefreshInGamePanel() (1 Hz) repaints it; all
                         the InGame* x:Names are preserved so the code-behind
                         needs no change. -->
                    <Border x:Name="InGameOverlay"
                            Grid.Column="0"
                            Background="{DynamicResource BgBase}"
                            BorderBrush="{DynamicResource MpDivider}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusMd}"
                            Visibility="Collapsed">
                        <Grid Margin="16,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- live header -->
                                <RowDefinition Height="Auto"/>   <!-- stats 2×2 -->
                                <RowDefinition Height="*"/>      <!-- peers list -->
                                <RowDefinition Height="Auto"/>   <!-- action -->
                            </Grid.RowDefinitions>

                            <!-- Pulsing dot + headline (stacked so it fits
                                 the narrow column). -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Ellipse x:Name="InGameLiveDot"
                                             Width="12" Height="12"
                                             Fill="{DynamicResource MpStatusOnline}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,10,0"/>
                                    <TextBlock x:Name="InGameTitleText"
                                               Text="GAME IN PROGRESS"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="{StaticResource FontSizeSubtitle}"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="InGameModeText"
                                           Text="— Connected via P2P LAN"
                                           Foreground="{DynamicResource MpStatusOnline}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Match timer / traffic / connection / room,
                                 laid out 2×2 to fit the 340 px column. -->
                            <Grid Grid.Row="1" Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                                    <TextBlock x:Name="InGameMatchTimeHeader"
                                               Text="MATCH TIME"
                                               Foreground="{DynamicResource MpTableHeader}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="InGameMatchTimer"
                                               Text="00:00"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="{StaticResource FontSizeSubtitle}"
                                               FontFamily="Consolas, Courier New, monospace"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                                    <TextBlock x:Name="InGameTrafficHeader"
                                               Text="TRAFFIC"
                                               Foreground="{DynamicResource MpTableHeader}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="InGameTrafficText"
                                               Text="0 KB"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="{StaticResource FontSizeSubtitle}"
                                               FontFamily="Consolas, Courier New, monospace"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                                <!-- Connection latency = YOUR internet RTT (not a
                                     per-rival ping). The per-player ping lives in the
                                     peer rows below (real ICMP RTT to each Radmin IP). -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock x:Name="InGameConnectionHeader"
                                               Text="CONNECTION"
                                               Foreground="{DynamicResource MpTableHeader}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="InGameConnectionText"
                                               Text="—"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="{StaticResource FontSizeSubtitle}"
                                               FontFamily="Consolas, Courier New, monospace"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock x:Name="InGameRoomHeader"
                                               Text="ROOM"
                                               Foreground="{DynamicResource MpTableHeader}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="InGameRoomText"
                                               Text=""
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>

                            <!-- Per-peer connection rows. -->
                            <Border Grid.Row="2"
                                    Background="{DynamicResource MpSurface}"
                                    BorderBrush="{DynamicResource MpDivider}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusMd}"
                                    Padding="12,8">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="InGamePeersPanel"/>
                                </ScrollViewer>
                            </Border>

                            <!-- Cancel / Leave action. Caption + colour
                                 change is driven from code-behind depending
                                 on whether the current user is the host. -->
                            <Button Grid.Row="3"
                                    x:Name="InGameCancelButton"
                                    Click="InGameCancelButton_Click"
                                    Style="{StaticResource MpDangerButton}"
                                    Padding="14,11"
                                    Margin="0,14,0,0"
                                    HorizontalContentAlignment="Center"
                                    FontSize="{StaticResource FontSizeBody}"
                                    Content="⚠  Cancel game"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
    </Border>
</Window>
