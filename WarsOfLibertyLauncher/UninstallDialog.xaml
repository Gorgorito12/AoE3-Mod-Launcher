<Window x:Class="WarsOfLibertyLauncher.UninstallDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uninstall"
        Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#ddd"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">
        <!-- Header -->
        <TextBlock x:Name="HeaderText"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,4"/>
        <TextBlock x:Name="DescriptionText"
                   FontSize="12"
                   Foreground="#aaa"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <!-- Refused panel (red) — shown only when the path doesn't have the WoL marker -->
        <Border x:Name="RefusedPanel"
                Background="#3a1a1a"
                BorderBrush="#8c3a3a"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,8"
                Margin="0,0,0,14"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="RefusedTitleText"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource ErrorBrush}"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="RefusedDetailText"
                           FontSize="12"
                           Foreground="White"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Install summary panel (gray) — shown when the path is valid -->
        <Border x:Name="SummaryPanel"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,10"
                Margin="0,0,0,14"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="LblInstallPath"
                           FontSize="11"
                           Foreground="#888"
                           Margin="0,0,0,2"/>
                <TextBlock x:Name="InstallPathText"
                           FontSize="12"
                           Foreground="White"
                           TextWrapping="Wrap"
                           FontFamily="Consolas"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="SummaryDetailText"
                           FontSize="12"
                           Foreground="#aaa"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Options -->
        <TextBlock x:Name="OptionsTitleText"
                   FontSize="11" FontWeight="SemiBold"
                   Foreground="#888"
                   Margin="0,4,0,4"/>
        <CheckBox x:Name="OptDeleteShortcuts" IsChecked="True"/>
        <CheckBox x:Name="OptRemoveRegistry" IsChecked="True"/>
        <CheckBox x:Name="OptResetConfig" IsChecked="False"/>

        <!-- Reassurance note about AoE3 not being touched -->
        <TextBlock x:Name="AoE3SafeNoteText"
                   FontSize="11"
                   Foreground="#9bd99b"
                   TextWrapping="Wrap"
                   Margin="0,16,0,12"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Style="{StaticResource DialogButton}"
                    MinWidth="100"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button x:Name="OkButton"
                    Style="{StaticResource DangerButton}"
                    MinWidth="140"
                    Click="OkButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
