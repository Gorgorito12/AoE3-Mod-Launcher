<Window x:Class="WarsOfLibertyLauncher.UninstallDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uninstall"
        Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1d24"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Background" Value="#3a3d44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4a4d54"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#2a2d34"/>
                                <Setter Property="Foreground" Value="#666"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#8b0000"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#a71d1d"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3a3d44"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#ddd"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">
        <!-- Header -->
        <TextBlock x:Name="HeaderText"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,4"/>
        <TextBlock x:Name="DescriptionText"
                   FontSize="12"
                   Foreground="#aaa"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <!-- Refused panel (red) — shown only when the path doesn't have the WoL marker -->
        <Border x:Name="RefusedPanel"
                Background="#3a1a1a"
                BorderBrush="#8c3a3a"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,8"
                Margin="0,0,0,14"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="RefusedTitleText"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#e63950"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="RefusedDetailText"
                           FontSize="12"
                           Foreground="White"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Install summary panel (gray) — shown when the path is valid -->
        <Border x:Name="SummaryPanel"
                Background="#22252c"
                BorderBrush="#3a3d44"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,10"
                Margin="0,0,0,14"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="LblInstallPath"
                           FontSize="11"
                           Foreground="#888"
                           Margin="0,0,0,2"/>
                <TextBlock x:Name="InstallPathText"
                           FontSize="12"
                           Foreground="White"
                           TextWrapping="Wrap"
                           FontFamily="Consolas"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="SummaryDetailText"
                           FontSize="12"
                           Foreground="#aaa"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Options -->
        <TextBlock x:Name="OptionsTitleText"
                   FontSize="11" FontWeight="SemiBold"
                   Foreground="#888"
                   Margin="0,4,0,4"/>
        <CheckBox x:Name="OptDeleteShortcuts" IsChecked="True"/>
        <CheckBox x:Name="OptRemoveRegistry" IsChecked="True"/>
        <CheckBox x:Name="OptResetConfig" IsChecked="False"/>

        <!-- Reassurance note about AoE3 not being touched -->
        <TextBlock x:Name="AoE3SafeNoteText"
                   FontSize="11"
                   Foreground="#9bd99b"
                   TextWrapping="Wrap"
                   Margin="0,16,0,12"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Style="{StaticResource DialogButton}"
                    MinWidth="100"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button x:Name="OkButton"
                    Style="{StaticResource DangerButton}"
                    MinWidth="140"
                    Click="OkButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
