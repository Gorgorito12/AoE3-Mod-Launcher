<Window x:Class="WarsOfLibertyLauncher.ModPropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:WarsOfLibertyLauncher.Controls"
        Title="Mod properties"
        Height="640" Width="900"
        MinHeight="540" MinWidth="780"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed">
    <!--
        Steam-style per-mod Properties dialog. Single destination for
        ALL per-mod actions. Layout refactored from cards-in-cards to
        flat full-width sections with thin dividers — matches the way
        Steam's per-game Properties popup uses the whole content area
        instead of padding everything inside nested panels.

        Chrome:
          • WindowStyle=None + WindowChrome — kills the white Windows
            title bar so the header integrates with the dark palette
          • Single ✕ close button top-right (no min/max — modal popup
            shouldn't be minimised; popup is Owner-bound)
          • No footer Close button — the ✕ in the header IS the close

        Tabs:
          GENERAL     — About section + Check for updates
          LOCAL FILES — Install location + Paths grid + Maintenance +
                        Diagnostics + Danger Zone (red divider section)
          USER DATA   — Three rows (Open / Backup / Restore) with the
                        title+description on the left and a button on
                        the right (Steam-style settings row)
          LANGUAGE    — Language combo with description
    -->

    <!-- WindowChrome (caption drag + edge-resize) is applied centrally in
         App.OnAnyWindowLoaded from the TitleBarHeight token; the title bar is
         the shared controls:TitleBar below. -->

    <Window.Resources>
        <!-- ============================================================
             Local styles. Scoped to the dialog so the flat-section
             visual language stays self-contained.
             ============================================================ -->

        <!-- Section header — small uppercase caption above each group.
             Same role the old DialogCardTitle had, just with margin
             tuned for the flat-section layout (no card padding to
             offset). -->
        <Style x:Key="DialogSectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Secondary}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeSubtitle}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <!-- Section divider — a hairline between flat sections. Same
             colour as BorderSubtle but at 60% opacity so it whispers
             rather than slicing the panel into hard bands. -->
        <Style x:Key="DialogDivider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource BorderSubtle}"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Margin" Value="0,18,0,18"/>
        </Style>

        <!-- Field label (Name / Author / Installed / Website caption). -->
        <Style x:Key="DialogFieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Secondary}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Field value -->
        <Style x:Key="DialogFieldValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryFixed}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBodyStrong}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Pill badge for version — used in the header and the GENERAL
             tab Installed row. -->
        <Style x:Key="DialogPillBadge" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource TintAccentBadge}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderAccentBadge}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Action-row title (User Data tab). Larger than the section
             header because each row IS the action, not a sub-section. -->
        <Style x:Key="DialogActionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryFixed}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBodyStrong}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Description text under an action title. -->
        <Style x:Key="DialogActionDesc" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Secondary}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Title-bar close ✕ now lives in the shared controls:TitleBar
             (Styles/Chrome.xaml TitleBarCloseButton) — no per-dialog style. -->
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header (with custom close) -->
            <RowDefinition Height="*"/>      <!-- Tabs + content -->
        </Grid.RowDefinitions>

        <!-- =========================================================
             HEADER — shared global title bar. Mod icon + name come from
             TitleBar.TitleIcon / .Title (set in code-behind); the version
             pill rides in BarContent (right-aligned). Close-only sheet.
             ========================================================= -->
        <controls:TitleBar Grid.Row="0"
                           x:Name="TitleBarControl"
                           ShowMinimize="True"
                           ShowMaximize="True"
                           ShowClose="True">
            <Border x:Name="HeaderVersionBadge"
                    Style="{StaticResource DialogPillBadge}"
                    HorizontalAlignment="Right"
                    Margin="0,0,8,0"
                    Visibility="Collapsed">
                <TextBlock x:Name="HeaderVersionText"
                           Foreground="{DynamicResource AccentBrush}"
                           FontSize="{StaticResource FontSizeCaption}"
                           FontWeight="SemiBold"/>
            </Border>
        </controls:TitleBar>

        <!-- =========================================================
             TABS + CONTENT
             ========================================================= -->
        <Grid Grid.Row="1" x:Name="PropsContentRoot">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"
                                  MinWidth="{StaticResource SidebarRailMinWidth}"
                                  MaxWidth="{StaticResource SidebarRailMaxWidth}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left tab rail with Segoe MDL2 icons. -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BgSidebar}"
                    BorderBrush="{DynamicResource BorderSecondary}"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="0,16,0,0">
                    <Button x:Name="TabGeneralBtn"
                            Style="{StaticResource SidebarNavButton}"
                            Click="TabGeneralBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TabGeneralLabel"
                                       Style="{StaticResource SidebarNavLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="TabLocalFilesBtn"
                            Style="{StaticResource SidebarNavButton}"
                            Click="TabLocalFilesBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TabLocalFilesLabel"
                                       Style="{StaticResource SidebarNavLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="TabUserDataBtn"
                            Style="{StaticResource SidebarNavButton}"
                            Click="TabUserDataBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE77B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TabUserDataLabel"
                                       Style="{StaticResource SidebarNavLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="TabLanguageBtn"
                            Style="{StaticResource SidebarNavButton}"
                            Click="TabLanguageBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE775;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TabLanguageLabel"
                                       Style="{StaticResource SidebarNavLabel}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Right content — flat sections, full width, separated by
                 thin dividers (Steam-style). No card containers, no
                 nested padding — content uses the whole column. -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="32,18,32,18">

                    <!-- ===================================================
                         GENERAL TAB
                         =================================================== -->
                    <StackPanel x:Name="GeneralPanel" Visibility="Visible">
                        <TextBlock x:Name="LblAboutSection"
                                   Style="{StaticResource DialogSectionTitle}"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="LblName"
                                       Style="{StaticResource DialogFieldLabel}"/>
                            <TextBlock Grid.Column="1" x:Name="ValName"
                                       Style="{StaticResource DialogFieldValue}"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="LblAuthor"
                                       Style="{StaticResource DialogFieldLabel}"/>
                            <TextBlock Grid.Column="1" x:Name="ValAuthor"
                                       Style="{StaticResource DialogFieldValue}"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="LblVersion"
                                       Style="{StaticResource DialogFieldLabel}"/>
                            <Border Grid.Column="1"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource DialogPillBadge}">
                                <TextBlock x:Name="ValVersion"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="LblWebsite"
                                       Style="{StaticResource DialogFieldLabel}"
                                       VerticalAlignment="Top"
                                       Margin="0,2,0,0"/>
                            <TextBlock Grid.Column="1" x:Name="ValWebsite"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Cursor="Hand"
                                       MouseLeftButtonUp="ValWebsite_Click"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Button x:Name="CheckUpdatesBtn"
                                Style="{StaticResource PropertyActionButton}"
                                HorizontalAlignment="Left"
                                MinWidth="220"
                                Click="CheckUpdatesBtn_Click"/>
                        <TextBlock x:Name="CheckUpdatesResult"
                                   Margin="0,10,0,0"
                                   FontSize="{StaticResource FontSizeBody}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>

                        <!-- Stay-on-version pin (Fase 0): pauses update prompts for
                             this mod while the installed version is the pinned one.
                             Collapsed until we know an installed version. -->
                        <CheckBox x:Name="StayOnVersionCheck"
                                  Margin="0,14,0,0"
                                  Click="StayOnVersionCheck_Click"
                                  Visibility="Collapsed"/>
                        <TextBlock x:Name="StayOnVersionHint"
                                   Margin="0,4,0,0"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>

                        <!-- Version picker (Fase 1): GitHubReleases mods only.
                             Collapsed for every other mechanism / until the list
                             loads. Lets the user install or roll back to a specific
                             published version instead of only the recommended one. -->
                        <StackPanel x:Name="VersionSection"
                                    Margin="0,22,0,0"
                                    Visibility="Collapsed">
                            <TextBlock x:Name="VersionSectionLabel"
                                       FontSize="{StaticResource FontSizeBodyStrong}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock x:Name="VersionSectionHint"
                                       Margin="0,4,0,0"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <ComboBox x:Name="VersionCombo"
                                          MinWidth="240"
                                          VerticalAlignment="Center"/>
                                <Button x:Name="InstallVersionBtn"
                                        Style="{StaticResource PropertyActionButton}"
                                        Margin="10,0,0,0"
                                        MinWidth="180"
                                        VerticalAlignment="Center"
                                        Click="InstallVersionBtn_Click"/>
                            </StackPanel>
                            <TextBlock x:Name="VersionStatus"
                                       Margin="0,10,0,0"
                                       FontSize="{StaticResource FontSizeBody}"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ===================================================
                         LOCAL FILES TAB — flat sections separated by
                         dividers. Each section uses the whole content
                         column (no card encapsulation). The Danger
                         Zone is just another section, signaled only by
                         a red title + red description + the red
                         Uninstall button at the bottom.
                         =================================================== -->
                    <StackPanel x:Name="LocalFilesPanel" Visibility="Collapsed">

                        <!-- Install location -->
                        <TextBlock x:Name="LblInstallPath"
                                   Style="{StaticResource DialogSectionTitle}"/>
                        <Border Background="{DynamicResource BgBase}"
                                BorderBrush="{DynamicResource BorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="14,10">
                            <TextBlock x:Name="ValInstallPath"
                                       Foreground="{DynamicResource SecondaryFixed}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       FontFamily="Consolas"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Border Style="{StaticResource DialogDivider}"/>

                        <!-- Temp / cache cleanup -->
                        <TextBlock x:Name="LblTempSection"
                                   Style="{StaticResource DialogSectionTitle}"/>
                        <TextBlock x:Name="LblTempDesc"
                                   Style="{StaticResource DialogActionDesc}"
                                   Margin="0,0,0,10"/>
                        <Button x:Name="ClearTempBtn"
                                Style="{StaticResource PropertyActionButton}"
                                HorizontalAlignment="Left"
                                Click="ClearTempBtn_Click"/>
                        <TextBlock x:Name="ClearTempResult"
                                   Margin="0,10,0,0"
                                   FontSize="{StaticResource FontSizeBody}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>

                        <Border Style="{StaticResource DialogDivider}"/>

                        <!-- Paths -->
                        <TextBlock x:Name="LblPathsSection"
                                   Style="{StaticResource DialogSectionTitle}"/>
                        <UniformGrid Columns="2" Rows="2">
                            <Button x:Name="OpenFolderBtn"
                                    Style="{StaticResource PropertyActionButton}"
                                    Margin="0,0,6,6"
                                    Click="OpenFolderBtn_Click"/>
                            <Button x:Name="OpenAoE3FolderBtn"
                                    Style="{StaticResource PropertyActionButton}"
                                    Margin="6,0,0,6"
                                    Click="OpenAoE3FolderBtn_Click"/>
                            <Button x:Name="ChangeModFolderBtn"
                                    Style="{StaticResource PropertyActionButton}"
                                    Margin="0,6,6,0"
                                    Click="ChangeModFolderBtn_Click"/>
                            <Button x:Name="ChangeAoE3FolderBtn"
                                    Style="{StaticResource PropertyActionButton}"
                                    Margin="6,6,0,0"
                                    Click="ChangeAoE3FolderBtn_Click"/>
                        </UniformGrid>

                        <Border Style="{StaticResource DialogDivider}"/>

                        <!-- Maintenance -->
                        <TextBlock x:Name="LblMaintenanceSection"
                                   Style="{StaticResource DialogSectionTitle}"/>
                        <UniformGrid Columns="2" Rows="1">
                            <Button x:Name="VerifyBtn"
                                    Style="{StaticResource PropertyActionButton}"
                                    Margin="0,0,6,0"
                                    Click="VerifyBtn_Click"/>
                            <Button x:Name="RepairBtn"
                                    Style="{StaticResource PropertyActionButton}"
                                    Margin="6,0,0,0"
                                    Click="RepairBtn_Click"/>
                        </UniformGrid>

                        <Border Style="{StaticResource DialogDivider}"/>

                        <!-- Diagnostics -->
                        <TextBlock x:Name="LblDiagnosticsSection"
                                   Style="{StaticResource DialogSectionTitle}"/>
                        <Button x:Name="ViewLogsBtn"
                                Style="{StaticResource PropertyActionButton}"
                                HorizontalAlignment="Left"
                                MinWidth="220"
                                Click="ViewLogsBtn_Click"/>

                        <Border Style="{StaticResource DialogDivider}"/>

                        <!-- Danger zone — flat, no red card border. The
                             red title + red description + the actual
                             red Uninstall button are enough to read as
                             "destructive area". -->
                        <TextBlock x:Name="LblDangerZone"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   FontSize="{StaticResource FontSizeSubtitle}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="LblDangerZoneDesc"
                                   Style="{StaticResource DialogActionDesc}"
                                   Margin="0,0,0,14"/>
                        <Button x:Name="UninstallBtn"
                                Style="{StaticResource DangerButton}"
                                HorizontalAlignment="Left"
                                MinWidth="220"
                                Click="UninstallBtn_Click"/>
                    </StackPanel>

                    <!-- ===================================================
                         USER DATA TAB — Steam-style settings rows. Each
                         row: title + description on the left, action
                         button on the right. Dividers separate rows.
                         =================================================== -->
                    <StackPanel x:Name="UserDataPanel" Visibility="Collapsed">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,18,0">
                                <TextBlock x:Name="LblOpenUserDataTitle"
                                           Style="{StaticResource DialogActionTitle}"/>
                                <TextBlock x:Name="LblOpenUserDataDesc"
                                           Style="{StaticResource DialogActionDesc}"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    x:Name="OpenUserDataFolderBtn"
                                    Style="{StaticResource PropertyActionButton}"
                                    MinWidth="120"
                                    VerticalAlignment="Center"
                                    Click="OpenUserDataFolderBtn_Click"/>
                        </Grid>

                        <Border Style="{StaticResource DialogDivider}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,18,0">
                                <TextBlock x:Name="LblCreateBackupTitle"
                                           Style="{StaticResource DialogActionTitle}"/>
                                <TextBlock x:Name="LblCreateBackupDesc"
                                           Style="{StaticResource DialogActionDesc}"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    x:Name="CreateBackupBtn"
                                    Style="{StaticResource PropertyActionButton}"
                                    MinWidth="120"
                                    VerticalAlignment="Center"
                                    Click="CreateBackupBtn_Click"/>
                        </Grid>

                        <Border Style="{StaticResource DialogDivider}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,18,0">
                                <TextBlock x:Name="LblRestoreBackupTitle"
                                           Style="{StaticResource DialogActionTitle}"/>
                                <TextBlock x:Name="LblRestoreBackupDesc"
                                           Style="{StaticResource DialogActionDesc}"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    x:Name="RestoreBackupBtn"
                                    Style="{StaticResource PropertyActionButton}"
                                    MinWidth="120"
                                    VerticalAlignment="Center"
                                    Click="RestoreBackupBtn_Click"/>
                        </Grid>
                    </StackPanel>

                    <!-- ===================================================
                         LANGUAGE TAB
                         =================================================== -->
                    <StackPanel x:Name="LanguagePanel" Visibility="Collapsed">
                        <TextBlock x:Name="LblLanguageSectionTitle"
                                   Style="{StaticResource DialogSectionTitle}"/>
                        <TextBlock x:Name="LblLanguageDesc"
                                   Style="{StaticResource DialogActionDesc}"
                                   Margin="0,0,0,14"/>
                        <Button x:Name="RefreshTranslationsBtn"
                                Style="{StaticResource PropertyActionButton}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,14"
                                Click="RefreshTranslationsBtn_Click"/>
                        <TextBlock x:Name="LblLanguageCurrent"
                                   Style="{StaticResource DialogFieldLabel}"
                                   Margin="0,0,0,6"/>
                        <StackPanel x:Name="LanguageCardList" MaxWidth="520" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="LanguageEmptyHint"
                                   Foreground="{DynamicResource OnSecondaryContainer}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Margin="0,10,0,0"
                                   Visibility="Collapsed"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
