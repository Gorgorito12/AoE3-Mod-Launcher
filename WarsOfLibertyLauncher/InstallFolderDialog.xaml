<Window x:Class="WarsOfLibertyLauncher.InstallFolderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WarsOfLibertyLauncher.Controls"
        Title="Install"
        Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">

  <Grid>
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <controls:TitleBar Grid.Row="0" x:Name="TitleBarControl"
                       ShowMinimize="False" ShowMaximize="False" ShowClose="True"/>
    <StackPanel Grid.Row="1" Margin="24">
        <!-- Header -->
        <TextBlock x:Name="HeaderText"
                   FontSize="{StaticResource FontSizeHeading}" FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,4"/>
        <TextBlock x:Name="DescriptionText"
                   FontSize="{StaticResource FontSizeBody}"
                   Foreground="#aaa"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <!-- AoE3 folder (always visible) -->
        <TextBlock x:Name="LblAoE3Folder"
                   FontSize="{StaticResource FontSizeCaption}"
                   Foreground="#888"
                   Margin="0,0,0,4"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="Aoe3PathTextBox"
                     Grid.Column="0"
                     FontSize="{StaticResource FontSizeBody}"
                     Background="{DynamicResource BgPanelAlt}"
                     Foreground="White"
                     BorderBrush="{DynamicResource BorderSubtle}"
                     BorderThickness="1"
                     Padding="8,6"
                     CaretBrush="White"
                     IsReadOnly="True"/>
            <Button x:Name="BrowseAoE3InDialogButton"
                    Grid.Column="1"
                    Style="{StaticResource DialogButton}"
                    Margin="8,0,0,0"
                    Click="BrowseAoE3InDialogButton_Click"/>
        </Grid>

        <!-- AoE3 status (color-coded inline message) -->
        <TextBlock x:Name="Aoe3StatusText"
                   FontSize="{StaticResource FontSizeCaption}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,14"/>

        <!-- Destination folder -->
        <TextBlock x:Name="LblFolder"
                   FontSize="{StaticResource FontSizeCaption}"
                   Foreground="#888"
                   Margin="0,0,0,4"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FolderTextBox"
                     Grid.Column="0"
                     FontSize="{StaticResource FontSizeBody}"
                     Background="{DynamicResource BgPanelAlt}"
                     Foreground="White"
                     BorderBrush="{DynamicResource BorderSubtle}"
                     BorderThickness="1"
                     Padding="8,6"
                     CaretBrush="White"
                     TextChanged="FolderTextBox_TextChanged"/>
            <Button x:Name="BrowseButton"
                    Grid.Column="1"
                    Style="{StaticResource DialogButton}"
                    Margin="8,0,0,0"
                    Click="BrowseButton_Click"/>
        </Grid>

        <!-- Disk space -->
        <TextBlock x:Name="DiskSpaceText"
                   FontSize="{StaticResource FontSizeCaption}"
                   Foreground="#888"
                   Margin="0,0,0,8"/>

        <!-- Validation warning -->
        <TextBlock x:Name="WarningText"
                   FontSize="{StaticResource FontSizeCaption}"
                   Foreground="{DynamicResource ErrorBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Style="{StaticResource DialogButton}"
                    MinWidth="100"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button x:Name="OkButton"
                    Style="{StaticResource PrimaryButton}"
                    MinWidth="120"
                    IsDefault="True"
                    Click="OkButton_Click"/>
        </StackPanel>
    </StackPanel>
  </Grid>
</Window>
