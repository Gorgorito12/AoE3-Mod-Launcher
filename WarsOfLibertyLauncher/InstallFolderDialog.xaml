<Window x:Class="WarsOfLibertyLauncher.InstallFolderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Install Wars of Liberty"
        Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1d24"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Background" Value="#3a3d44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4a4d54"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#2a2d34"/>
                                <Setter Property="Foreground" Value="#666"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#c8102e"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e63950"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3a3d44"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">
        <!-- Header -->
        <TextBlock x:Name="HeaderText"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,4"/>
        <TextBlock x:Name="DescriptionText"
                   FontSize="12"
                   Foreground="#aaa"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <!-- AoE3 detected (green) -->
        <Border x:Name="Aoe3DetectionPanel"
                Background="#1f3a1f"
                BorderBrush="#3a8c3a"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,8"
                Margin="0,0,0,14"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="Aoe3DetectionTitleText"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#9bd99b"
                           Margin="0,0,0,2"/>
                <TextBlock x:Name="Aoe3DetectionPathText"
                           FontSize="12"
                           Foreground="White"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- AoE3 NOT detected (orange) -->
        <Border x:Name="Aoe3NotDetectedPanel"
                Background="#3a2a1a"
                BorderBrush="#8c6c3a"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,8"
                Margin="0,0,0,14"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="Aoe3NotDetectedText"
                           FontSize="11"
                           Foreground="#d4a04a"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>
                <Button x:Name="BrowseAoE3InDialogButton"
                        Background="#8c6c3a"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Padding="12,6"
                        HorizontalAlignment="Left"
                        Click="BrowseAoE3InDialogButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#a88040"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- Destination folder -->
        <TextBlock x:Name="LblFolder"
                   FontSize="11"
                   Foreground="#888"
                   Margin="0,0,0,4"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FolderTextBox"
                     Grid.Column="0"
                     FontSize="13"
                     Background="#2a2d34"
                     Foreground="White"
                     BorderBrush="#3a3d44"
                     BorderThickness="1"
                     Padding="8,6"
                     CaretBrush="White"
                     TextChanged="FolderTextBox_TextChanged"/>
            <Button x:Name="BrowseButton"
                    Grid.Column="1"
                    Style="{StaticResource DialogButton}"
                    Margin="8,0,0,0"
                    Click="BrowseButton_Click"/>
        </Grid>

        <!-- Disk space -->
        <TextBlock x:Name="DiskSpaceText"
                   FontSize="11"
                   Foreground="#888"
                   Margin="0,0,0,8"/>

        <!-- Validation warning -->
        <TextBlock x:Name="WarningText"
                   FontSize="11"
                   Foreground="#e63950"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Style="{StaticResource DialogButton}"
                    MinWidth="100"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button x:Name="OkButton"
                    Style="{StaticResource PrimaryButton}"
                    MinWidth="120"
                    IsDefault="True"
                    Click="OkButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
