<Window x:Class="WarsOfLibertyLauncher.GitHubLoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WarsOfLibertyLauncher.Controls"
        Title="Discord sign-in"
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">
  <Grid>
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <controls:TitleBar Grid.Row="0" x:Name="TitleBarControl"
                       ShowMinimize="False" ShowMaximize="False" ShowClose="True"/>
    <Grid Grid.Row="1" Margin="28,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="TitleText"
                   Foreground="{DynamicResource TextPrimary}"
                   FontSize="{StaticResource FontSizeHeading}"
                   FontWeight="Bold"/>

        <TextBlock Grid.Row="1"
                   x:Name="Step1Text"
                   Foreground="{DynamicResource TextSecondary}"
                   FontSize="{StaticResource FontSizeBody}"
                   TextWrapping="Wrap"
                   Margin="0,14,0,6"/>

        <!-- The verification URI + Open browser button. -->
        <Border Grid.Row="2"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="VerificationUriText"
                           Foreground="{DynamicResource TextPrimary}"
                           FontFamily="Consolas, Courier New, monospace"
                           FontSize="{StaticResource FontSizeBody}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="1"
                        x:Name="OpenBrowserButton"
                        Click="OpenBrowserButton_Click"
                        Style="{StaticResource SidebarPrimaryButton}"
                        Padding="14,6"
                        MinWidth="120"/>
            </Grid>
        </Border>

        <!-- Step 2 + code panel are only shown for legacy device-code
             flows (GitHub-style) where the user has to type a code
             into the browser. Discord skips this step entirely, so
             we hide both rows when the server returns an empty
             user_code. -->
        <TextBlock Grid.Row="3"
                   x:Name="Step2Text"
                   Foreground="{DynamicResource TextSecondary}"
                   FontSize="{StaticResource FontSizeBody}"
                   TextWrapping="Wrap"
                   Margin="0,18,0,6"/>

        <!-- Big user code + Copy button. -->
        <Border Grid.Row="4"
                x:Name="UserCodeBorder"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="UserCodeText"
                           Foreground="{DynamicResource TextPrimary}"
                           FontFamily="Consolas, Courier New, monospace"
                           FontSize="{StaticResource FontSizeDisplay}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        x:Name="CopyButton"
                        Click="CopyButton_Click"
                        Style="{StaticResource SidebarPrimaryButton}"
                        Padding="14,6"
                        MinWidth="120"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Privacy consent line — links to PRIVACY.md (the policy is also
             reachable from Launcher Settings → Privacy). Built in code-behind
             (PrivacyConsentBlock.Inlines) so the localized prefix + hyperlink
             compose cleanly across EN/ES. -->
        <TextBlock Grid.Row="5"
                   x:Name="PrivacyConsentBlock"
                   Foreground="{DynamicResource TextSecondary}"
                   FontSize="{StaticResource FontSizeCaption}"
                   TextWrapping="Wrap"
                   Margin="0,18,0,0"/>

        <!-- Status row (waiting…) + Cancel. -->
        <Grid Grid.Row="6" Margin="0,22,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       x:Name="StatusText"
                       Foreground="{DynamicResource TextSecondary}"
                       FontSize="{StaticResource FontSizeBody}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    x:Name="CancelButton"
                    Click="CancelButton_Click"
                    Style="{StaticResource SidebarPrimaryButton}"
                    Padding="18,6"
                    MinWidth="110"/>
        </Grid>
    </Grid>
  </Grid>
</Window>
