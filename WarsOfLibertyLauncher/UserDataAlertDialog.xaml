<Window x:Class="WarsOfLibertyLauncher.UserDataAlertDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Datos de versión anterior detectados"
        Width="600" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1d24"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Background" Value="#3a3d44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4a4d54"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#c8102e"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e63950"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">
        <!-- Header -->
        <TextBlock x:Name="HeaderText"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,4"/>
        <TextBlock x:Name="DescriptionText"
                   FontSize="12"
                   Foreground="#aaa"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <!-- Orange warning panel with the detected path -->
        <Border Background="#3a2a1a"
                BorderBrush="#8c6c3a"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,10"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="WarningTitleText"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#d4a04a"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="UserDataPathText"
                           FontSize="12"
                           Foreground="White"
                           TextWrapping="Wrap"
                           FontFamily="Consolas"/>
                <TextBlock x:Name="SavegameCountText"
                           FontSize="11"
                           Foreground="#d4a04a"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- Recommendation text -->
        <TextBlock x:Name="RecommendationText"
                   FontSize="12"
                   Foreground="#ccc"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <!-- Buttons row -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OpenFolderButton"
                    Style="{StaticResource DialogButton}"
                    MinWidth="120"
                    Margin="0,0,8,0"
                    Click="OpenFolderButton_Click"/>
            <Button x:Name="IgnoreButton"
                    Style="{StaticResource DialogButton}"
                    MinWidth="120"
                    Margin="0,0,8,0"
                    Click="IgnoreButton_Click"/>
            <Button x:Name="BackupButton"
                    Style="{StaticResource PrimaryButton}"
                    MinWidth="180"
                    IsDefault="True"
                    Click="BackupButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
