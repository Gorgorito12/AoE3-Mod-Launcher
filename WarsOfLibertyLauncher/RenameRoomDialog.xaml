<Window x:Class="WarsOfLibertyLauncher.RenameRoomDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WarsOfLibertyLauncher.Controls"
        Title="Rename room"
        Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBase}"
        ShowInTaskbar="False">
  <Grid>
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <controls:TitleBar x:Name="TitleBarControl" Grid.Row="0" Title="Rename room"
                       ShowMinimize="False" ShowMaximize="False" ShowClose="True"/>
    <StackPanel Grid.Row="1" Margin="24,20">
        <TextBlock x:Name="PromptText"
                   Foreground="{DynamicResource TextPrimary}"
                   FontSize="{StaticResource FontSizeBody}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>
        <TextBox x:Name="NameEntry"
                 Background="#2a2d34"
                 Foreground="White"
                 BorderBrush="#3a3d44"
                 BorderThickness="1"
                 Padding="8,5"
                 FontSize="{StaticResource FontSizeBody}"
                 MaxLength="80"
                 TextChanged="NameEntry_TextChanged"/>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelButton"
                    Click="CancelButton_Click"
                    Style="{StaticResource SidebarPrimaryButton}"
                    Background="#3a3d44"
                    Padding="18,6"
                    MinWidth="100"
                    Margin="0,0,8,0"
                    Content="Cancel"/>
            <Button x:Name="OkButton"
                    Click="OkButton_Click"
                    IsDefault="True"
                    Style="{StaticResource SidebarPrimaryButton}"
                    Padding="18,6"
                    MinWidth="100"
                    Content="OK"/>
        </StackPanel>
    </StackPanel>
  </Grid>
</Window>
